# Auto detect text files and perform LF normalization
* text=auto

# Source code
*.cs text diff=csharp
*.cshtml text
*.csproj text
*.sln text
*.config text
*.json text
*.xml text
*.yml text
*.yaml text

# Documentation
*.md text
*.txt text

# Scripts
*.sh text eol=lf
*.ps1 text eol=crlf
*.bat text eol=crlf
*.cmd text eol=crlf

# Web files
*.html text
*.htm text
*.css text
*.scss text
*.sass text
*.js text
*.ts text
*.jsx text
*.tsx text

# Configuration files
.gitignore text
.gitattributes text
.editorconfig text

# Images
*.jpg binary
*.jpeg binary
*.png binary
*.gif binary
*.ico binary
*.svg text
*.bmp binary
*.tiff binary
*.webp binary

# Fonts
*.ttf binary
*.otf binary
*.woff binary
*.woff2 binary
*.eot binary

# Documents
*.pdf binary
*.doc binary
*.docx binary
*.xls binary
*.xlsx binary
*.ppt binary
*.pptx binary

# Archives
*.zip binary
*.7z binary
*.rar binary
*.tar binary
*.gz binary

# Database
*.db binary
*.sqlite binary
*.sqlite3 binary
*.mdf binary
*.ldf binary

# Other binary files
*.dll binary
*.exe binary
*.so binary
*.dylib binary

# Export diffs for specific file types
*.csproj merge=union

