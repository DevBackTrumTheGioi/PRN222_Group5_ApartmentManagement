@page
@model PRN222_ApartmentManagement.Pages.Account.ChangePasswordModel
@{
    ViewData["Title"] = "Đổi mật khẩu";
    ViewData["CurrentPage"] = "changepassword";
}

<div class="container mx-auto px-4 py-8">
    <div class="max-w-md mx-auto bg-white rounded-xl shadow-md overflow-hidden md:max-w-2xl p-6">
        <h2 class="text-2xl font-bold text-slate-900 mb-6">Đổi mật khẩu</h2>

        @if (!string.IsNullOrEmpty(Model.SuccessMessage))
        {
            <div class="bg-emerald-100 border border-emerald-400 text-emerald-700 px-4 py-3 rounded mb-4">
                @Model.SuccessMessage
            </div>
        }

        @if (!ModelState.IsValid)
        {
            <div class="bg-red-100 border border-red-400 text-red-700 px-4 py-3 rounded mb-4">
                <div asp-validation-summary="All"></div>
            </div>
        }

        <form method="post" class="space-y-4">
            <div>
                <label asp-for="Input.OldPassword" class="block text-sm font-medium text-slate-700 mb-1">Mật khẩu cũ</label>
                <input asp-for="Input.OldPassword" type="password" class="w-full px-3 py-2 border border-slate-300 rounded-md focus:outline-none focus:ring-2 focus:ring-emerald-500" />
                <span asp-validation-for="Input.OldPassword" class="text-red-500 text-xs"></span>
            </div>
            <div>
                <label asp-for="Input.NewPassword" class="block text-sm font-medium text-slate-700 mb-1">Mật khẩu mới</label>
                <input asp-for="Input.NewPassword" type="password" class="w-full px-3 py-2 border border-slate-300 rounded-md focus:outline-none focus:ring-2 focus:ring-emerald-500" />
                <span asp-validation-for="Input.NewPassword" class="text-red-500 text-xs"></span>
            </div>
            <div>
                <label asp-for="Input.ConfirmPassword" class="block text-sm font-medium text-slate-700 mb-1">Xác nhận mật khẩu mới</label>
                <input asp-for="Input.ConfirmPassword" type="password" class="w-full px-3 py-2 border border-slate-300 rounded-md focus:outline-none focus:ring-2 focus:ring-emerald-500" />
                <span asp-validation-for="Input.ConfirmPassword" class="text-red-500 text-xs"></span>
            </div>
            <div class="pt-4">
                <button type="submit" class="w-full bg-emerald-600 text-white font-bold py-2 px-4 rounded-md hover:bg-emerald-700 transition duration-300">
                    Cập nhật mật khẩu
                </button>
            </div>
        </form>
    </div>
</div>

