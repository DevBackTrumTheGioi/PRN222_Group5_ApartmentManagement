@page
@model PRN222_ApartmentManagement.Pages.Account.ForgotPasswordModel
@{
    ViewData["Title"] = "Quên mật khẩu";
    Layout = null;
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Apartment Management</title>
    <script src="https://cdn.tailwindcss.com"></script>
</head>
<body class="bg-gray-100 h-screen flex items-center justify-center">
    <div class="bg-white p-8 rounded-lg shadow-md w-full max-w-md">
        <h2 class="text-2xl font-bold mb-6 text-center text-gray-800">Quên mật khẩu</h2>
        <p class="text-slate-600 text-sm mb-6 text-center">Vui lòng nhập tên đăng nhập hoặc email, mật khẩu mới sẽ được gửi qua Email.</p>

        @if (!string.IsNullOrEmpty(Model.Message))
        {
            <div class="bg-emerald-100 border border-emerald-400 text-emerald-700 px-4 py-3 rounded mb-4">
                @Model.Message
            </div>
        }

        @if (!ModelState.IsValid)
        {
            <div class="bg-red-100 border border-red-400 text-red-700 px-4 py-3 rounded mb-4">
                <div asp-validation-summary="All"></div>
            </div>
        }

        <form method="post">
            <div class="mb-6">
                <label asp-for="UsernameOrEmail" class="block text-sm font-medium text-gray-700 mb-1">Tài khoản hoặc Email</label>
                <input asp-for="UsernameOrEmail" class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-blue-500" placeholder="Username or Email" />
                <span asp-validation-for="UsernameOrEmail" class="text-red-500 text-xs mt-1"></span>
            </div>
            
            <button type="submit" class="w-full bg-blue-600 text-white font-bold py-2 px-4 rounded-md hover:bg-blue-700 transition duration-300">
                Gửi mật khẩu mới
            </button>
            <div class="mt-4 text-center">
                <a asp-page="/Account/Login" class="text-sm text-blue-600 hover:underline">Quay lại đăng nhập</a>
            </div>
        </form>
    </div>
</body>
</html>

