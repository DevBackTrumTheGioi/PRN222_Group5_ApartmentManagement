@page
@model PRN222_ApartmentManagement.Pages.Account.InactiveModel
@{
    ViewData["Title"] = "Tài khoản chưa kích hoạt";
    Layout = null;
}

<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Apartment Management</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
    <link href="https://fonts.googleapis.com/icon?family=Material+Icons" rel="stylesheet">
    <script src="https://cdn.tailwindcss.com"></script>
</head>
<body class="bg-slate-50 font-['Inter'] min-h-screen flex items-center justify-center px-4">
    <div class="w-full max-w-md bg-white border border-slate-200 rounded-2xl shadow-sm p-8 text-center space-y-6">
        <div class="mx-auto w-14 h-14 rounded-full bg-amber-100 text-amber-600 flex items-center justify-center">
            <span class="material-icons text-3xl">pending_actions</span>
        </div>

        <div class="space-y-2">
            <h1 class="text-2xl font-bold tracking-tight text-slate-900">Tài khoản chưa được kích hoạt</h1>
            <p class="text-sm text-slate-600">
                Tài khoản của bạn hiện chưa thể đăng nhập. Vui lòng hoàn tất bước kích hoạt tài khoản trước khi tiếp tục.
            </p>
        </div>

        <div class="rounded-xl border border-amber-200 bg-amber-50 px-4 py-3 text-sm text-amber-700">
            Bạn có thể quay lại màn hình đăng nhập và thử lại sau khi tài khoản đã được kích hoạt.
        </div>

        <a asp-page="/Account/Login"
           class="inline-flex items-center justify-center w-full rounded-lg bg-emerald-600 px-4 py-2.5 text-sm font-medium text-white hover:bg-emerald-700 transition-colors">
            Quay lại đăng nhập
        </a>
    </div>
</body>
</html>
