@page
@model PRN222_ApartmentManagement.Pages.Account.ProfileModel
@{
    ViewData["Title"] = "Hồ sơ cá nhân";
    ViewData["CurrentPage"] = "profile";
}

<div class="container mx-auto px-4 py-8">
    <div class="grid gap-6 lg:grid-cols-[320px,1fr]">
        <div class="rounded-2xl border border-slate-200 bg-white p-6 shadow-sm">
            <div class="flex items-center gap-4">
                <div class="flex h-16 w-16 items-center justify-center rounded-2xl bg-emerald-100 text-emerald-600">
                    <span class="material-icons text-3xl">person</span>
                </div>
                <div>
                    <h2 class="text-xl font-bold text-slate-900">@Model.CurrentUser.FullName</h2>
                    <p class="text-sm text-slate-500">@Model.CurrentUser.Username</p>
                </div>
            </div>

            <dl class="mt-6 space-y-4 text-sm">
                <div>
                    <dt class="text-slate-500">Vai trò</dt>
                    <dd class="font-medium text-slate-800">@Model.RoleDisplayName</dd>
                </div>
                <div>
                    <dt class="text-slate-500">Email</dt>
                    <dd class="font-medium text-slate-800">@(string.IsNullOrWhiteSpace(Model.CurrentUser.Email) ? "Chưa cập nhật" : Model.CurrentUser.Email)</dd>
                </div>
                <div>
                    <dt class="text-slate-500">Số điện thoại</dt>
                    <dd class="font-medium text-slate-800">@(string.IsNullOrWhiteSpace(Model.CurrentUser.PhoneNumber) ? "Chưa cập nhật" : Model.CurrentUser.PhoneNumber)</dd>
                </div>
                @if (!string.IsNullOrWhiteSpace(Model.ApartmentDisplay))
                {
                    <div>
                        <dt class="text-slate-500">Căn hộ</dt>
                        <dd class="font-medium text-slate-800">@Model.ApartmentDisplay</dd>
                    </div>
                }
            </dl>
        </div>

        <div class="rounded-2xl border border-slate-200 bg-white p-6 shadow-sm">
            <h2 class="text-2xl font-bold text-slate-900">Cập nhật hồ sơ</h2>
            <p class="mt-1 text-sm text-slate-500">Chỉnh sửa thông tin cá nhân dùng chung cho mọi tài khoản trong hệ thống.</p>

            @if (!string.IsNullOrWhiteSpace(Model.SuccessMessage))
            {
                <div class="mt-6 rounded-xl border border-emerald-200 bg-emerald-50 px-4 py-3 text-sm text-emerald-700">
                    @Model.SuccessMessage
                </div>
            }

            @if (!ModelState.IsValid)
            {
                <div class="mt-6 rounded-xl border border-red-200 bg-red-50 px-4 py-3 text-sm text-red-700">
                    <div asp-validation-summary="All"></div>
                </div>
            }

            <form method="post" class="mt-6 space-y-5">
                <div class="grid gap-5 md:grid-cols-2">
                    <div>
                        <label asp-for="Input.FullName" class="mb-1 block text-sm font-medium text-slate-700"></label>
                        <input asp-for="Input.FullName" class="w-full rounded-lg border border-slate-300 px-3 py-2 focus:outline-none focus:ring-2 focus:ring-emerald-500" />
                        <span asp-validation-for="Input.FullName" class="text-xs text-red-500"></span>
                    </div>

                    <div>
                        <label class="mb-1 block text-sm font-medium text-slate-700">Tên đăng nhập</label>
                        <input value="@Model.CurrentUser.Username" class="w-full rounded-lg border border-slate-200 bg-slate-50 px-3 py-2 text-slate-500" disabled />
                    </div>

                    <div>
                        <label asp-for="Input.Email" class="mb-1 block text-sm font-medium text-slate-700"></label>
                        <input asp-for="Input.Email" class="w-full rounded-lg border border-slate-300 px-3 py-2 focus:outline-none focus:ring-2 focus:ring-emerald-500" />
                        <span asp-validation-for="Input.Email" class="text-xs text-red-500"></span>
                    </div>

                    <div>
                        <label asp-for="Input.PhoneNumber" class="mb-1 block text-sm font-medium text-slate-700"></label>
                        <input asp-for="Input.PhoneNumber" class="w-full rounded-lg border border-slate-300 px-3 py-2 focus:outline-none focus:ring-2 focus:ring-emerald-500" />
                        <span asp-validation-for="Input.PhoneNumber" class="text-xs text-red-500"></span>
                    </div>

                    <div>
                        <label asp-for="Input.DateOfBirth" class="mb-1 block text-sm font-medium text-slate-700"></label>
                        <input asp-for="Input.DateOfBirth" type="date" class="w-full rounded-lg border border-slate-300 px-3 py-2 focus:outline-none focus:ring-2 focus:ring-emerald-500" />
                        <span asp-validation-for="Input.DateOfBirth" class="text-xs text-red-500"></span>
                    </div>

                    <div>
                        <label asp-for="Input.IdentityCardNumber" class="mb-1 block text-sm font-medium text-slate-700"></label>
                        <input asp-for="Input.IdentityCardNumber" class="w-full rounded-lg border border-slate-300 px-3 py-2 focus:outline-none focus:ring-2 focus:ring-emerald-500" />
                        <span asp-validation-for="Input.IdentityCardNumber" class="text-xs text-red-500"></span>
                    </div>
                </div>

                <div>
                    <label asp-for="Input.Note" class="mb-1 block text-sm font-medium text-slate-700"></label>
                    <textarea asp-for="Input.Note" rows="4" class="w-full rounded-lg border border-slate-300 px-3 py-2 focus:outline-none focus:ring-2 focus:ring-emerald-500"></textarea>
                    <span asp-validation-for="Input.Note" class="text-xs text-red-500"></span>
                </div>

                <div class="flex justify-end">
                    <button type="submit" class="rounded-lg bg-emerald-600 px-5 py-2.5 font-semibold text-white transition hover:bg-emerald-700">
                        Lưu thay đổi
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
