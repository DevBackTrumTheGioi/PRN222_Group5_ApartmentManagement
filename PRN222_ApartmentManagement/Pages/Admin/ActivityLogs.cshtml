@page
@model PRN222_ApartmentManagement.Pages.Admin.ActivityLogsModel
@{
    ViewData["Title"] = "Activity Logs";
}

<div class="p-6 space-y-6">
    @await Html.PartialAsync("Components/PageHeader", new { 
        Title = "Activity Logs",
        BreadcrumbItems = new[] {
            new { Label = "Admin", Href = "/Admin" },
            new { Label = "Activity Logs", Href = "#" }
        }
    })

    <!-- Filter Form - Using Select Components -->
    <div class="bg-white rounded-xl shadow-sm border border-slate-200 p-6">
        <form method="get" class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-5 gap-4">
            <div>
                <label class="block text-sm font-medium text-slate-700 mb-1">Từ ngày</label>
                <input type="date" name="fromDate" class="w-full rounded-lg border-slate-300 shadow-sm focus:border-primary-500 focus:ring-primary-500 text-sm transition-all" value="@Model.FromDate?.ToString("yyyy-MM-dd")">
            </div>
            <div>
                <label class="block text-sm font-medium text-slate-700 mb-1">Đến ngày</label>
                <input type="date" name="toDate" class="w-full rounded-lg border-slate-300 shadow-sm focus:border-primary-500 focus:ring-primary-500 text-sm transition-all" value="@Model.ToDate?.ToString("yyyy-MM-dd")">
            </div>
            
            @await Html.PartialAsync("Components/Select", new {
                Label = "Hành động",
                Name = "action",
                Value = Model.Action,
                Items = new[] {
                    new { Text = "-- Tất cả --", Value = "" },
                    new { Text = "Thêm mới", Value = "Create" },
                    new { Text = "Cập nhật", Value = "Update" },
                    new { Text = "Xóa", Value = "Delete" },
                    new { Text = "Đăng nhập", Value = "Login" },
                    new { Text = "Đăng xuất", Value = "Logout" }
                }
            })

            <div>
                <label class="block text-sm font-medium text-slate-700 mb-1">Đối tượng</label>
                <input type="text" name="entityName" class="w-full rounded-lg border-slate-300 shadow-sm focus:border-primary-500 focus:ring-primary-500 text-sm transition-all" placeholder="Ví dụ: Apartment..." value="@Model.EntityName">
            </div>
            <div class="flex items-end">
                <button type="submit" class="w-full bg-primary-600 hover:bg-primary-700 text-white font-medium py-2 px-4 rounded-lg transition-all shadow-sm flex items-center justify-center gap-2">
                    <span class="material-icons text-sm">search</span>
                    Lọc dữ liệu
                </button>
            </div>
        </form>
    </div>

    <!-- Logs Table - Using DataTable Component -->
    @await Html.PartialAsync("Components/DataTable", new {
        Title = "Activity Logs",
        ShowSearch = false,
        ShowPagination = true,
        CurrentPage = Model.PageNumber,
        TotalPages = Model.TotalPages,
        TotalItems = Model.Logs.Count, // Note: Simplified
        ItemsPerPage = Model.PageSize,
        Columns = new object[] {
            new { Header = "Thời gian", Field = "Timestamp", Align = "left", Type = "text", BadgeClassField = "" },
            new { Header = "Người dùng", Field = "UserDisplay", Align = "left", Type = "user", BadgeClassField = "" },
            new { Header = "Hành động", Field = "Action", Align = "left", Type = "badge", BadgeClassField = "ActionBadgeClass" },
            new { Header = "Đối tượng", Field = "EntityDisplay", Align = "left", Type = "text", BadgeClassField = "" },
            new { Header = "Mô tả", Field = "Description", Align = "left", Type = "text", BadgeClassField = "" },
            new { Header = "Trạng thái", Field = "StatusDisplay", Align = "left", Type = "status_component", BadgeClassField = "" },
            new { Header = "IP", Field = "IpAddress", Align = "left", Type = "text", BadgeClassField = "" }
        },
        Rows = Model.Logs.Select(log => new {
            PrimaryId = log.LogId,
            ActionType = "details",
            Timestamp = log.Timestamp.ToString("dd/MM/yyyy HH:mm:ss"),
            UserDisplay = new { Name = log.UserName, Subtitle = log.UserRole },
            Action = log.Action,
            ActionBadgeClass = GetActionBadgeClass(log.Action),
            EntityDisplay = $"{log.EntityName} (ID: {log.EntityId})",
            Description = log.Description,
            StatusDisplay = new { 
                Label = log.IsSuccess ? "Thành công" : "Thất bại",
                Type = log.IsSuccess ? "success" : "danger",
                Icon = log.IsSuccess ? "check_circle" : "cancel"
            },
            IpAddress = log.IpAddress
        })
    })
</div>

@await Html.PartialAsync("Components/Modal", new { 
    Id = "logDetailsModal",
    Title = "Log Details",
    Size = "lg"
})

@section Scripts {
    <script>
        function viewDetails(logId) {
            // Hiển thị modal và có thể load dữ liệu qua AJAX nếu cần
            const modal = document.getElementById('logDetailsModal');
            if (modal) {
                modal.classList.remove('hidden');
                modal.classList.add('flex');
            }
        }
        
        function closeModal() {
            const modal = document.getElementById('logDetailsModal');
            if (modal) {
                modal.classList.add('hidden');
                modal.classList.remove('flex');
            }
        }
    </script>
}

@functions {
    private string GetActionBadgeClass(string action)
    {
        return action switch
        {
            "Create" => "bg-green-100 text-green-800",
            "Update" => "bg-amber-100 text-amber-800",
            "Delete" => "bg-red-100 text-red-800",
            "Login" => "bg-blue-100 text-blue-800",
            "Logout" => "bg-slate-100 text-slate-800",
            _ => "bg-slate-100 text-slate-800"
        };
    }
}
