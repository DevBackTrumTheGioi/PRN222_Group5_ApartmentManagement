@page
@model PRN222_ApartmentManagement.Pages.Admin.Amenities.IndexModel
@{
    ViewData["Title"] = "Quản lý tiện ích";
}

<div class="space-y-4">
    <div class="flex justify-between items-center">
        <h1 class="text-xl font-bold">Quản lý Tiện ích</h1>
        <a class="btn btn-primary" asp-page="Create">Thêm tiện ích</a>
    </div>

    <table class="w-full text-sm bg-white rounded border-collapse table-auto">
        <thead>
            <tr class="text-left text-xs text-slate-500 uppercase">
                <th class="px-4 py-3">Tên</th>
                <th class="px-4 py-3">Loại</th>
                <th class="px-4 py-3">Vị trí</th>
                <th class="px-4 py-3">Sức chứa</th>
                <th class="px-4 py-3">Giá/giờ</th>
                <th class="px-4 py-3">Trạng thái</th>
                <th class="px-4 py-3">Hành động</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var a in Model.Amenities)
            {
                <tr class="border-t">
                    <td class="px-4 py-3">@a.AmenityName</td>
                    <td class="px-4 py-3">@a.AmenityType?.TypeName</td>
                    <td class="px-4 py-3">@a.Location</td>
                    <td class="px-4 py-3">@a.Capacity</td>
                    <td class="px-4 py-3">@String.Format("{0:N0}", a.PricePerHour ?? 0)</td>
                    <td class="px-4 py-3">@if (a.IsActive) { <span class="text-emerald-600">Active</span> } else { <span class="text-slate-500">Inactive</span> }</td>
                    <td class="px-4 py-3">
                        <a class="text-indigo-600 hover:underline mr-3" asp-page="Edit" asp-route-id="@a.AmenityId">Sửa</a>

                        <form method="post" asp-page-handler="ToggleActive" class="inline">
                            <input type="hidden" name="id" value="@a.AmenityId" />
                            <button type="submit" class="text-sm text-slate-600 hover:text-emerald-600 mr-3">@((a.IsActive) ? "Tắt" : "Bật")</button>
                        </form>

                        <form method="post" asp-page-handler="Delete" class="inline" onsubmit="return confirm('Bạn có chắc muốn xóa tiện ích này?');">
                            <input type="hidden" name="id" value="@a.AmenityId" />
                            <button type="submit" class="text-sm text-rose-600 hover:underline">Xóa</button>
                        </form>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>
