@page
@model PRN222_ApartmentManagement.Pages.Admin.IndexModel
@{
    ViewData["Title"] = "Admin Dashboard";
    ViewData["Subtitle"] = "Quản trị hệ thống và cấu hình";
    ViewData["CurrentPage"] = "dashboard";
}

<div class="space-y-6">
    <!-- Quick Stats -->
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6">
        <div class="bg-white p-6 rounded-2xl border border-slate-200 shadow-sm">
            <div class="flex items-center gap-4">
                <div class="w-12 h-12 bg-blue-50 text-blue-600 rounded-xl flex items-center justify-center">
                    <span class="material-icons">group</span>
                </div>
                <div>
                    <p class="text-sm text-slate-500 font-medium">Người dùng</p>
                    <h3 class="text-2xl font-bold">@Model.DashboardData.TotalUsers</h3>
                </div>
            </div>
            <div class="mt-4 flex items-center text-xs">
                <span class="text-emerald-500 font-medium flex items-center">
                    <span class="material-icons text-xs">arrow_upward</span> @Model.DashboardData.ActiveUsers Đang hoạt động
                </span>
            </div>
        </div>

        <div class="bg-white p-6 rounded-2xl border border-slate-200 shadow-sm">
            <div class="flex items-center gap-4">
                <div class="w-12 h-12 bg-emerald-50 text-emerald-600 rounded-xl flex items-center justify-center">
                    <span class="material-icons">domain</span>
                </div>
                <div>
                    <p class="text-sm text-slate-500 font-medium">Căn hộ</p>
                    <h3 class="text-2xl font-bold">@Model.DashboardData.TotalApartments</h3>
                </div>
            </div>
            <div class="mt-4 flex items-center text-xs">
                <span class="text-slate-500 font-medium">
                    @Model.DashboardData.OccupiedApartments / @Model.DashboardData.TotalApartments Đã có người ở
                </span>
            </div>
        </div>

        <div class="bg-white p-6 rounded-2xl border border-slate-200 shadow-sm">
            <div class="flex items-center gap-4">
                <div class="w-12 h-12 bg-amber-50 text-amber-600 rounded-xl flex items-center justify-center">
                    <span class="material-icons">security</span>
                </div>
                <div>
                    <p class="text-sm text-slate-500 font-medium">Vai trò</p>
                    <h3 class="text-2xl font-bold">@Model.DashboardData.UsersByRole.Count</h3>
                </div>
            </div>
            <div class="mt-4 flex items-center text-xs">
                <span class="text-slate-500 font-medium">Cấu hình phân quyền hệ thống</span>
            </div>
        </div>

        <div class="bg-white p-6 rounded-2xl border border-slate-200 shadow-sm">
            <div class="flex items-center gap-4">
                <div class="w-12 h-12 bg-rose-50 text-rose-600 rounded-xl flex items-center justify-center">
                    <span class="material-icons">history</span>
                </div>
                <div>
                    <p class="text-sm text-slate-500 font-medium">Log Hệ thống</p>
                    <h3 class="text-2xl font-bold">Logs</h3>
                </div>
            </div>
            <div class="mt-4 flex items-center text-xs">
                <a href="/Admin/ActivityLogs" class="text-rose-600 font-medium hover:underline">Xem tất cả hoạt động</a>
            </div>
        </div>
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-3 gap-6">
        <!-- Chart/Distribution placeholder -->
        <div class="lg:col-span-2 bg-white p-6 rounded-2xl border border-slate-200 shadow-sm">
            <h3 class="text-lg font-bold mb-6">Phân bổ người dùng theo vai trò</h3>
            <div class="space-y-4">
                @foreach (var roleStat in Model.DashboardData.UsersByRole)
                {
                    var percentage = Model.DashboardData.TotalUsers > 0 
                        ? (roleStat.Count * 100 / Model.DashboardData.TotalUsers) 
                        : 0;
                    <div>
                        <div class="flex justify-between items-center mb-1">
                            <span class="text-sm font-medium text-slate-700">@roleStat.Role</span>
                            <span class="text-sm text-slate-500">@roleStat.Count (@percentage%)</span>
                        </div>
                        <div class="w-full bg-slate-100 rounded-full h-2">
                            <div class="bg-emerald-500 h-2 rounded-full" style="width: @percentage%"></div>
                        </div>
                    </div>
                }
            </div>
        </div>

        <!-- System Status -->
        <div class="bg-white p-6 rounded-2xl border border-slate-200 shadow-sm">
            <h3 class="text-lg font-bold mb-4">Trạng thái hệ thống</h3>
            <div class="space-y-4">
                <div class="flex items-center justify-between p-3 bg-slate-50 rounded-xl">
                    <div class="flex items-center gap-3">
                        <div class="w-2 h-2 bg-emerald-500 rounded-full"></div>
                        <span class="text-sm font-medium">Cơ sở dữ liệu</span>
                    </div>
                    <span class="text-xs text-emerald-600 font-bold uppercase tracking-wider">Ổn định</span>
                </div>
                <div class="flex items-center justify-between p-3 bg-slate-50 rounded-xl">
                    <div class="flex items-center gap-3">
                        <div class="w-2 h-2 bg-emerald-500 rounded-full"></div>
                        <span class="text-sm font-medium">Dịch vụ Email</span>
                    </div>
                    <span class="text-xs text-emerald-600 font-bold uppercase tracking-wider">Ổn định</span>
                </div>
                <div class="flex items-center justify-between p-3 bg-slate-50 rounded-xl">
                    <div class="flex items-center gap-3">
                        <div class="w-2 h-2 bg-emerald-500 rounded-full"></div>
                        <span class="text-sm font-medium">Dịch vụ Face Auth</span>
                    </div>
                    <span class="text-xs text-emerald-600 font-bold uppercase tracking-wider">Ổn định</span>
                </div>
            </div>
            
            <div class="mt-8">
                <h4 class="text-sm font-semibold text-slate-900 mb-4">Lối tắt cấu hình</h4>
                <div class="grid grid-cols-2 gap-3">
                    <a href="/Admin/Settings" class="p-3 border border-slate-200 rounded-xl text-center hover:bg-slate-50 transition-colors">
                        <span class="material-icons text-slate-400 block mb-1">settings</span>
                        <span class="text-xs font-medium">Cài đặt</span>
                    </a>
                    <a href="/Admin/SeedData" class="p-3 border border-slate-200 rounded-xl text-center hover:bg-slate-50 transition-colors">
                        <span class="material-icons text-slate-400 block mb-1">storage</span>
                        <span class="text-xs font-medium">Seed Data</span>
                    </a>
                </div>
            </div>
        </div>
    </div>
</div>

