@page
@model PRN222_ApartmentManagement.Pages.Admin.Users.CreateModel
@{
    ViewData["Title"] = "Thêm người dùng mới";
    ViewData["CurrentPage"] = "users";
    Layout = "_AdminLayout";
    ViewData["PageHeader"] = new { 
        Title = "Thêm người dùng mới",
        BreadcrumbItems = new[] {
            new { Label = "Admin", Href = "/Admin" },
            new { Label = "Quản lý người dùng", Href = "/Admin/Users" },
            new { Label = "Thêm người dùng", Href = "#" }
        }
    };
}

<div class="max-w-3xl mx-auto space-y-6">
    <div class="flex items-center gap-2 mb-2">
        <a asp-page="./Index" class="inline-flex items-center text-sm text-slate-500 hover:text-emerald-600 transition-colors">
            <span class="material-icons text-lg mr-1">arrow_back</span>
            Quay lại danh sách
        </a>
    </div>

    <form method="post" class="bg-white rounded-xl shadow-sm border border-slate-200 overflow-hidden">
        <div class="p-6 space-y-6">
            @if (!ModelState.IsValid)
            {
                <div class="p-4 bg-red-50 border border-red-200 rounded-lg">
                    <div asp-validation-summary="All" class="text-sm text-red-600"></div>
                </div>
            }

            <!-- Basic Info -->
            <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                <div class="space-y-2">
                    <label asp-for="Input.FullName" class="text-sm font-medium text-slate-700">Họ và tên <span class="text-red-500">*</span></label>
                    <input asp-for="Input.FullName" placeholder="Nhập họ tên đầy đủ" 
                           class="w-full px-4 py-2 border border-slate-200 rounded-lg focus:outline-none focus:ring-2 focus:ring-emerald-500 transition-all text-sm" />
                    <span asp-validation-for="Input.FullName" class="text-red-500 text-xs"></span>
                </div>
                <div class="space-y-2">
                    <label asp-for="Input.Username" class="text-sm font-medium text-slate-700">Tên đăng nhập <span class="text-red-500">*</span></label>
                    <input asp-for="Input.Username" placeholder="Nhập tên đăng nhập" 
                           class="w-full px-4 py-2 border border-slate-200 rounded-lg focus:outline-none focus:ring-2 focus:ring-emerald-500 transition-all text-sm" />
                    <span asp-validation-for="Input.Username" class="text-red-500 text-xs"></span>
                </div>
                <div class="space-y-2">
                    <label asp-for="Input.Email" class="text-sm font-medium text-slate-700">Email <span class="text-red-500">*</span></label>
                    <input asp-for="Input.Email" type="email" placeholder="email@example.com" 
                           class="w-full px-4 py-2 border border-slate-200 rounded-lg focus:outline-none focus:ring-2 focus:ring-emerald-500 transition-all text-sm" />
                    <span asp-validation-for="Input.Email" class="text-red-500 text-xs"></span>
                </div>
                <div class="space-y-2">
                    <label asp-for="Input.PhoneNumber" class="text-sm font-medium text-slate-700">Số điện thoại</label>
                    <input asp-for="Input.PhoneNumber" placeholder="Số điện thoại liên lạc" 
                           class="w-full px-4 py-2 border border-slate-200 rounded-lg focus:outline-none focus:ring-2 focus:ring-emerald-500 transition-all text-sm" />
                    <span asp-validation-for="Input.PhoneNumber" class="text-red-500 text-xs"></span>
                </div>
                <div class="space-y-2">
                    <label asp-for="Input.Password" class="text-sm font-medium text-slate-700">Mật khẩu <span class="text-red-500">*</span></label>
                    <input asp-for="Input.Password" type="password" placeholder="Nhập mật khẩu" 
                           class="w-full px-4 py-2 border border-slate-200 rounded-lg focus:outline-none focus:ring-2 focus:ring-emerald-500 transition-all text-sm" />
                    <span asp-validation-for="Input.Password" class="text-red-500 text-xs"></span>
                </div>
                <div class="space-y-2">
                    <label asp-for="Input.Role" class="text-sm font-medium text-slate-700">Vai trò <span class="text-red-500">*</span></label>
                    <select asp-for="Input.Role" class="w-full px-4 py-2 border border-slate-200 rounded-lg focus:outline-none focus:ring-2 focus:ring-emerald-500 transition-all text-sm bg-white">
                        <option value="">-- Chọn vai trò --</option>
                        @foreach (var role in Enum.GetValues<PRN222_ApartmentManagement.Models.UserRole>())
                        {
                            <option value="@role">@role</option>
                        }
                    </select>
                    <span asp-validation-for="Input.Role" class="text-red-500 text-xs"></span>
                </div>
            </div>

            <div class="flex items-center gap-2">
                <input asp-for="Input.IsActive" type="checkbox" class="w-4 h-4 text-emerald-600 border-slate-300 rounded focus:ring-emerald-500" />
                <label asp-for="Input.IsActive" class="text-sm text-slate-700">Kích hoạt tài khoản ngay sau khi tạo</label>
            </div>

            <!-- Resident Specific Info (Visible only when Resident, BQT_Head, or BQT_Member role is selected) -->
            <div id="residentFields" class="border-t border-slate-100 pt-6 space-y-6 @(Model.Input.Role == PRN222_ApartmentManagement.Models.UserRole.Resident || Model.Input.Role == PRN222_ApartmentManagement.Models.UserRole.BQT_Head || Model.Input.Role == PRN222_ApartmentManagement.Models.UserRole.BQT_Member ? "" : "hidden")">
                <h3 class="text-md font-semibold text-slate-800">Thông tin cư dân</h3>
                <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                    <div class="space-y-2">
                        <label asp-for="Input.DateOfBirth" class="text-sm font-medium text-slate-700">Ngày sinh</label>
                        <input asp-for="Input.DateOfBirth" type="date" class="w-full px-4 py-2 border border-slate-200 rounded-lg focus:outline-none focus:ring-2 focus:ring-emerald-500 transition-all text-sm" />
                    </div>
                    <div class="space-y-2">
                        <label asp-for="Input.IdentityCardNumber" class="text-sm font-medium text-slate-700">Số CMND/CCCD</label>
                        <input asp-for="Input.IdentityCardNumber" placeholder="Nhập số CMND/CCCD" class="w-full px-4 py-2 border border-slate-200 rounded-lg focus:outline-none focus:ring-2 focus:ring-emerald-500 transition-all text-sm" />
                    </div>
                    <div class="space-y-2">
                        <label asp-for="Input.ResidentType" class="text-sm font-medium text-slate-700">Loại cư dân</label>
                        <select asp-for="Input.ResidentType" class="w-full px-4 py-2 border border-slate-200 rounded-lg focus:outline-none focus:ring-2 focus:ring-emerald-500 transition-all text-sm bg-white">
                            <option value="">-- Chọn loại cư dân --</option>
                            @foreach (var type in Enum.GetValues<PRN222_ApartmentManagement.Models.ResidentType>())
                            {
                                <option value="@type">@type</option>
                            }
                        </select>
                    </div>
                    <div class="space-y-2">
                        <label asp-for="Input.ResidencyStatus" class="text-sm font-medium text-slate-700">Trạng thái cư trú</label>
                        <input asp-for="Input.ResidencyStatus" placeholder="VD: Thường trú, Tạm trú" class="w-full px-4 py-2 border border-slate-200 rounded-lg focus:outline-none focus:ring-2 focus:ring-emerald-500 transition-all text-sm" />
                    </div>
                    <div class="space-y-2">
                        <label asp-for="Input.ApartmentId" class="text-sm font-medium text-slate-700">Căn hộ</label>
                        <select asp-for="Input.ApartmentId" class="w-full px-4 py-2 border border-slate-200 rounded-lg focus:outline-none focus:ring-2 focus:ring-emerald-500 transition-all text-sm bg-white">
                            <option value="">-- Chọn căn hộ --</option>
                            @foreach (var apt in Model.Apartments)
                            {
                                <option value="@apt.ApartmentId">@apt.ApartmentNumber (@apt.BuildingBlock)</option>
                            }
                        </select>
                    </div>
                    <div class="space-y-2">
                        <label asp-for="Input.MoveInDate" class="text-sm font-medium text-slate-700">Ngày chuyển vào</label>
                        <input asp-for="Input.MoveInDate" type="date" class="w-full px-4 py-2 border border-slate-200 rounded-lg focus:outline-none focus:ring-2 focus:ring-emerald-500 transition-all text-sm" />
                    </div>
                </div>
                <div class="space-y-2">
                    <label asp-for="Input.Note" class="text-sm font-medium text-slate-700">Ghi chú</label>
                    <textarea asp-for="Input.Note" rows="3" placeholder="Nhập ghi chú chi tiết..." class="w-full px-4 py-2 border border-slate-200 rounded-lg focus:outline-none focus:ring-2 focus:ring-emerald-500 transition-all text-sm"></textarea>
                </div>
            </div>
        </div>

        <div class="bg-slate-50 px-6 py-4 border-t border-slate-200 flex items-center justify-end gap-3">
            <a asp-page="./Index" class="px-4 py-2 text-slate-600 hover:bg-slate-100 rounded-lg transition-colors text-sm font-medium">Hủy</a>
            <button type="submit" class="px-4 py-2 bg-emerald-600 text-white rounded-lg hover:bg-emerald-700 transition-colors text-sm font-medium">
                Tạo người dùng
            </button>
        </div>
    </form>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        document.addEventListener('DOMContentLoaded', function() {
            const roleSelect = document.querySelector('select[name="Input.Role"]');
            const residentFields = document.getElementById('residentFields');

            roleSelect.addEventListener('change', function() {
                const residentRoles = ['Resident', 'BQT_Head', 'BQT_Member'];
                if (residentRoles.includes(this.value)) {
                    residentFields.classList.remove('hidden');
                } else {
                    residentFields.classList.add('hidden');
                }
            });
        });
    </script>
}
