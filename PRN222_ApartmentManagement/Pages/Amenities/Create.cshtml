@page
@model PRN222_ApartmentManagement.Pages.Amenities.CreateModel
@{
    ViewData["Title"] = "Thêm tiện ích";
}

<div class="max-w-3xl">
    <div class="bg-white p-6 rounded-xl border shadow-sm">
        <h2 class="text-lg font-bold mb-4">Thêm tiện ích</h2>

        <form method="post">
            <div class="space-y-4">
                <fieldset class="p-4 bg-slate-50 border rounded-lg">
                    <legend class="text-sm font-medium text-slate-700 px-2">Thông tin chính</legend>
                    <div class="grid grid-cols-1 md:grid-cols-2 gap-4 mt-2">
                        <div>
                            <label class="block text-sm text-slate-700">Tên tiện ích</label>
                            <input asp-for="Input.AmenityName" class="form-input w-full" />
                            <span asp-validation-for="Input.AmenityName" class="text-rose-600 text-sm"></span>
                        </div>

                        <div>
                            <label class="block text-sm text-slate-700">Loại</label>
                            <select asp-for="Input.AmenityTypeId" class="form-select w-full">
                                <option value="">-- Chọn loại --</option>
                                @foreach (var t in Model.AmenityTypes)
                                {
                                    <option value="@t.AmenityTypeId">@t.TypeName</option>
                                }
                            </select>
                        </div>

                        <div>
                            <label class="block text-sm text-slate-700">Vị trí</label>
                            <input asp-for="Input.Location" class="form-input w-full" />
                        </div>

                        <div>
                            <label class="block text-sm text-slate-700">Sức chứa</label>
                            <input asp-for="Input.Capacity" class="form-input w-full" />
                        </div>

                        <div>
                            <label class="block text-sm text-slate-700">Giá / giờ</label>
                            <input asp-for="Input.PricePerHour" class="form-input w-full" />
                        </div>

                        <div>
                            <label class="block text-sm text-slate-700">Kích hoạt</label>
                            <div class="mt-2">
                                <input type="checkbox" asp-for="Input.IsActive" class="mr-2" /> <span class="text-sm">Đang hoạt động</span>
                            </div>
                        </div>
                    </div>
                </fieldset>

                <fieldset class="p-4 bg-slate-50 border rounded-lg">
                    <legend class="text-sm font-medium text-slate-700 px-2">Mô tả & Ghi chú</legend>
                    <div class="mt-2">
                        <label class="block text-sm text-slate-700">Mô tả</label>
                        <textarea asp-for="Input.Description" class="form-textarea w-full"></textarea>
                    </div>
                </fieldset>

                <div class="flex items-center gap-3">
                    <button type="submit" class="btn btn-primary">Lưu</button>
                    <a asp-page="Index" class="btn btn-secondary">Hủy</a>
                </div>
            </div>
        </form>
    </div>
</div>

@section Scripts{
    <partial name="_ValidationScriptsPartial" />
}
