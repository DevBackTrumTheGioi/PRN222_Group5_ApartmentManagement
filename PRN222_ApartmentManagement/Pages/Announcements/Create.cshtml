@page
@model PRN222_ApartmentManagement.Pages.Announcements.CreateModel
@using PRN222_ApartmentManagement.Models.Enums
@using PRN222_ApartmentManagement.Utils
@{
    ViewData["Title"] = "Tạo thông báo";
    ViewData["CurrentPage"] = "announcements";
}

<div class="max-w-4xl mx-auto space-y-6">
    <a asp-page="Index" class="inline-flex items-center text-sm text-slate-500 hover:text-emerald-600 transition-colors">
        <span class="material-icons text-lg mr-1">arrow_back</span>
        Quay lại danh sách
    </a>

    <div class="bg-white rounded-xl border border-slate-200 shadow-sm overflow-hidden">
        <div class="px-6 py-4 border-b border-slate-100 bg-slate-50">
            <h2 class="text-lg font-bold text-slate-900">@Model.AnnouncementActionLabel</h2>
        </div>

        <form method="post" enctype="multipart/form-data" class="p-6 space-y-6">
            @if (!ViewData.ModelState.IsValid)
            {
                <div class="p-4 bg-red-50 border border-red-200 rounded-lg">
                    <div asp-validation-summary="All" class="text-sm text-red-600"></div>
                </div>
            }

            <div class="space-y-2">
                <label asp-for="Input.Title" class="text-sm font-medium text-slate-700">Tiêu đề <span class="text-red-500">*</span></label>
                <input asp-for="Input.Title" class="w-full px-4 py-2 border border-slate-200 rounded-lg focus:outline-none focus:ring-2 focus:ring-emerald-500 text-sm" />
                <span asp-validation-for="Input.Title" class="text-xs text-red-500"></span>
            </div>

            <div class="space-y-2">
                <label asp-for="Input.Content" class="text-sm font-medium text-slate-700">Nội dung <span class="text-red-500">*</span></label>
                <textarea asp-for="Input.Content" rows="6" class="w-full px-4 py-2 border border-slate-200 rounded-lg focus:outline-none focus:ring-2 focus:ring-emerald-500 text-sm"></textarea>
                <span asp-validation-for="Input.Content" class="text-xs text-red-500"></span>
            </div>

            <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                <div class="space-y-2">
                    <label asp-for="Input.AnnouncementType" class="text-sm font-medium text-slate-700">Loại thông báo</label>
                    <select asp-for="Input.AnnouncementType" class="w-full px-4 py-2 border border-slate-200 rounded-lg focus:outline-none focus:ring-2 focus:ring-emerald-500 text-sm bg-white">
                        <option value="">-- Chọn loại --</option>
                        @foreach (var type in Enum.GetValues<AnnouncementType>())
                        {
                            <option value="@type">@type.GetDisplayName()</option>
                        }
                    </select>
                </div>

                <div class="space-y-2">
                    <label asp-for="Input.Priority" class="text-sm font-medium text-slate-700">Mức độ ưu tiên <span class="text-red-500">*</span></label>
                    <select asp-for="Input.Priority" class="w-full px-4 py-2 border border-slate-200 rounded-lg focus:outline-none focus:ring-2 focus:ring-emerald-500 text-sm bg-white">
                        @foreach (var priority in Enum.GetValues<AnnouncementPriority>())
                        {
                            <option value="@priority">@priority.GetDisplayName()</option>
                        }
                    </select>
                    <span asp-validation-for="Input.Priority" class="text-xs text-red-500"></span>
                </div>

                <div class="space-y-2">
                    <label asp-for="Input.PublishedDate" class="text-sm font-medium text-slate-700">Ngày đăng <span class="text-red-500">*</span></label>
                    <input asp-for="Input.PublishedDate" type="datetime-local" class="w-full px-4 py-2 border border-slate-200 rounded-lg focus:outline-none focus:ring-2 focus:ring-emerald-500 text-sm" />
                    <span asp-validation-for="Input.PublishedDate" class="text-xs text-red-500"></span>
                </div>

                <div class="space-y-2">
                    <label asp-for="Input.ExpiryDate" class="text-sm font-medium text-slate-700">Ngày hết hạn</label>
                    <input asp-for="Input.ExpiryDate" type="datetime-local" class="w-full px-4 py-2 border border-slate-200 rounded-lg focus:outline-none focus:ring-2 focus:ring-emerald-500 text-sm" />
                    <span asp-validation-for="Input.ExpiryDate" class="text-xs text-red-500"></span>
                </div>
            </div>

            <div class="flex items-center gap-2">
                <input asp-for="Input.IsActive" type="checkbox" class="w-4 h-4 text-emerald-600 border-slate-300 rounded focus:ring-emerald-500" />
                <label asp-for="Input.IsActive" class="text-sm text-slate-700">Kích hoạt ngay sau khi đăng</label>
            </div>

            <div class="space-y-2">
                <label for="attachments" class="text-sm font-medium text-slate-700">Tệp đính kèm (ảnh/video/file)</label>
                <input type="file"
                       id="attachments"
                       name="Attachments"
                       multiple
                       accept="image/*,video/*,.pdf,.doc,.docx,.xls,.xlsx,.txt,.zip"
                       class="w-full px-4 py-2 border border-slate-200 rounded-lg focus:outline-none focus:ring-2 focus:ring-emerald-500 text-sm bg-white" />
                <p class="text-xs text-slate-400">Tối đa 10 tệp, mỗi tệp tối đa 20MB.</p>
                <span asp-validation-for="Attachments" class="text-xs text-red-500"></span>
            </div>

            <div class="flex items-center justify-end gap-3 pt-4 border-t border-slate-100">
                <a asp-page="Index" class="px-4 py-2 text-slate-600 hover:bg-slate-100 rounded-lg text-sm font-medium">Hủy</a>
                <button type="submit" class="px-4 py-2 bg-emerald-600 text-white rounded-lg hover:bg-emerald-700 text-sm font-medium">Lưu thông báo</button>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
