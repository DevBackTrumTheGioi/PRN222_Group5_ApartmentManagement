@page "{id:int}"
@model PRN222_ApartmentManagement.Pages.Announcements.DetailsModel
@{
    ViewData["Title"] = "Chi tiết thông báo";
    ViewData["CurrentPage"] = "announcements";
}

<div class="max-w-5xl mx-auto space-y-6">
    <a asp-page="/Announcements/View" class="inline-flex items-center text-sm text-slate-500 hover:text-emerald-600 transition-colors">
        <span class="material-icons text-lg mr-1">arrow_back</span>
        Quay lại danh sách thông báo
    </a>

    <div class="bg-white border border-slate-200 rounded-2xl p-6 shadow-sm space-y-4">
        <div class="flex flex-wrap items-center gap-2">
            <span class="px-2 py-0.5 rounded-full text-xs font-semibold @(Model.Announcement.Source == "BQT" ? "bg-violet-100 text-violet-700" : "bg-blue-100 text-blue-700")">@Model.Announcement.Source</span>
            <span class="px-2 py-0.5 rounded-full text-xs font-semibold bg-slate-100 text-slate-700">@Model.Announcement.Priority</span>
            <span class="text-xs text-slate-400">Đăng lúc @Model.Announcement.PublishedDate.ToString("dd/MM/yyyy HH:mm")</span>
        </div>

        <h2 class="text-2xl font-bold text-slate-900">@Model.Announcement.Title</h2>
        <p class="text-sm text-slate-600 whitespace-pre-line">@Model.Announcement.Content</p>

        @if (Model.Announcement.Attachments.Any())
        {
            <div class="pt-4 border-t border-slate-100">
                <h3 class="text-sm font-semibold text-slate-800 mb-3">Tệp đính kèm</h3>
                <div class="space-y-3">
                    @foreach (var file in Model.Announcement.Attachments.OrderByDescending(x => x.UploadedAt))
                    {
                        var isImage = file.ContentType?.StartsWith("image/") == true;
                        var isVideo = file.ContentType?.StartsWith("video/") == true;

                        <div class="p-3 border border-slate-200 rounded-lg bg-slate-50">
                            <div class="flex items-center justify-between gap-3 mb-2">
                                <p class="text-sm font-medium text-slate-800 truncate">@file.FileName</p>
                                <a href="@file.FilePath" target="_blank" class="text-xs font-semibold text-emerald-600 hover:underline shrink-0">Mở tệp</a>
                            </div>

                            @if (isImage)
                            {
                                <img src="@file.FilePath" alt="@file.FileName" class="max-h-72 rounded border border-slate-200" />
                            }
                            else if (isVideo)
                            {
                                <video controls class="w-full max-h-80 rounded border border-slate-200">
                                    <source src="@file.FilePath" type="@file.ContentType" />
                                </video>
                            }
                        </div>
                    }
                </div>
            </div>
        }
    </div>
</div>
