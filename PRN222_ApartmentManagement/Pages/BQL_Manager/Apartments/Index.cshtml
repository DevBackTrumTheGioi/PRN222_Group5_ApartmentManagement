@page
@using PRN222_ApartmentManagement.Models.Enums
@model PRN222_ApartmentManagement.Pages.BQL_Manager.Apartments.IndexModel
@{
    ViewData["Title"] = "Quản lý căn hộ";
    Layout = "_Layout";
    ViewData["CurrentPage"] = "apartments";
    ViewData["PageHeader"] = new
    {
        Title = "Quản lý căn hộ",
        BreadcrumbItems = new[]
        {
            new { Label = "BQL Manager", Href = "/BQL_Manager" },
            new { Label = "Căn hộ", Href = "#" }
        }
    };
}

<div class="space-y-6">

    @* ===== STATS ROW ===== *@
    <section class="grid grid-cols-2 gap-4 md:grid-cols-4">
        <div class="rounded-xl border border-slate-200 bg-white p-5 shadow-sm">
            <div class="flex items-start justify-between gap-4">
                <div>
                    <p class="text-sm font-medium text-slate-500">Tổng căn hộ</p>
                    <p class="mt-3 text-3xl font-bold tracking-tight text-slate-900">@Model.Total</p>
                    <p class="mt-1 text-xs text-slate-400">Tất cả căn hộ</p>
                </div>
                <div class="flex h-11 w-11 items-center justify-center rounded-xl bg-blue-50 text-blue-600">
                    <span class="material-icons">apartment</span>
                </div>
            </div>
        </div>
        <div class="rounded-xl border border-emerald-200 bg-white p-5 shadow-sm">
            <div class="flex items-start justify-between gap-4">
                <div>
                    <p class="text-sm font-medium text-emerald-600">Trống</p>
                    <p class="mt-3 text-3xl font-bold tracking-tight text-emerald-700">@Model.AvailableCount</p>
                    <p class="mt-1 text-xs text-emerald-400">Sẵn sàng cho thuê</p>
                </div>
                <div class="flex h-11 w-11 items-center justify-center rounded-xl bg-emerald-100 text-emerald-600">
                    <span class="material-icons">check_circle</span>
                </div>
            </div>
        </div>
        <div class="rounded-xl border border-blue-200 bg-white p-5 shadow-sm">
            <div class="flex items-start justify-between gap-4">
                <div>
                    <p class="text-sm font-medium text-blue-600">Đang ở</p>
                    <p class="mt-3 text-3xl font-bold tracking-tight text-blue-700">@Model.OccupiedCount</p>
                    <p class="mt-1 text-xs text-blue-400">Đã có cư dân</p>
                </div>
                <div class="flex h-11 w-11 items-center justify-center rounded-xl bg-blue-50 text-blue-500">
                    <span class="material-icons">group</span>
                </div>
            </div>
        </div>
        <div class="rounded-xl border border-violet-200 bg-white p-5 shadow-sm">
            <div class="flex items-start justify-between gap-4">
                <div>
                    <p class="text-sm font-medium text-violet-600">Đã đặt</p>
                    <p class="mt-3 text-3xl font-bold tracking-tight text-violet-700">@Model.ReservedCount</p>
                    <p class="mt-1 text-xs text-violet-400">Chờ ký HĐ</p>
                </div>
                <div class="flex h-11 w-11 items-center justify-center rounded-xl bg-violet-50 text-violet-500">
                    <span class="material-icons">description</span>
                </div>
            </div>
        </div>
    </section>

    @* ===== STATUS MESSAGE ===== *@
    @if (!string.IsNullOrWhiteSpace(Model.StatusMessage))
    {
        <div class="rounded-xl border border-emerald-200 bg-emerald-50 px-4 py-3 text-sm text-emerald-700 flex items-center gap-2">
            <span class="material-icons text-base">check_circle</span>
            @Model.StatusMessage
        </div>
    }

    @* ===== FILTER FORM ===== *@
    <section class="rounded-xl border border-slate-200 bg-white p-6 shadow-sm">
        <div class="mb-5 flex items-start justify-between gap-4">
            <div>
                <h2 class="text-lg font-semibold text-slate-900">Bộ lọc căn hộ</h2>
                <p class="mt-1 text-sm text-slate-500">Tìm kiếm và lọc căn hộ theo trạng thái.</p>
            </div>
            <div class="flex h-10 w-10 items-center justify-center rounded-xl bg-slate-100 text-slate-600">
                <span class="material-icons">filter_alt</span>
            </div>
        </div>

        <form method="get" class="space-y-3">
            @* Row 1: Search + Status *@
            <div class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-4 gap-3">
                <div class="sm:col-span-2">
                    <input id="SearchTerm" name="searchTerm" value="@Model.SearchTerm"
                           placeholder="Tìm số căn hộ, block..."
                           class="w-full rounded-lg border border-slate-200 px-4 py-2.5 text-sm text-slate-900 placeholder-slate-400 focus:outline-none focus:ring-2 focus:ring-emerald-500" />
                </div>
                <div>
                    <select id="StatusFilter" name="statusfilter"
                            class="w-full rounded-lg border border-slate-200 bg-white px-4 py-2.5 text-sm text-slate-900 focus:outline-none focus:ring-2 focus:ring-emerald-500">
                        <option value="">Tất cả trạng thái</option>
                        <option value="Available" selected="@(Model.StatusFilter == ApartmentStatus.Available)">Trống</option>
                        <option value="Occupied" selected="@(Model.StatusFilter == ApartmentStatus.Occupied)">Đang ở</option>
                        <option value="Reserved" selected="@(Model.StatusFilter == ApartmentStatus.Reserved)">Đã đặt</option>
                    </select>
                </div>
                <div>
                    <select id="TypeFilter" name="typeFilter"
                            class="w-full rounded-lg border border-slate-200 bg-white px-4 py-2.5 text-sm text-slate-900 focus:outline-none focus:ring-2 focus:ring-emerald-500">
                        <option value="">Loại căn hộ</option>
                        <option value="Studio" selected="@(Model.TypeFilter == "Studio")">Studio</option>
                        <option value="1 Phòng ngủ" selected="@(Model.TypeFilter == "1 Phòng ngủ")">1 Phòng ngủ</option>
                        <option value="2 Phòng ngủ" selected="@(Model.TypeFilter == "2 Phòng ngủ")">2 Phòng ngủ</option>
                        <option value="3 Phòng ngủ" selected="@(Model.TypeFilter == "3 Phòng ngủ")">3 Phòng ngủ</option>
                        <option value="Penthouse" selected="@(Model.TypeFilter == "Penthouse")">Penthouse</option>
                        <option value="Căn hộ thương mại" selected="@(Model.TypeFilter == "Căn hộ thương mại")">Căn hộ thương mại</option>
                    </select>
                </div>
            </div>

            @* Row 2: Block + Floor + Buttons *@
            <div class="grid grid-cols-1 sm:grid-cols-3 md:grid-cols-4 gap-3">
                <div>
                    <select id="BlockFilter" name="blockFilter"
                            class="w-full rounded-lg border border-slate-200 bg-white px-4 py-2.5 text-sm text-slate-900 focus:outline-none focus:ring-2 focus:ring-emerald-500">
                        <option value="">Block</option>
                        @foreach (var block in Model.AvailableBlocks)
                        {
                            <option value="@block" selected="@(Model.BlockFilter == block)">Block @block</option>
                        }
                    </select>
                </div>
                <div>
                    <select id="FloorFilter" name="floorFilter"
                            class="w-full rounded-lg border border-slate-200 bg-white px-4 py-2.5 text-sm text-slate-900 focus:outline-none focus:ring-2 focus:ring-emerald-500">
                        <option value="">Tầng</option>
                        @foreach (var floor in Model.AvailableFloors)
                        {
                            <option value="@floor" selected="@(Model.FloorFilter == floor)">Tầng @floor</option>
                        }
                    </select>
                </div>
                <div class="sm:col-span-2 md:col-span-2 flex items-center gap-2 sm:justify-end">
                    <button type="submit" class="inline-flex items-center gap-2 rounded-lg bg-emerald-600 px-5 py-2.5 text-sm font-medium text-white transition-colors hover:bg-emerald-700">
                        <span class="material-icons text-base">filter_alt</span>
                        Lọc
                    </button>
                    <a asp-page="./Index" class="inline-flex items-center gap-2 rounded-lg border border-slate-200 px-4 py-2.5 text-sm font-medium text-slate-600 transition-colors hover:bg-slate-50">
                        <span class="material-icons text-base">restart_alt</span>
                        Xóa lọc
                    </a>
                </div>
            </div>
        </form>
    </section>

    @* ===== TABLE ===== *@
    <section class="overflow-hidden rounded-xl border border-slate-200 bg-white shadow-sm">
        <div class="px-6 py-4 border-b border-slate-100 flex items-center justify-between">
            <div>
                <h3 class="text-base font-semibold text-slate-900">Danh sách căn hộ</h3>
                <p class="text-xs text-slate-500 mt-0.5">@Model.TotalItems căn hộ</p>
            </div>
            <div class="flex items-center gap-3">
                @if (User.IsInRole("Admin"))
                {
                    <a asp-page="Create" class="inline-flex items-center gap-2 rounded-lg bg-emerald-600 px-4 py-2 text-sm font-medium text-white transition-colors hover:bg-emerald-700">
                        <span class="material-icons text-base">add</span>
                        Thêm căn hộ
                    </a>
                }
            </div>
        </div>

        @if (Model.Rows.Any())
        {
            <div class="overflow-x-auto">
                <table class="w-full text-sm">
                    <thead class="bg-slate-50 text-slate-500">
                        <tr>
                            <th class="px-6 py-3 text-left text-xs font-semibold uppercase tracking-wide">Căn hộ</th>
                            <th class="px-6 py-3 text-left text-xs font-semibold uppercase tracking-wide">Block / Tầng</th>
                            <th class="px-6 py-3 text-left text-xs font-semibold uppercase tracking-wide">Loại</th>
                            <th class="px-6 py-3 text-left text-xs font-semibold uppercase tracking-wide">Diện tích</th>
                            <th class="px-6 py-3 text-left text-xs font-semibold uppercase tracking-wide">Trạng thái</th>
                            <th class="px-6 py-3 text-left text-xs font-semibold uppercase tracking-wide">Ngày tạo</th>
                            <th class="px-6 py-3 text-right text-xs font-semibold uppercase tracking-wide">Thao tác</th>
                        </tr>
                    </thead>
                    <tbody class="divide-y divide-slate-100">
                        @foreach (var row in Model.Rows)
                        {
                            <tr class="hover:bg-slate-50 transition-colors">
                                <td class="px-6 py-4">
                                    <p class="font-bold text-slate-900">@row.ApartmentNumber</p>
                                </td>
                                <td class="px-6 py-4">
                                    <p class="text-slate-700">@(string.IsNullOrWhiteSpace(row.BuildingBlock) || row.BuildingBlock == "—" ? "—" : $"Block {row.BuildingBlock}")</p>
                                    <p class="text-xs text-slate-400">Tầng @row.Floor</p>
                                </td>
                                <td class="px-6 py-4 text-slate-600">@row.ApartmentType</td>
                                <td class="px-6 py-4 text-slate-600">
                                    @(row.Area.HasValue ? $"{row.Area:0.##} m²" : "—")
                                </td>
                                <td class="px-6 py-4">
                                    <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium @row.StatusCss">
                                        @row.StatusLabel
                                    </span>
                                </td>
                                <td class="px-6 py-4 text-slate-600">@row.CreatedAt</td>
                                <td class="px-6 py-4 text-right">
                                    <div class="flex items-center justify-end gap-2">
                                        <a asp-page="Details" asp-route-id="@row.ApartmentId"
                                           class="inline-flex items-center gap-1.5 px-3 py-1.5 rounded-lg border border-slate-200 text-slate-600 hover:bg-slate-50 text-sm font-medium transition-colors">
                                            <span class="material-icons text-base">visibility</span>
                                            Chi tiết
                                        </a>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>

            @* Pagination *@
            <div class="px-6 py-4 bg-slate-50/30 border-t border-slate-100 flex items-center justify-between flex-wrap gap-4">
                <p class="text-sm text-slate-500">
                    Hiển thị <span class="font-medium text-slate-900">@(((Model.PageIndex - 1) * Model.PageSize) + 1)</span> -
                    <span class="font-medium text-slate-900">@Math.Min(Model.PageIndex * Model.PageSize, Model.TotalItems)</span>
                    trong tổng số <span class="font-medium text-slate-900">@Model.TotalItems</span> bản ghi
                </p>
                <div class="flex items-center gap-2">
                    @{
                        int prev = Model.PageIndex - 1;
                        int next = Model.PageIndex + 1;
                    }
                    <a href="?pageIndex=@prev&pageSize=@Model.PageSize&searchTerm=@Model.SearchTerm&statusfilter=@Model.StatusFilter&typeFilter=@Model.TypeFilter&blockFilter=@Model.BlockFilter&floorFilter=@Model.FloorFilter"
                       class="px-3 py-1 bg-white border border-slate-200 rounded-lg text-sm font-medium hover:bg-slate-50 transition-colors @(Model.PageIndex == 1 ? "opacity-50 pointer-events-none" : "")">
                        Trước
                    </a>
                    <div class="flex items-center gap-1">
                        @for (int i = 1; i <= Model.TotalPages; i++)
                        {
                            if (i == 1 || i == Model.TotalPages || (i >= Model.PageIndex - 2 && i <= Model.PageIndex + 2))
                            {
                                <a href="?pageIndex=@i&pageSize=@Model.PageSize&searchTerm=@Model.SearchTerm&statusfilter=@Model.StatusFilter&typeFilter=@Model.TypeFilter&blockFilter=@Model.BlockFilter&floorFilter=@Model.FloorFilter"
                                   class="min-w-[36px] px-3 py-1 rounded-lg text-sm font-medium text-center transition-colors @(i == Model.PageIndex ? "bg-emerald-600 text-white" : "text-slate-600 hover:bg-slate-50")">
                                    @i
                                </a>
                            }
                            else if (i == Model.PageIndex - 3 || i == Model.PageIndex + 3)
                            {
                                <span class="px-1 text-slate-400">…</span>
                            }
                        }
                    </div>
                    <a href="?pageIndex=@next&pageSize=@Model.PageSize&searchTerm=@Model.SearchTerm&statusfilter=@Model.StatusFilter&typeFilter=@Model.TypeFilter&blockFilter=@Model.BlockFilter&floorFilter=@Model.FloorFilter"
                       class="px-3 py-1 bg-white border border-slate-200 rounded-lg text-sm font-medium hover:bg-slate-50 transition-colors @(Model.PageIndex == Model.TotalPages ? "opacity-50 pointer-events-none" : "")">
                        Sau
                    </a>
                </div>
            </div>
        }
        else
        {
            <div class="py-16 text-center">
                <span class="material-icons text-5xl text-slate-200">apartment</span>
                <p class="mt-4 text-slate-500 font-medium">Không tìm thấy căn hộ nào</p>
                <p class="mt-1 text-sm text-slate-400">Thử thay đổi bộ lọc hoặc thêm căn hộ mới.</p>
                <a asp-page="./Index" class="mt-4 inline-flex items-center gap-2 rounded-lg border border-slate-200 px-4 py-2 text-sm font-medium text-slate-600 hover:bg-slate-50">
                    <span class="material-icons text-base">restart_alt</span>
                    Xóa bộ lọc
                </a>
            </div>
        }
    </section>
</div>
