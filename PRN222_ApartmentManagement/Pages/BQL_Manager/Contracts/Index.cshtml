@page
@using PRN222_ApartmentManagement.Models.Enums
@model PRN222_ApartmentManagement.Pages.BQL_Manager.Contracts.IndexModel
@{
    ViewData["Title"] = "Quản lý hợp đồng";
    ViewData["CurrentPage"] = "contracts";
    Layout = "_Layout";
    ViewData["PageHeader"] = new
    {
        Title = "Quản lý hợp đồng",
        BreadcrumbItems = new[]
        {
            new { Label = "BQL Manager", Href = "/BQL_Manager" },
            new { Label = "Hợp đồng", Href = "#" }
        }
    };

    var activeCount = Model.Rows.Count(r => r.StatusLabel == "Đang hiệu lực");
    var draftCount = Model.Rows.Count(r => r.StatusLabel == "Bản nháp");
    var expiredCount = Model.Rows.Count(r => r.StatusLabel == "Hết hạn");
    var terminatedCount = Model.Rows.Count(r => r.StatusLabel == "Đã chấm dứt");
}

<div class="space-y-6">

    @* ===== STATS ROW ===== *@
    <section class="grid grid-cols-2 gap-4 md:grid-cols-4">
        <div class="rounded-xl border border-slate-200 bg-white p-5 shadow-sm">
            <div class="flex items-start justify-between gap-4">
                <div>
                    <p class="text-sm font-medium text-slate-500">Tổng hợp đồng</p>
                    <p class="mt-3 text-3xl font-bold tracking-tight text-slate-900">@Model.TotalItems</p>
                    <p class="mt-1 text-xs text-slate-400">Đang hiển thị theo bộ lọc</p>
                </div>
                <div class="flex h-11 w-11 items-center justify-center rounded-xl bg-emerald-50 text-emerald-600">
                    <span class="material-icons">description</span>
                </div>
            </div>
        </div>
        <div class="rounded-xl border border-emerald-200 bg-white p-5 shadow-sm">
            <div class="flex items-start justify-between gap-4">
                <div>
                    <p class="text-sm font-medium text-emerald-600">Đang hiệu lực</p>
                    <p class="mt-3 text-3xl font-bold tracking-tight text-emerald-700">@activeCount</p>
                    <p class="mt-1 text-xs text-emerald-400">Hợp đồng có hiệu lực</p>
                </div>
                <div class="flex h-11 w-11 items-center justify-center rounded-xl bg-emerald-100 text-emerald-600">
                    <span class="material-icons">check_circle</span>
                </div>
            </div>
        </div>
        <div class="rounded-xl border border-slate-200 bg-white p-5 shadow-sm">
            <div class="flex items-start justify-between gap-4">
                <div>
                    <p class="text-sm font-medium text-slate-500">Bản nháp</p>
                    <p class="mt-3 text-3xl font-bold tracking-tight text-slate-700">@draftCount</p>
                    <p class="mt-1 text-xs text-slate-400">Chờ duyệt</p>
                </div>
                <div class="flex h-11 w-11 items-center justify-center rounded-xl bg-slate-100 text-slate-500">
                    <span class="material-icons">edit_note</span>
                </div>
            </div>
        </div>
        <div class="rounded-xl border border-red-200 bg-white p-5 shadow-sm">
            <div class="flex items-start justify-between gap-4">
                <div>
                    <p class="text-sm font-medium text-red-600">Hết hạn / Chấm dứt</p>
                    <p class="mt-3 text-3xl font-bold tracking-tight text-red-700">@(expiredCount + terminatedCount)</p>
                    <p class="mt-1 text-xs text-red-400">Cần xử lý</p>
                </div>
                <div class="flex h-11 w-11 items-center justify-center rounded-xl bg-red-50 text-red-500">
                    <span class="material-icons">event_busy</span>
                </div>
            </div>
        </div>
    </section>

    @* ===== STATUS MESSAGE ===== *@
    @if (!string.IsNullOrWhiteSpace(Model.StatusMessage))
    {
        <div class="rounded-xl border border-emerald-200 bg-emerald-50 px-4 py-3 text-sm text-emerald-700">
            @Model.StatusMessage
        </div>
    }

    @* ===== FILTER FORM ===== *@
    <section class="rounded-xl border border-slate-200 bg-white p-6 shadow-sm">
        <div class="mb-5 flex items-start justify-between gap-4">
            <div>
                <h2 class="text-lg font-semibold text-slate-900">Bộ lọc hợp đồng</h2>
                <p class="mt-1 text-sm text-slate-500">Tìm kiếm và lọc hợp đồng theo trạng thái, loại hợp đồng.</p>
            </div>
            <div class="flex h-10 w-10 items-center justify-center rounded-xl bg-slate-100 text-slate-600">
                <span class="material-icons">filter_alt</span>
            </div>
        </div>

        <form method="get" class="grid grid-cols-1 gap-4 md:grid-cols-2 xl:grid-cols-4">
            <div class="space-y-2">
                <label for="SearchTerm" class="text-sm font-medium text-slate-700">Tìm kiếm</label>
                <input id="SearchTerm" name="searchTerm" value="@Model.SearchTerm" placeholder="Số hợp đồng, căn hộ, tên..."
                       class="w-full rounded-lg border border-slate-200 px-4 py-2 text-sm text-slate-900 focus:outline-none focus:ring-2 focus:ring-emerald-500" />
            </div>
            <div class="space-y-2">
                <label for="Status" class="text-sm font-medium text-slate-700">Trạng thái</label>
                <select id="Status" name="status"
                        class="w-full rounded-lg border border-slate-200 bg-white px-4 py-2 text-sm text-slate-900 focus:outline-none focus:ring-2 focus:ring-emerald-500">
                    <option value="">Tất cả trạng thái</option>
                    @foreach (var status in Enum.GetValues<ContractStatus>())
                    {
                        @if (status == ContractStatus.PendingSignature) { continue; }
                        <option value="@status" selected="@(Model.Status == status)">@(status switch
                        {
                            ContractStatus.Draft => "Bản nháp",
                            ContractStatus.Active => "Đang hiệu lực",
                            ContractStatus.Expired => "Hết hạn",
                            ContractStatus.Terminated => "Đã chấm dứt",
                            ContractStatus.Cancelled => "Đã hủy",
                            _ => status.ToString()
                        })</option>
                    }
                </select>
            </div>
            <div class="space-y-2">
                <label for="ContractTypeFilter" class="text-sm font-medium text-slate-700">Loại hợp đồng</label>
                <select id="ContractTypeFilter" name="contracttypefilter"
                        class="w-full rounded-lg border border-slate-200 bg-white px-4 py-2 text-sm text-slate-900 focus:outline-none focus:ring-2 focus:ring-emerald-500">
                    <option value="">Tất cả loại</option>
                    @foreach (var type in Enum.GetValues<ContractType>())
                    {
                        <option value="@type" selected="@(Model.ContractTypeFilter == type)">@(type switch
                        {
                            ContractType.Rental => "Thuê",
                            ContractType.Purchase => "Mua bán",
                            ContractType.Other => "Khác",
                            _ => type.ToString()
                        })</option>
                    }
                </select>
            </div>
            <div class="md:col-span-2 xl:col-span-4 flex flex-wrap items-center gap-3 pt-2">
                <button type="submit" class="inline-flex items-center gap-2 rounded-lg bg-emerald-600 px-4 py-2 text-sm font-medium text-white transition-colors hover:bg-emerald-700">
                    <span class="material-icons text-base">filter_alt</span>
                    Lọc danh sách
                </button>
                <a asp-page="./Index" class="inline-flex items-center gap-2 rounded-lg border border-slate-200 px-4 py-2 text-sm font-medium text-slate-600 transition-colors hover:bg-slate-50">
                    <span class="material-icons text-base">restart_alt</span>
                    Xóa bộ lọc
                </a>
                <a asp-page="Create" class="ml-auto inline-flex items-center gap-2 rounded-lg bg-emerald-600 px-4 py-2 text-sm font-medium text-white transition-colors hover:bg-emerald-700">
                    <span class="material-icons text-base">add</span>
                    Tạo hợp đồng
                </a>
            </div>
        </form>
    </section>

    @* ===== TABLE ===== *@
    <section class="overflow-hidden rounded-xl border border-slate-200 bg-white shadow-sm">
        <div class="px-6 py-4 border-b border-slate-100 flex items-center justify-between">
            <div>
                <h3 class="text-base font-semibold text-slate-900">Danh sách hợp đồng</h3>
                <p class="text-xs text-slate-500 mt-0.5">@Model.TotalItems hợp đồng</p>
            </div>
            <span class="material-icons text-slate-300">table_rows</span>
        </div>

        @if (Model.Rows.Any())
        {
            <div class="overflow-x-auto">
                <table class="w-full text-sm">
                    <thead class="bg-slate-50 text-slate-500">
                        <tr>
                            <th class="px-6 py-3 text-left text-xs font-semibold uppercase tracking-wide">Số hợp đồng</th>
                            <th class="px-6 py-3 text-left text-xs font-semibold uppercase tracking-wide">Căn hộ</th>
                            <th class="px-6 py-3 text-left text-xs font-semibold uppercase tracking-wide">Loại</th>
                            <th class="px-6 py-3 text-left text-xs font-semibold uppercase tracking-wide">Ngày bắt đầu</th>
                            <th class="px-6 py-3 text-left text-xs font-semibold uppercase tracking-wide">Ngày kết thúc</th>
                            <th class="px-6 py-3 text-left text-xs font-semibold uppercase tracking-wide">Trạng thái</th>
                            <th class="px-6 py-3 text-left text-xs font-semibold uppercase tracking-wide">Chủ hộ</th>
                            <th class="px-6 py-3 text-left text-xs font-semibold uppercase tracking-wide">Điện thoại</th>
                            <th class="px-6 py-3 text-right text-xs font-semibold uppercase tracking-wide">Thao tác</th>
                        </tr>
                    </thead>
                    <tbody class="divide-y divide-slate-100">
                        @foreach (var row in Model.Rows)
                        {
                            <tr class="hover:bg-slate-50 transition-colors">
                                <td class="px-6 py-4 font-semibold text-slate-900">@row.ContractNumber</td>
                                <td class="px-6 py-4 text-slate-600">@row.ApartmentDisplay</td>
                                <td class="px-6 py-4 text-slate-600">@row.TypeLabel</td>
                                <td class="px-6 py-4 text-slate-600">@row.StartDate</td>
                                <td class="px-6 py-4 text-slate-600">@row.EndDate</td>
                                <td class="px-6 py-4">
                                    <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium @row.StatusCssClass">
                                        @row.StatusLabel
                                    </span>
                                </td>
                                <td class="px-6 py-4 text-slate-600">@row.OwnerName</td>
                                <td class="px-6 py-4 text-slate-600">@row.OwnerPhone</td>
                                <td class="px-6 py-4 text-right">
                                    <a href="/BQL_Manager/Contracts/Details/@row.ContractId"
                                       class="inline-flex items-center gap-1.5 px-3 py-1.5 rounded-lg border border-slate-200 text-slate-600 hover:bg-slate-50 text-sm font-medium transition-colors">
                                        <span class="material-icons text-base">visibility</span>
                                        Xem
                                    </a>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>

            @* Pagination *@
            <div class="px-6 py-4 bg-slate-50/30 border-t border-slate-100 flex items-center justify-between flex-wrap gap-4">
                <p class="text-sm text-slate-500">
                    Hiển thị <span class="font-medium text-slate-900">@(((Model.PageIndex - 1) * Model.PageSize) + 1)</span> -
                    <span class="font-medium text-slate-900">@Math.Min(Model.PageIndex * Model.PageSize, Model.TotalItems)</span>
                    trong tổng số <span class="font-medium text-slate-900">@Model.TotalItems</span> bản ghi
                </p>
                <div class="flex items-center gap-2">
                    @{
                        int prev = Model.PageIndex - 1;
                        int next = Model.PageIndex + 1;
                    }
                    <a href="?pageIndex=@prev&pageSize=@Model.PageSize&searchTerm=@Model.SearchTerm&status=@Model.Status&contracttypefilter=@Model.ContractTypeFilter"
                       class="px-3 py-1 bg-white border border-slate-200 rounded-lg text-sm font-medium hover:bg-slate-50 transition-colors @(Model.PageIndex == 1 ? "opacity-50 pointer-events-none" : "")">
                        Trước
                    </a>
                    <div class="flex items-center gap-1">
                        @for (int i = 1; i <= Model.TotalPages; i++)
                        {
                            if (i == 1 || i == Model.TotalPages || (i >= Model.PageIndex - 2 && i <= Model.PageIndex + 2))
                            {
                                <a href="?pageIndex=@i&pageSize=@Model.PageSize&searchTerm=@Model.SearchTerm&status=@Model.Status&contracttypefilter=@Model.ContractTypeFilter"
                                   class="w-8 h-8 rounded-lg text-sm font-medium flex items-center justify-center transition-colors @(i == Model.PageIndex ? "bg-primary-600 text-white font-bold" : "text-slate-600 hover:bg-slate-100")">
                                    @i
                                </a>
                            }
                            else if (i == Model.PageIndex - 3 || i == Model.PageIndex + 3)
                            {
                                <span class="text-slate-400">...</span>
                            }
                        }
                    </div>
                    <a href="?pageIndex=@next&pageSize=@Model.PageSize&searchTerm=@Model.SearchTerm&status=@Model.Status&contracttypefilter=@Model.ContractTypeFilter"
                       class="px-3 py-1 bg-white border border-slate-200 rounded-lg text-sm font-medium hover:bg-slate-50 transition-colors @(Model.PageIndex == Model.TotalPages ? "opacity-50 pointer-events-none" : "")">
                        Sau
                    </a>
                </div>
            </div>
        }
        else
        {
            <div class="px-6 py-16 text-center">
                <div class="mx-auto flex h-16 w-16 items-center justify-center rounded-2xl bg-slate-100 text-slate-400">
                    <span class="material-icons text-3xl">description</span>
                </div>
                <h3 class="mt-4 text-lg font-semibold text-slate-900">Không có hợp đồng nào</h3>
                <p class="mt-2 text-sm text-slate-500">Tạo hợp đồng mới để bắt đầu quản lý.</p>
                <a asp-page="Create" class="mt-4 inline-flex items-center gap-2 rounded-lg bg-emerald-600 px-4 py-2 text-sm font-medium text-white hover:bg-emerald-700">
                    <span class="material-icons text-base">add</span>
                    Tạo hợp đồng
                </a>
            </div>
        }
    </section>

</div>

