@page "{id:int}"
@model PRN222_ApartmentManagement.Pages.BQL_Manager.Contracts.TerminateModel
@{
    ViewData["Title"] = "Kết thúc hợp đồng";
    ViewData["CurrentPage"] = "contracts";
    Layout = "_Layout";
    ViewData["PageHeader"] = new
    {
        Title = "Kết thúc hợp đồng",
        BreadcrumbItems = new[]
        {
            new { Label = "BQL Manager", Href = "/BQL_Manager" },
            new { Label = "Hợp đồng", Href = "/BQL_Manager/Contracts" },
            new { Label = "Kết thúc", Href = "#" }
        }
    };
}

<div class="max-w-2xl mx-auto space-y-6">
    <div class="flex items-center gap-2 mb-2">
        <a asp-page="Index" class="inline-flex items-center text-sm text-slate-500 hover:text-emerald-600 transition-colors">
            <span class="material-icons text-lg mr-1">arrow_back</span>
            Quay lại danh sách
        </a>
    </div>

    @if (Model.Contract == null)
    {
        <div class="rounded-xl border border-red-200 bg-red-50 px-4 py-3 text-sm text-red-700">
            Không tìm thấy hợp đồng.
        </div>
    }
    else
    {
        <div class="rounded-xl border border-amber-200 bg-amber-50 p-4">
            <div class="flex items-center gap-3">
                <span class="material-icons text-amber-600">warning</span>
                <div>
                    <p class="font-semibold text-amber-800">Cảnh báo!</p>
                    <p class="text-sm text-amber-700">
                        Việc kết thúc hợp đồng sẽ vô hiệu hóa tài khoản của chủ hộ và tất cả thành viên liên quan.
                    </p>
                </div>
            </div>
        </div>

        <section class="rounded-xl border border-slate-200 bg-white p-6 shadow-sm">
            <h3 class="text-base font-semibold text-slate-900 mb-4 flex items-center gap-2">
                <span class="material-icons text-emerald-600 text-lg">description</span>
                Thông tin hợp đồng
            </h3>
            <dl class="space-y-2 text-sm">
                <div class="flex justify-between">
                    <dt class="text-slate-500">Số hợp đồng</dt>
                    <dd class="font-semibold text-slate-900">@Model.Contract.ContractNumber</dd>
                </div>
                <div class="flex justify-between">
                    <dt class="text-slate-500">Căn hộ</dt>
                    <dd class="font-medium text-slate-900">Căn @Model.Contract.Apartment?.ApartmentNumber (@(Model.Contract.Apartment?.BuildingBlock ?? "-"))</dd>
                </div>
                <div class="flex justify-between">
                    <dt class="text-slate-500">Ngày bắt đầu</dt>
                    <dd class="font-medium text-slate-900">@Model.Contract.StartDate.ToString("dd/MM/yyyy")</dd>
                </div>
                <div class="flex justify-between">
                    <dt class="text-slate-500">Ngày kết thúc</dt>
                    <dd class="font-medium text-slate-900">@(Model.Contract.EndDate?.ToString("dd/MM/yyyy") ?? "Không có thời hạn")</dd>
                </div>
            </dl>
        </section>

        <form method="post" class="bg-white rounded-xl shadow-sm border border-slate-200 overflow-hidden">
            <input type="hidden" name="id" value="@Model.Contract.ContractId" />
            <div class="p-6 space-y-4">
                @if (!string.IsNullOrWhiteSpace(Model.ErrorMessage))
                {
                    <div class="p-4 bg-red-50 border border-red-200 rounded-lg">
                        <p class="text-sm text-red-600">@Model.ErrorMessage</p>
                    </div>
                }

                <div class="space-y-2">
                    <label class="text-sm font-medium text-slate-700">
                        Lý do kết thúc hợp đồng <span class="text-red-500">*</span>
                    </label>
                    <textarea asp-for="TerminationReason" rows="4" required
                              placeholder="VD: Chủ hộ yêu cầu kết thúc hợp đồng, hết hạn hợp đồng..."
                              class="w-full px-4 py-2 border border-slate-200 rounded-lg focus:outline-none focus:ring-2 focus:ring-red-500 transition-all text-sm"></textarea>
                    <span class="text-xs text-slate-400">Vui lòng mô tả chi tiết lý do kết thúc hợp đồng.</span>
                </div>
            </div>

            <div class="bg-slate-50 px-6 py-4 border-t border-slate-200 flex items-center justify-end gap-3">
                <a asp-page="Details" asp-route-id="@Model.Contract.ContractId"
                   class="px-4 py-2 text-slate-600 hover:bg-slate-100 rounded-lg transition-colors text-sm font-medium">
                    Hủy
                </a>
                <button type="submit"
                        class="px-4 py-2 bg-red-600 text-white rounded-lg hover:bg-red-700 transition-colors text-sm font-medium inline-flex items-center gap-2">
                    <span class="material-icons text-base">cancel</span>
                    Xác nhận kết thúc
                </button>
            </div>
        </form>
    }
</div>
