@page
@model PRN222_ApartmentManagement.Pages.BQL_Manager.FaceAuth.DashboardModel
@{
    ViewData["Title"] = "Bảng điều khiển Face ID";
    ViewData["CurrentPage"] = "faceauthdashboard";
    Layout = "_Layout";
    ViewData["PageHeader"] = new
    {
        Title = "Bảng điều khiển Face ID",
        BreadcrumbItems = new[]
        {
            new { Label = "BQL Manager", Href = "/BQL_Manager" },
            new { Label = "Bảng điều khiển Face ID", Href = "#" }
        }
    };
}

<div class="space-y-6">
    <section class="rounded-xl border border-slate-200 bg-white p-6 shadow-sm">
        <form method="get" class="flex flex-col gap-4 md:flex-row md:items-end md:justify-between">
            <div>
                <h2 class="text-lg font-semibold text-slate-900">Tổng quan sử dụng Face ID</h2>
                <p class="mt-1 text-sm text-slate-500">Theo dõi tỷ lệ đăng ký, tần suất xác thực và kết quả trong khoảng thời gian gần đây.</p>
            </div>
            <div class="flex items-end gap-3">
                <div class="space-y-2">
                    <label asp-for="RecentDays" class="text-sm font-medium text-slate-700">Số ngày gần đây</label>
                    <select asp-for="RecentDays" class="w-40 rounded-lg border border-slate-200 bg-white px-4 py-2 text-sm">
                        <option value="7">7 ngày</option>
                        <option value="30">30 ngày</option>
                        <option value="90">90 ngày</option>
                    </select>
                </div>
                <button type="submit" class="inline-flex items-center gap-2 rounded-lg bg-emerald-600 px-4 py-2 text-sm font-medium text-white hover:bg-emerald-700">
                    <span class="material-icons text-base">filter_alt</span>
                    Cập nhật
                </button>
            </div>
        </form>
    </section>

    <section class="grid grid-cols-1 gap-4 md:grid-cols-2 xl:grid-cols-4">
        <div class="rounded-xl border border-slate-200 bg-white p-5 shadow-sm">
            <p class="text-sm font-medium text-slate-500">Tổng cư dân</p>
            <p class="mt-3 text-3xl font-bold tracking-tight text-slate-900">@Model.Dashboard.TotalResidents</p>
        </div>
        <div class="rounded-xl border border-slate-200 bg-white p-5 shadow-sm">
            <p class="text-sm font-medium text-slate-500">Đã đăng ký Face ID</p>
            <p class="mt-3 text-3xl font-bold tracking-tight text-emerald-700">@Model.Dashboard.RegisteredResidents</p>
            <p class="mt-2 text-sm text-slate-500">Tỷ lệ @Model.Dashboard.RegistrationRate.ToString("N2")%</p>
        </div>
        <div class="rounded-xl border border-slate-200 bg-white p-5 shadow-sm">
            <p class="text-sm font-medium text-slate-500">Đăng ký mới trong tháng</p>
            <p class="mt-3 text-3xl font-bold tracking-tight text-slate-900">@Model.Dashboard.RegisteredThisMonth</p>
        </div>
        <div class="rounded-xl border border-slate-200 bg-white p-5 shadow-sm">
            <p class="text-sm font-medium text-slate-500">Xác thực hôm nay</p>
            <p class="mt-3 text-3xl font-bold tracking-tight text-slate-900">@Model.Dashboard.AttemptsToday</p>
        </div>
    </section>

    <section class="grid grid-cols-1 gap-6 xl:grid-cols-3">
        <div class="rounded-xl border border-slate-200 bg-white p-6 shadow-sm xl:col-span-2">
            <div class="mb-5 flex items-center justify-between">
                <div>
                    <h2 class="text-lg font-semibold text-slate-900">Hiệu suất xác thực @Model.Dashboard.RecentDays ngày</h2>
                    <p class="mt-1 text-sm text-slate-500">Tổng hợp kết quả thành công và thất bại trong giai đoạn đã chọn.</p>
                </div>
                <a href="/FaceAuth/Logs" class="inline-flex items-center gap-2 rounded-lg border border-slate-200 px-4 py-2 text-sm font-medium text-slate-600 hover:bg-slate-50">
                    <span class="material-icons text-base">history</span>
                    Xem lịch sử đầy đủ
                </a>
            </div>

            <div class="grid grid-cols-1 gap-4 md:grid-cols-3">
                <div class="rounded-xl bg-slate-50 p-4">
                    <p class="text-sm font-medium text-slate-500">Tổng lượt xác thực</p>
                    <p class="mt-2 text-2xl font-bold text-slate-900">@Model.Dashboard.AttemptsInPeriod</p>
                </div>
                <div class="rounded-xl bg-emerald-50 p-4">
                    <p class="text-sm font-medium text-emerald-700">Thành công</p>
                    <p class="mt-2 text-2xl font-bold text-emerald-700">@Model.Dashboard.SuccessfulAttemptsInPeriod</p>
                </div>
                <div class="rounded-xl bg-red-50 p-4">
                    <p class="text-sm font-medium text-red-700">Thất bại</p>
                    <p class="mt-2 text-2xl font-bold text-red-700">@Model.Dashboard.FailedAttemptsInPeriod</p>
                </div>
            </div>

            <div class="mt-6">
                <div class="mb-2 flex items-center justify-between text-sm">
                    <span class="font-medium text-slate-700">Tỷ lệ thành công</span>
                    <span class="font-semibold text-slate-900">@Model.Dashboard.SuccessRateInPeriod.ToString("N2")%</span>
                </div>
                <div class="h-3 rounded-full bg-slate-100">
                    <div class="h-3 rounded-full bg-emerald-500" style="width:@Model.Dashboard.SuccessRateInPeriod%"></div>
                </div>
            </div>
        </div>

        <div class="rounded-xl border border-slate-200 bg-white p-6 shadow-sm">
            <h2 class="text-lg font-semibold text-slate-900">Trạng thái đăng ký</h2>
            <div class="mt-5 space-y-4">
                <div class="rounded-xl border border-emerald-100 bg-emerald-50 p-4">
                    <p class="text-sm font-medium text-emerald-700">Đã đăng ký</p>
                    <p class="mt-2 text-2xl font-bold text-emerald-700">@Model.Dashboard.RegisteredResidents</p>
                </div>
                <div class="rounded-xl border border-amber-100 bg-amber-50 p-4">
                    <p class="text-sm font-medium text-amber-700">Chưa đăng ký</p>
                    <p class="mt-2 text-2xl font-bold text-amber-700">@Model.Dashboard.UnregisteredResidents</p>
                </div>
            </div>
        </div>
    </section>

    <section class="overflow-hidden rounded-xl border border-slate-200 bg-white shadow-sm">
        <div class="border-b border-slate-200 px-6 py-5">
            <h2 class="text-lg font-semibold text-slate-900">Lịch sử gần đây</h2>
            <p class="mt-1 text-sm text-slate-500">Một số bản ghi mới nhất trong khoảng thời gian đã chọn.</p>
        </div>
        @if (Model.Dashboard.RecentLogs.Any())
        {
            <div class="overflow-x-auto">
                <table class="min-w-full text-sm">
                    <thead class="bg-slate-50 text-slate-600">
                        <tr>
                            <th class="px-6 py-3 text-left font-semibold">Cư dân</th>
                            <th class="px-6 py-3 text-left font-semibold">Căn hộ</th>
                            <th class="px-6 py-3 text-left font-semibold">Thời gian</th>
                            <th class="px-6 py-3 text-left font-semibold">Kết quả</th>
                            <th class="px-6 py-3 text-right font-semibold">Độ khớp</th>
                        </tr>
                    </thead>
                    <tbody class="divide-y divide-slate-100">
                        @foreach (var log in Model.Dashboard.RecentLogs)
                        {
                            <tr class="hover:bg-slate-50">
                                <td class="px-6 py-4 font-medium text-slate-900">@log.ResidentName</td>
                                <td class="px-6 py-4 text-slate-700">Căn @((log.ApartmentNumber ?? "-"))</td>
                                <td class="px-6 py-4 text-slate-600">@log.AuthTime.ToString("dd/MM/yyyy HH:mm")</td>
                                <td class="px-6 py-4">
                                    <span class="inline-flex items-center gap-2 rounded-full px-3 py-1 text-xs font-medium @(log.IsSuccess ? "bg-emerald-50 text-emerald-700" : "bg-red-50 text-red-700")">
                                        <span class="material-icons text-sm">@(log.IsSuccess ? "check_circle" : "cancel")</span>
                                        @(log.IsSuccess ? "Thành công" : "Thất bại")
                                    </span>
                                </td>
                                <td class="px-6 py-4 text-right font-semibold text-slate-900">@((log.ConfidenceScore * 100).ToString("N1"))%</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
        else
        {
            <div class="px-6 py-16 text-center text-sm text-slate-500">Chưa có dữ liệu xác thực trong khoảng thời gian đã chọn.</div>
        }
    </section>
</div>
