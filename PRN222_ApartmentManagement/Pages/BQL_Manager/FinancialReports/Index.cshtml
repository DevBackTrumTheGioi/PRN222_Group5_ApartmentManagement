@page
@model PRN222_ApartmentManagement.Pages.BQL_Manager.FinancialReports.IndexModel
@{
    ViewData["Title"] = "Báo cáo tài chính";
    ViewData["CurrentPage"] = "financialreports";
    Layout = "_Layout";
    ViewData["PageHeader"] = new
    {
        Title = "Báo cáo tài chính",
        BreadcrumbItems = new[]
        {
            new { Label = "BQL Manager", Href = "/BQL_Manager" },
            new { Label = "Báo cáo tài chính", Href = "#" }
        }
    };

    var chartMax = Model.Report.MonthlyTrend.Any()
        ? Math.Max(Model.Report.MonthlyTrend.Max(x => Math.Max(x.BilledAmount, x.CollectedAmount)), 1)
        : 1;
}

<div class="space-y-6">
    <section class="rounded-xl border border-slate-200 bg-white p-6 shadow-sm">
        <div class="mb-5 flex flex-col gap-4 md:flex-row md:items-center md:justify-between">
            <div>
                <h2 class="text-lg font-semibold text-slate-900">Bộ lọc báo cáo</h2>
                <p class="mt-1 text-sm text-slate-500">Theo dõi tổng thu, công nợ và chi tiết doanh thu theo tháng.</p>
            </div>
            <form method="post" asp-page-handler="Export">
                <input type="hidden" asp-for="Year" />
                <input type="hidden" asp-for="Month" />
                <button type="submit" class="inline-flex items-center gap-2 rounded-lg bg-emerald-600 px-4 py-2 text-sm font-medium text-white hover:bg-emerald-700">
                    <span class="material-icons text-base">download</span>
                    Xuất Excel
                </button>
            </form>
        </div>

        <form method="get" class="grid grid-cols-1 gap-4 md:grid-cols-4">
            <div class="space-y-2">
                <label asp-for="Year" class="text-sm font-medium text-slate-700">Năm</label>
                <input asp-for="Year" type="number" min="2024" class="w-full rounded-lg border border-slate-200 px-4 py-2 text-sm" />
            </div>
            <div class="space-y-2">
                <label asp-for="Month" class="text-sm font-medium text-slate-700">Tháng</label>
                <select asp-for="Month" class="w-full rounded-lg border border-slate-200 bg-white px-4 py-2 text-sm">
                    <option value="">Toàn năm</option>
                    @for (var month = 1; month <= 12; month++)
                    {
                        <option value="@month">Tháng @month</option>
                    }
                </select>
            </div>
            <div class="md:col-span-2 flex items-end gap-3">
                <button type="submit" class="inline-flex items-center gap-2 rounded-lg bg-emerald-600 px-4 py-2 text-sm font-medium text-white hover:bg-emerald-700">
                    <span class="material-icons text-base">filter_alt</span>
                    Lọc báo cáo
                </button>
                <a asp-page="./Index" class="inline-flex items-center gap-2 rounded-lg border border-slate-200 px-4 py-2 text-sm font-medium text-slate-600 hover:bg-slate-50">
                    <span class="material-icons text-base">restart_alt</span>
                    Đặt lại
                </a>
            </div>
        </form>
    </section>

    <section class="grid grid-cols-1 gap-4 md:grid-cols-2 xl:grid-cols-4">
        <div class="rounded-xl border border-slate-200 bg-white p-5 shadow-sm">
            <p class="text-sm font-medium text-slate-500">Tổng phát hành</p>
            <p class="mt-3 text-3xl font-bold tracking-tight text-slate-900">@Model.Report.TotalBilled.ToString("N0")</p>
            <p class="mt-2 text-sm text-slate-500">@Model.Report.PeriodLabel</p>
        </div>
        <div class="rounded-xl border border-slate-200 bg-white p-5 shadow-sm">
            <p class="text-sm font-medium text-slate-500">Tổng thu</p>
            <p class="mt-3 text-3xl font-bold tracking-tight text-emerald-700">@Model.Report.TotalCollected.ToString("N0")</p>
            <p class="mt-2 text-sm text-slate-500">@Model.Report.SuccessfulTransactions giao dịch thành công</p>
        </div>
        <div class="rounded-xl border border-slate-200 bg-white p-5 shadow-sm">
            <p class="text-sm font-medium text-slate-500">Công nợ còn lại</p>
            <p class="mt-3 text-3xl font-bold tracking-tight text-amber-700">@Model.Report.TotalOutstanding.ToString("N0")</p>
            <p class="mt-2 text-sm text-slate-500">Quá hạn: @Model.Report.OverdueOutstanding.ToString("N0")</p>
        </div>
        <div class="rounded-xl border border-slate-200 bg-white p-5 shadow-sm">
            <p class="text-sm font-medium text-slate-500">Tỷ lệ thu</p>
            <p class="mt-3 text-3xl font-bold tracking-tight text-slate-900">@Model.Report.CollectionRate.ToString("N2")%</p>
            <p class="mt-2 text-sm text-slate-500">@Model.Report.PaidInvoices / @Model.Report.TotalInvoices hóa đơn đã thanh toán đủ</p>
        </div>
    </section>

    <section class="grid grid-cols-1 gap-6 xl:grid-cols-[minmax(0,1.6fr)_minmax(320px,0.9fr)]">
        <div class="rounded-xl border border-slate-200 bg-white p-6 shadow-sm">
            <div class="mb-5">
                <h2 class="text-lg font-semibold text-slate-900">Dashboard tài chính theo tháng</h2>
                <p class="mt-1 text-sm text-slate-500">So sánh số phát hành và số đã thu của từng tháng trong năm.</p>
            </div>

            <div class="grid grid-cols-12 gap-3 items-end h-72">
                @foreach (var point in Model.Report.MonthlyTrend)
                {
                    var billedHeight = Math.Max(8, (int)Math.Round(point.BilledAmount / chartMax * 220m));
                    var collectedHeight = Math.Max(8, (int)Math.Round(point.CollectedAmount / chartMax * 220m));
                    <div class="flex flex-col items-center gap-2">
                        <div class="flex items-end gap-1 h-56">
                            <div class="w-3 rounded-t bg-slate-300" style="height:@(billedHeight)px" title="Phát hành: @point.BilledAmount.ToString("N0")"></div>
                            <div class="w-3 rounded-t bg-emerald-500" style="height:@(collectedHeight)px" title="Đã thu: @point.CollectedAmount.ToString("N0")"></div>
                        </div>
                        <span class="text-xs font-medium text-slate-500">@point.Month</span>
                    </div>
                }
            </div>

            <div class="mt-4 flex flex-wrap gap-4 text-xs text-slate-500">
                <div class="inline-flex items-center gap-2"><span class="h-3 w-3 rounded-full bg-slate-300"></span> Phát hành</div>
                <div class="inline-flex items-center gap-2"><span class="h-3 w-3 rounded-full bg-emerald-500"></span> Đã thu</div>
            </div>
        </div>

        <div class="space-y-6">
            <div class="rounded-xl border border-slate-200 bg-white p-6 shadow-sm">
                <div class="mb-5">
                    <h2 class="text-lg font-semibold text-slate-900">Cơ cấu thu</h2>
                    <p class="mt-1 text-sm text-slate-500">Theo phương thức thanh toán.</p>
                </div>

                @if (Model.Report.PaymentMethods.Any())
                {
                    <div class="space-y-4">
                        @foreach (var item in Model.Report.PaymentMethods)
                        {
                            var width = Model.Report.TotalCollected > 0 ? Math.Max(8, (int)Math.Round(item.Amount / Model.Report.TotalCollected * 100m)) : 0;
                            <div>
                                <div class="mb-2 flex items-center justify-between text-sm">
                                    <span class="font-medium text-slate-700">@item.PaymentMethod</span>
                                    <span class="text-slate-500">@item.Amount.ToString("N0")</span>
                                </div>
                                <div class="h-2 rounded-full bg-slate-100">
                                    <div class="h-2 rounded-full bg-emerald-500" style="width:@(width)%"></div>
                                </div>
                                <p class="mt-1 text-xs text-slate-500">@item.TransactionCount giao dịch</p>
                            </div>
                        }
                    </div>
                }
                else
                {
                    <div class="py-10 text-center text-sm text-slate-500">Chưa có giao dịch thành công trong kỳ báo cáo.</div>
                }
            </div>

            <div class="rounded-xl border border-slate-200 bg-white p-6 shadow-sm">
                <div class="mb-5">
                    <h2 class="text-lg font-semibold text-slate-900">Top công nợ</h2>
                    <p class="mt-1 text-sm text-slate-500">Các căn hộ còn nợ cao nhất trong bộ lọc hiện tại.</p>
                </div>

                @if (Model.Report.TopOutstandingApartments.Any())
                {
                    <div class="space-y-4">
                        @foreach (var item in Model.Report.TopOutstandingApartments)
                        {
                            <div class="rounded-lg border border-slate-200 p-4">
                                <div class="flex items-center justify-between gap-3">
                                    <div>
                                        <p class="font-semibold text-slate-900">Căn @item.ApartmentNumber</p>
                                        <p class="mt-1 text-xs text-slate-500">Tòa @item.BuildingBlock • @item.InvoiceCount hóa đơn</p>
                                    </div>
                                    <p class="text-sm font-semibold text-amber-700">@item.OutstandingAmount.ToString("N0")</p>
                                </div>
                            </div>
                        }
                    </div>
                }
                else
                {
                    <div class="py-10 text-center text-sm text-slate-500">Không có công nợ nổi bật trong kỳ báo cáo.</div>
                }
            </div>
        </div>
    </section>

    <section class="overflow-hidden rounded-xl border border-slate-200 bg-white shadow-sm">
        <div class="border-b border-slate-200 px-6 py-5">
            <h2 class="text-lg font-semibold text-slate-900">Báo cáo thu chi theo tháng</h2>
            <p class="mt-1 text-sm text-slate-500">Chi tiết doanh thu phát hành, số đã thu và phần công nợ còn lại.</p>
        </div>

        <div class="overflow-x-auto">
            <table class="min-w-full text-sm">
                <thead class="bg-slate-50 text-slate-600">
                    <tr>
                        <th class="px-6 py-3 text-left font-semibold">Tháng</th>
                        <th class="px-6 py-3 text-right font-semibold">Phát hành</th>
                        <th class="px-6 py-3 text-right font-semibold">Đã thu</th>
                        <th class="px-6 py-3 text-right font-semibold">Công nợ</th>
                        <th class="px-6 py-3 text-right font-semibold">Hóa đơn</th>
                        <th class="px-6 py-3 text-right font-semibold">Giao dịch</th>
                    </tr>
                </thead>
                <tbody class="divide-y divide-slate-100">
                    @foreach (var row in Model.Report.MonthlyRows)
                    {
                        <tr class="hover:bg-slate-50">
                            <td class="px-6 py-4 font-medium text-slate-900">@row.Label</td>
                            <td class="px-6 py-4 text-right text-slate-700">@row.BilledAmount.ToString("N0")</td>
                            <td class="px-6 py-4 text-right font-semibold text-emerald-700">@row.CollectedAmount.ToString("N0")</td>
                            <td class="px-6 py-4 text-right font-semibold text-amber-700">@row.OutstandingAmount.ToString("N0")</td>
                            <td class="px-6 py-4 text-right text-slate-600">@row.InvoiceCount</td>
                            <td class="px-6 py-4 text-right text-slate-600">@row.SuccessfulTransactionCount</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </section>

    <section class="overflow-hidden rounded-xl border border-slate-200 bg-white shadow-sm">
        <div class="border-b border-slate-200 px-6 py-5">
            <h2 class="text-lg font-semibold text-slate-900">Giao dịch gần nhất</h2>
        </div>

        @if (Model.Report.RecentTransactions.Any())
        {
            <div class="overflow-x-auto">
                <table class="min-w-full text-sm">
                    <thead class="bg-slate-50 text-slate-600">
                        <tr>
                            <th class="px-6 py-3 text-left font-semibold">Mã giao dịch</th>
                            <th class="px-6 py-3 text-left font-semibold">Hóa đơn</th>
                            <th class="px-6 py-3 text-left font-semibold">Phương thức</th>
                            <th class="px-6 py-3 text-right font-semibold">Số tiền</th>
                            <th class="px-6 py-3 text-left font-semibold">Thời gian</th>
                        </tr>
                    </thead>
                    <tbody class="divide-y divide-slate-100">
                        @foreach (var transaction in Model.Report.RecentTransactions)
                        {
                            <tr class="hover:bg-slate-50">
                                <td class="px-6 py-4 font-medium text-slate-900">@transaction.TransactionCode</td>
                                <td class="px-6 py-4 text-slate-700">@transaction.Invoice.InvoiceNumber</td>
                                <td class="px-6 py-4 text-slate-600">@(string.IsNullOrWhiteSpace(transaction.PaymentMethod) ? "-" : transaction.PaymentMethod)</td>
                                <td class="px-6 py-4 text-right font-semibold text-slate-900">@transaction.Amount.ToString("N0")</td>
                                <td class="px-6 py-4 text-slate-600">@transaction.PaymentDate.ToString("dd/MM/yyyy HH:mm")</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
        else
        {
            <div class="px-6 py-16 text-center text-sm text-slate-500">Chưa có giao dịch nào trong bộ lọc hiện tại.</div>
        }
    </section>
</div>
