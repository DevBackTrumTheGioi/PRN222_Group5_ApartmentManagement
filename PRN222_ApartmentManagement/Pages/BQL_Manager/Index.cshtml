@page
@model PRN222_ApartmentManagement.Pages.BQL_Manager.IndexModel
@{
    ViewData["Title"] = "Trang điều hành BQL";
    ViewData["Subtitle"] = "Tổng quan vận hành và quản lý chung cư";
}

<div class="space-y-6">
    <!-- Quick Stats -->
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6">
        <div class="bg-white p-6 rounded-2xl border border-slate-200 shadow-sm">
            <div class="flex items-center gap-4">
                <div class="w-12 h-12 bg-blue-50 text-blue-600 rounded-xl flex items-center justify-center">
                    <span class="material-icons">apartment</span>
                </div>
                <div>
                    <p class="text-sm text-slate-500 font-medium">Tỉ lệ lấp đầy</p>
                    <h3 class="text-2xl font-bold">@((Model.DashboardData.TotalApartments > 0 ? (Model.DashboardData.OccupiedApartments * 100 / Model.DashboardData.TotalApartments) : 0))%</h3>
                </div>
            </div>
            <p class="mt-4 text-xs text-slate-500">@Model.DashboardData.OccupiedApartments / @Model.DashboardData.TotalApartments căn hộ đã ở</p>
        </div>

        <div class="bg-white p-6 rounded-2xl border border-slate-200 shadow-sm">
            <div class="flex items-center gap-4">
                <div class="w-12 h-12 bg-emerald-50 text-emerald-600 rounded-xl flex items-center justify-center">
                    <span class="material-icons">payments</span>
                </div>
                <div>
                    <p class="text-sm text-slate-500 font-medium">Doanh thu tháng</p>
                    <h3 class="text-2xl font-bold">@Model.DashboardData.TotalRevenueThisMonth.ToString("N0") <span class="text-sm font-normal">đ</span></h3>
                </div>
            </div>
            <p class="mt-4 text-xs text-slate-500 font-medium text-amber-600">Nợ đọng: @Model.DashboardData.TotalOutstandingDebt.ToString("N0") đ</p>
        </div>

        <div class="bg-white p-6 rounded-2xl border border-slate-200 shadow-sm">
            <div class="flex items-center gap-4">
                <div class="w-12 h-12 bg-rose-50 text-rose-600 rounded-xl flex items-center justify-center">
                    <span class="material-icons">assignment_late</span>
                </div>
                <div>
                    <p class="text-sm text-slate-500 font-medium">Yêu cầu chờ xử lý</p>
                    <h3 class="text-2xl font-bold">@Model.DashboardData.PendingRequests</h3>
                </div>
            </div>
            <p class="mt-4 text-xs text-slate-500">Đang xử lý: @Model.DashboardData.InProgressRequests</p>
        </div>

        <div class="bg-white p-6 rounded-2xl border border-slate-200 shadow-sm">
            <div class="flex items-center gap-4">
                <div class="w-12 h-12 bg-amber-50 text-amber-600 rounded-xl flex items-center justify-center">
                    <span class="material-icons">people</span>
                </div>
                <div>
                    <p class="text-sm text-slate-500 font-medium">Cư dân mới tháng</p>
                    <h3 class="text-2xl font-bold">@Model.DashboardData.NewResidentsThisMonth</h3>
                </div>
            </div>
            <p class="mt-4 text-xs text-slate-500">Tổng cộng: @Model.DashboardData.TotalResidents cư dân</p>
        </div>
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-2 gap-6">
        <!-- Recent Requests -->
        <div class="bg-white p-6 rounded-2xl border border-slate-200 shadow-sm">
            <div class="flex justify-between items-center mb-6">
                <h3 class="text-lg font-bold">Yêu cầu mới nhất</h3>
                <a href="/BQL_Manager/Requests" class="text-emerald-600 text-sm font-semibold hover:underline">Tất cả yêu cầu</a>
            </div>
            <div class="space-y-4">
                @foreach (var request in Model.DashboardData.RecentRequests)
                {
                    <div class="flex items-start gap-4 p-3 hover:bg-slate-50 rounded-xl transition-colors border border-transparent hover:border-slate-100">
                        <div class="w-10 h-10 rounded-full bg-slate-100 flex items-center justify-center flex-shrink-0">
                            <span class="material-icons text-slate-500 text-sm">build</span>
                        </div>
                        <div class="flex-1 min-w-0">
                            <h4 class="text-sm font-semibold text-slate-900 truncate">@request.Title</h4>
                            <p class="text-xs text-slate-500 mt-1">@request.Resident?.FullName - Phòng @request.Apartment?.ApartmentNumber</p>
                        </div>
                        <div class="text-right">
                            <span class="px-2 py-1 rounded-full text-[10px] font-bold uppercase tracking-wider 
                                @(request.Status == PRN222_ApartmentManagement.Models.Enums.RequestStatus.Pending ? "bg-amber-50 text-amber-600" : "bg-blue-50 text-blue-600")">
                                @request.Status
                            </span>
                            <p class="text-[10px] text-slate-400 mt-1">@request.CreatedAt.ToString("dd/MM HH:mm")</p>
                        </div>
                    </div>
                }
            </div>
        </div>

        <!-- Recent Invoices -->
        <div class="bg-white p-6 rounded-2xl border border-slate-200 shadow-sm">
            <div class="flex justify-between items-center mb-6">
                <h3 class="text-lg font-bold">Hóa đơn vừa tạo</h3>
                <a href="/Invoices" class="text-emerald-600 text-sm font-semibold hover:underline">Quản lý hóa đơn</a>
            </div>
            <div class="space-y-4">
                @foreach (var invoice in Model.DashboardData.RecentInvoices)
                {
                    <div class="flex items-center gap-4 p-3 hover:bg-slate-50 rounded-xl transition-colors">
                        <div class="w-10 h-10 rounded-lg bg-emerald-50 text-emerald-600 flex items-center justify-center flex-shrink-0">
                            <span class="material-icons text-xl">receipt</span>
                        </div>
                        <div class="flex-1 min-w-0">
                            <h4 class="text-sm font-semibold text-slate-900">#@invoice.InvoiceNumber</h4>
                            <p class="text-xs text-slate-500">Phòng @invoice.Apartment?.ApartmentNumber - @invoice.CreatedAt.ToString("MM/yyyy")</p>
                        </div>
                        <div class="text-right">
                            <p class="text-sm font-bold text-slate-900">@invoice.TotalAmount.ToString("N0") đ</p>
                            <span class="text-[10px] @(invoice.Status == PRN222_ApartmentManagement.Models.Enums.InvoiceStatus.Paid ? "text-emerald-600" : "text-amber-600") font-bold uppercase">
                                @invoice.Status
                            </span>
                        </div>
                    </div>
                }
            </div>
        </div>
    </div>
</div>

