@page
@using PRN222_ApartmentManagement.Models.Enums
@model PRN222_ApartmentManagement.Pages.BQL_Manager.Invoices.IndexModel
@{
    ViewData["Title"] = "Phê duyệt hóa đơn";
    ViewData["CurrentPage"] = "invoices";
    Layout = "_Layout";
    ViewData["PageHeader"] = new
    {
        Title = "Phê duyệt hóa đơn",
        BreadcrumbItems = new[]
        {
            new { Label = "BQL Manager", Href = "/BQL_Manager" },
            new { Label = "Hóa đơn", Href = "#" }
        }
    };

    var pendingApprovalCount = Model.Invoices.Count(i => i.ApprovalStatus == InvoiceApprovalStatus.PendingApproval);
    var approvedCount = Model.Invoices.Count(i => i.ApprovalStatus == InvoiceApprovalStatus.Approved);
    var rejectedCount = Model.Invoices.Count(i => i.ApprovalStatus == InvoiceApprovalStatus.Rejected);
    var unstableCount = Model.Invoices.Count(i => i.Status == InvoiceStatus.Unpaid || i.Status == InvoiceStatus.Overdue) + rejectedCount;

    string GetPaymentLabel(InvoiceStatus status) => status switch
    {
        InvoiceStatus.Unpaid => "Chưa thanh toán",
        InvoiceStatus.Paid => "Đã thanh toán",
        InvoiceStatus.PartiallyPaid => "Thanh toán một phần",
        InvoiceStatus.Overdue => "Quá hạn",
        InvoiceStatus.Cancelled => "Đã hủy",
        InvoiceStatus.Pending => "Chờ xác nhận",
        _ => status.ToString()
    };

    string GetApprovalLabel(InvoiceApprovalStatus status) => status switch
    {
        InvoiceApprovalStatus.Draft => "Bản nháp",
        InvoiceApprovalStatus.PendingApproval => "Chờ duyệt",
        InvoiceApprovalStatus.Approved => "Đã duyệt",
        InvoiceApprovalStatus.Rejected => "Từ chối",
        _ => status.ToString()
    };

    string GetPaymentBadgeClass(InvoiceStatus status) => status switch
    {
        InvoiceStatus.Paid => "bg-emerald-50 text-emerald-700 ring-1 ring-emerald-200",
        InvoiceStatus.PartiallyPaid => "bg-amber-50 text-amber-700 ring-1 ring-amber-200",
        InvoiceStatus.Overdue => "bg-red-50 text-red-700 ring-1 ring-red-200",
        InvoiceStatus.Cancelled => "bg-slate-100 text-slate-700 ring-1 ring-slate-200",
        InvoiceStatus.Pending => "bg-amber-50 text-amber-700 ring-1 ring-amber-200",
        _ => "bg-slate-100 text-slate-700 ring-1 ring-slate-200"
    };

    string GetApprovalBadgeClass(InvoiceApprovalStatus status) => status switch
    {
        InvoiceApprovalStatus.Approved => "bg-emerald-50 text-emerald-700 ring-1 ring-emerald-200",
        InvoiceApprovalStatus.PendingApproval => "bg-amber-50 text-amber-700 ring-1 ring-amber-200",
        InvoiceApprovalStatus.Rejected => "bg-red-50 text-red-700 ring-1 ring-red-200",
        _ => "bg-slate-100 text-slate-700 ring-1 ring-slate-200"
    };
}

<div class="space-y-6">
    <section class="grid grid-cols-1 gap-4 md:grid-cols-2 xl:grid-cols-4">
        <div class="rounded-xl border border-slate-200 bg-white p-5 shadow-sm">
            <div class="flex items-start justify-between gap-4">
                <div>
                    <p class="text-sm font-medium text-slate-500">Tổng hóa đơn</p>
                    <p class="mt-3 text-3xl font-bold tracking-tight text-slate-900">@Model.Invoices.Count</p>
                    <p class="mt-2 text-sm text-slate-500">Đang hiển thị theo bộ lọc</p>
                </div>
                <div class="flex h-11 w-11 items-center justify-center rounded-xl bg-emerald-50 text-emerald-600">
                    <span class="material-icons">inventory_2</span>
                </div>
            </div>
        </div>
        <div class="rounded-xl border border-slate-200 bg-white p-5 shadow-sm">
            <div class="flex items-start justify-between gap-4">
                <div>
                    <p class="text-sm font-medium text-slate-500">Chờ duyệt</p>
                    <p class="mt-3 text-3xl font-bold tracking-tight text-slate-900">@pendingApprovalCount</p>
                    <p class="mt-2 text-sm text-slate-500">Cần quyết định của manager</p>
                </div>
                <div class="flex h-11 w-11 items-center justify-center rounded-xl bg-amber-50 text-amber-600">
                    <span class="material-icons">fact_check</span>
                </div>
            </div>
        </div>
        <div class="rounded-xl border border-slate-200 bg-white p-5 shadow-sm">
            <div class="flex items-start justify-between gap-4">
                <div>
                    <p class="text-sm font-medium text-slate-500">Đã duyệt</p>
                    <p class="mt-3 text-3xl font-bold tracking-tight text-slate-900">@approvedCount</p>
                    <p class="mt-2 text-sm text-slate-500">Sẵn sàng chuyển sang bước gửi</p>
                </div>
                <div class="flex h-11 w-11 items-center justify-center rounded-xl bg-emerald-50 text-emerald-600">
                    <span class="material-icons">verified</span>
                </div>
            </div>
        </div>
        <div class="rounded-xl border border-slate-200 bg-white p-5 shadow-sm">
            <div class="flex items-start justify-between gap-4">
                <div>
                    <p class="text-sm font-medium text-slate-500">Cần theo dõi</p>
                    <p class="mt-3 text-3xl font-bold tracking-tight text-slate-900">@unstableCount</p>
                    <p class="mt-2 text-sm text-slate-500">Hóa đơn chưa ổn định trạng thái</p>
                </div>
                <div class="flex h-11 w-11 items-center justify-center rounded-xl bg-rose-50 text-rose-600">
                    <span class="material-icons">priority_high</span>
                </div>
            </div>
        </div>
    </section>

    @if (!string.IsNullOrWhiteSpace(Model.StatusMessage))
    {
        <div class="rounded-xl border border-emerald-200 bg-emerald-50 px-4 py-3 text-sm text-emerald-700">
            @Model.StatusMessage
        </div>
    }

    <section class="rounded-xl border border-slate-200 bg-white p-6 shadow-sm">
        <div class="mb-5 flex items-start justify-between gap-4">
            <div>
                <h2 class="text-lg font-semibold text-slate-900">Bộ lọc phê duyệt</h2>
                <p class="mt-1 text-sm text-slate-500">Tập trung vào những hóa đơn cần review theo kỳ, thanh toán và approval status.</p>
            </div>
            <div class="flex h-10 w-10 items-center justify-center rounded-xl bg-slate-100 text-slate-600">
                <span class="material-icons">rule</span>
            </div>
        </div>

        <form method="get" class="grid grid-cols-1 gap-4 md:grid-cols-2 xl:grid-cols-4">
            <div class="space-y-2">
                <label asp-for="BillingMonth" class="text-sm font-medium text-slate-700">Tháng</label>
                <input asp-for="BillingMonth" type="number" min="1" max="12"
                       class="w-full rounded-lg border border-slate-200 px-4 py-2 text-sm text-slate-900 focus:outline-none focus:ring-2 focus:ring-emerald-500" />
            </div>
            <div class="space-y-2">
                <label asp-for="BillingYear" class="text-sm font-medium text-slate-700">Năm</label>
                <input asp-for="BillingYear" type="number" min="2024"
                       class="w-full rounded-lg border border-slate-200 px-4 py-2 text-sm text-slate-900 focus:outline-none focus:ring-2 focus:ring-emerald-500" />
            </div>
            <div class="space-y-2">
                <label asp-for="Status" class="text-sm font-medium text-slate-700">Thanh toán</label>
                <select asp-for="Status" asp-items="Html.GetEnumSelectList<InvoiceStatus>()"
                        class="w-full rounded-lg border border-slate-200 bg-white px-4 py-2 text-sm text-slate-900 focus:outline-none focus:ring-2 focus:ring-emerald-500">
                    <option value="">Tất cả trạng thái</option>
                </select>
            </div>
            <div class="space-y-2">
                <label asp-for="ApprovalStatus" class="text-sm font-medium text-slate-700">Phê duyệt</label>
                <select asp-for="ApprovalStatus" asp-items="Html.GetEnumSelectList<InvoiceApprovalStatus>()"
                        class="w-full rounded-lg border border-slate-200 bg-white px-4 py-2 text-sm text-slate-900 focus:outline-none focus:ring-2 focus:ring-emerald-500">
                    <option value="">Tất cả trạng thái</option>
                </select>
            </div>
            <div class="md:col-span-2 xl:col-span-4 flex flex-wrap items-center gap-3 pt-2">
                <button type="submit" class="inline-flex items-center gap-2 rounded-lg bg-emerald-600 px-4 py-2 text-sm font-medium text-white transition-colors hover:bg-emerald-700">
                    <span class="material-icons text-base">filter_alt</span>
                    Lọc danh sách
                </button>
                <a asp-page="./Index" class="inline-flex items-center gap-2 rounded-lg border border-slate-200 px-4 py-2 text-sm font-medium text-slate-600 transition-colors hover:bg-slate-50">
                    <span class="material-icons text-base">restart_alt</span>
                    Xóa bộ lọc
                </a>
            </div>
        </form>
    </section>

    <section class="overflow-hidden rounded-xl border border-slate-200 bg-white shadow-sm">
        <div class="flex flex-col gap-3 border-b border-slate-200 px-6 py-5 md:flex-row md:items-center md:justify-between">
            <div>
                <h2 class="text-lg font-semibold text-slate-900">Danh sách chờ xử lý</h2>
                <p class="mt-1 text-sm text-slate-500">Kiểm tra thông tin, xem chi tiết và duyệt hóa đơn trước khi gửi cho cư dân.</p>
            </div>
            <div class="inline-flex items-center gap-2 rounded-full bg-slate-100 px-3 py-1.5 text-sm text-slate-600">
                <span class="material-icons text-base">approval</span>
                @pendingApprovalCount hóa đơn đang chờ
            </div>
        </div>

        @if (Model.Invoices.Any())
        {
            <div class="overflow-x-auto">
                <table class="min-w-full text-sm">
                    <thead class="bg-slate-50 text-slate-600">
                        <tr>
                            <th class="px-6 py-3 text-left font-semibold">Hóa đơn</th>
                            <th class="px-6 py-3 text-left font-semibold">Căn hộ</th>
                            <th class="px-6 py-3 text-left font-semibold">Kỳ</th>
                            <th class="px-6 py-3 text-left font-semibold">Thanh toán</th>
                            <th class="px-6 py-3 text-left font-semibold">Phê duyệt</th>
                            <th class="px-6 py-3 text-right font-semibold">Tổng tiền</th>
                            <th class="px-6 py-3 text-right font-semibold">Thao tác</th>
                        </tr>
                    </thead>
                    <tbody class="divide-y divide-slate-100">
                        @foreach (var invoice in Model.Invoices)
                        {
                            <tr class="hover:bg-slate-50">
                                <td class="px-6 py-4 align-top">
                                    <div>
                                        <p class="font-semibold text-slate-900">@invoice.InvoiceNumber</p>
                                        <p class="mt-1 text-xs text-slate-500">Đến hạn @invoice.DueDate.ToString("dd/MM/yyyy")</p>
                                    </div>
                                </td>
                                <td class="px-6 py-4 align-top">
                                    <div>
                                        <p class="font-medium text-slate-800">Căn @invoice.Apartment.ApartmentNumber</p>
                                        <p class="mt-1 text-xs text-slate-500">Tòa @(string.IsNullOrWhiteSpace(invoice.Apartment.BuildingBlock) ? "-" : invoice.Apartment.BuildingBlock)</p>
                                    </div>
                                </td>
                                <td class="px-6 py-4 align-top text-slate-600">@invoice.BillingMonth/@invoice.BillingYear</td>
                                <td class="px-6 py-4 align-top">
                                    <span class="inline-flex rounded-full px-3 py-1 text-xs font-semibold @GetPaymentBadgeClass(invoice.Status)">
                                        @GetPaymentLabel(invoice.Status)
                                    </span>
                                </td>
                                <td class="px-6 py-4 align-top">
                                    <span class="inline-flex rounded-full px-3 py-1 text-xs font-semibold @GetApprovalBadgeClass(invoice.ApprovalStatus)">
                                        @GetApprovalLabel(invoice.ApprovalStatus)
                                    </span>
                                </td>
                                <td class="px-6 py-4 text-right align-top">
                                    <p class="font-semibold text-slate-900">@invoice.TotalAmount.ToString("N0")</p>
                                    <p class="mt-1 text-xs text-slate-500">VNĐ</p>
                                </td>
                                <td class="px-6 py-4 align-top">
                                    <div class="flex justify-end gap-2">
                                        <a asp-page="/Invoices/Print" asp-route-id="@invoice.InvoiceId"
                                           class="inline-flex items-center gap-2 rounded-lg border border-slate-200 px-3 py-2 text-sm font-medium text-slate-600 transition-colors hover:bg-slate-50">
                                            <span class="material-icons text-base">visibility</span>
                                            Xem
                                        </a>
                                        @if (invoice.ApprovalStatus == InvoiceApprovalStatus.PendingApproval)
                                        {
                                            <form method="post" asp-page-handler="Approve">
                                                <input type="hidden" name="id" value="@invoice.InvoiceId" />
                                                <button type="submit"
                                                        class="inline-flex items-center gap-2 rounded-lg bg-emerald-600 px-3 py-2 text-sm font-medium text-white transition-colors hover:bg-emerald-700">
                                                    <span class="material-icons text-base">done_all</span>
                                                    Duyệt
                                                </button>
                                            </form>
                                        }
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
        else
        {
            <div class="px-6 py-16 text-center">
                <div class="mx-auto flex h-16 w-16 items-center justify-center rounded-2xl bg-slate-100 text-slate-400">
                    <span class="material-icons text-3xl">task_alt</span>
                </div>
                <h3 class="mt-4 text-lg font-semibold text-slate-900">Không có hóa đơn cần hiển thị</h3>
                <p class="mt-2 text-sm text-slate-500">Bộ lọc hiện tại không trả về dữ liệu hoặc staff chưa tạo hóa đơn cho kỳ này.</p>
            </div>
        }
    </section>
</div>
