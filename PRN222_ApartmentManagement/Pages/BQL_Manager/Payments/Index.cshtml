@page
@using PRN222_ApartmentManagement.Models.Enums
@model PRN222_ApartmentManagement.Pages.BQL_Manager.Payments.IndexModel
@{
    ViewData["Title"] = "Giám sát thanh toán";
    ViewData["CurrentPage"] = "payments";
    Layout = "_Layout";
    ViewData["PageHeader"] = new
    {
        Title = "Giám sát thanh toán",
        BreadcrumbItems = new[]
        {
            new { Label = "BQL Manager", Href = "/BQL_Manager" },
            new { Label = "Thanh toán", Href = "#" }
        }
    };

    var totalAmount = Model.Transactions.Sum(t => t.Amount);
    var cashCount = Model.Transactions.Count(t => t.PaymentMethod == "Cash");
    var transferCount = Model.Transactions.Count(t => t.PaymentMethod == "BankTransfer");
    var onlineCount = Model.Transactions.Count(t => t.PaymentMethod == "VNPay" || t.PaymentMethod == "Momo");

    string GetTransactionStatusLabel(int status) => status switch
    {
        (int)PaymentTransactionStatus.Pending => "Đang xử lý",
        (int)PaymentTransactionStatus.Success => "Thành công",
        (int)PaymentTransactionStatus.Failed => "Thất bại",
        (int)PaymentTransactionStatus.Cancelled => "Đã hủy",
        _ => "Không xác định"
    };
}

<div class="space-y-6">
    <section class="grid grid-cols-1 gap-4 md:grid-cols-2 xl:grid-cols-4">
        <div class="rounded-xl border border-slate-200 bg-white p-5 shadow-sm">
            <p class="text-sm font-medium text-slate-500">Tổng giao dịch</p>
            <p class="mt-3 text-3xl font-bold tracking-tight text-slate-900">@Model.Transactions.Count</p>
        </div>
        <div class="rounded-xl border border-slate-200 bg-white p-5 shadow-sm">
            <p class="text-sm font-medium text-slate-500">Tổng thu</p>
            <p class="mt-3 text-3xl font-bold tracking-tight text-slate-900">@totalAmount.ToString("N0")</p>
        </div>
        <div class="rounded-xl border border-slate-200 bg-white p-5 shadow-sm">
            <p class="text-sm font-medium text-slate-500">Cash / Bank</p>
            <p class="mt-3 text-3xl font-bold tracking-tight text-slate-900">@(cashCount + transferCount)</p>
        </div>
        <div class="rounded-xl border border-slate-200 bg-white p-5 shadow-sm">
            <p class="text-sm font-medium text-slate-500">Online</p>
            <p class="mt-3 text-3xl font-bold tracking-tight text-slate-900">@onlineCount</p>
        </div>
    </section>

    <section class="rounded-xl border border-slate-200 bg-white p-6 shadow-sm">
        <div class="mb-5">
            <h2 class="text-lg font-semibold text-slate-900">Bộ lọc lịch sử</h2>
            <p class="mt-1 text-sm text-slate-500">Theo dõi tình hình thu tiền của toàn hệ thống.</p>
        </div>
        <form method="get" class="grid grid-cols-1 gap-4 md:grid-cols-4">
            <div class="space-y-2">
                <label asp-for="BillingMonth" class="text-sm font-medium text-slate-700">Tháng</label>
                <input asp-for="BillingMonth" type="number" min="1" max="12" class="w-full rounded-lg border border-slate-200 px-4 py-2 text-sm" />
            </div>
            <div class="space-y-2">
                <label asp-for="BillingYear" class="text-sm font-medium text-slate-700">Năm</label>
                <input asp-for="BillingYear" type="number" min="2024" class="w-full rounded-lg border border-slate-200 px-4 py-2 text-sm" />
            </div>
            <div class="space-y-2">
                <label asp-for="PaymentMethod" class="text-sm font-medium text-slate-700">Phương thức</label>
                <select asp-for="PaymentMethod" class="w-full rounded-lg border border-slate-200 bg-white px-4 py-2 text-sm">
                    <option value="">Tất cả</option>
                    <option value="Cash">Cash</option>
                    <option value="BankTransfer">Bank transfer</option>
                    <option value="VNPay">VNPay</option>
                    <option value="Momo">Momo</option>
                </select>
            </div>
            <div class="flex items-end gap-3">
                <button type="submit" class="inline-flex items-center gap-2 rounded-lg bg-emerald-600 px-4 py-2 text-sm font-medium text-white hover:bg-emerald-700">
                    <span class="material-icons text-base">filter_alt</span>
                    Lọc
                </button>
                <a asp-page="./Index" class="inline-flex items-center gap-2 rounded-lg border border-slate-200 px-4 py-2 text-sm font-medium text-slate-600 hover:bg-slate-50">
                    <span class="material-icons text-base">restart_alt</span>
                    Đặt lại
                </a>
            </div>
        </form>
    </section>

    <section class="overflow-hidden rounded-xl border border-slate-200 bg-white shadow-sm">
        <div class="border-b border-slate-200 px-6 py-5">
            <h2 class="text-lg font-semibold text-slate-900">Lịch sử giao dịch toàn hệ thống</h2>
        </div>
        @if (Model.Transactions.Any())
        {
            <div class="overflow-x-auto">
                <table class="min-w-full text-sm">
                    <thead class="bg-slate-50 text-slate-600">
                        <tr>
                            <th class="px-6 py-3 text-left font-semibold">Mã giao dịch</th>
                            <th class="px-6 py-3 text-left font-semibold">Hóa đơn</th>
                            <th class="px-6 py-3 text-left font-semibold">Phương thức</th>
                            <th class="px-6 py-3 text-left font-semibold">Trạng thái</th>
                            <th class="px-6 py-3 text-right font-semibold">Số tiền</th>
                            <th class="px-6 py-3 text-left font-semibold">Người ghi nhận</th>
                            <th class="px-6 py-3 text-right font-semibold">Biên lai</th>
                        </tr>
                    </thead>
                    <tbody class="divide-y divide-slate-100">
                        @foreach (var transaction in Model.Transactions)
                        {
                            <tr class="hover:bg-slate-50">
                                <td class="px-6 py-4">
                                    <p class="font-semibold text-slate-900">@transaction.TransactionCode</p>
                                    <p class="mt-1 text-xs text-slate-500">@transaction.PaymentDate.ToString("dd/MM/yyyy HH:mm")</p>
                                </td>
                                <td class="px-6 py-4">
                                    <p class="font-medium text-slate-800">@transaction.Invoice.InvoiceNumber</p>
                                    <p class="mt-1 text-xs text-slate-500">Căn @transaction.Invoice.Apartment.ApartmentNumber</p>
                                </td>
                                <td class="px-6 py-4 text-slate-600">@(string.IsNullOrWhiteSpace(transaction.PaymentMethod) ? "-" : transaction.PaymentMethod)</td>
                                <td class="px-6 py-4 text-slate-600">@GetTransactionStatusLabel(transaction.Status)</td>
                                <td class="px-6 py-4 text-right font-semibold text-slate-900">@transaction.Amount.ToString("N0") VNĐ</td>
                                <td class="px-6 py-4 text-slate-600">@(transaction.Creator?.FullName ?? "Hệ thống")</td>
                                <td class="px-6 py-4 text-right">
                                    <a asp-page="/Payments/Receipt" asp-route-id="@transaction.TransactionId" class="inline-flex items-center gap-2 rounded-lg border border-slate-200 px-3 py-2 text-sm font-medium text-slate-600 hover:bg-slate-50">
                                        <span class="material-icons text-base">receipt_long</span>
                                        Biên lai
                                    </a>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
        else
        {
            <div class="px-6 py-16 text-center text-sm text-slate-500">Chưa có giao dịch nào trong bộ lọc hiện tại.</div>
        }
    </section>
</div>
