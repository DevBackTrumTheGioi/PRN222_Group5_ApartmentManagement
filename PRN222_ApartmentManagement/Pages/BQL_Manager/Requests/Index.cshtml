@page
@model PRN222_ApartmentManagement.Pages.BQL_Manager.Requests.IndexModel
@using PRN222_ApartmentManagement.Models.Enums
@using PRN222_ApartmentManagement.Utils
@{
    ViewData["Title"] = "Quản lý yêu cầu";
    ViewData["Subtitle"] = "Tất cả yêu cầu từ cư dân — phân công và theo dõi xử lý";
    ViewData["CurrentPage"] = "requests";
}

<div class="space-y-6">

    @if (TempData["SuccessMessage"] != null)
    {
        <div class="flex items-center gap-3 p-4 bg-emerald-50 border border-emerald-200 rounded-xl text-emerald-700 text-sm">
            <span class="material-icons text-emerald-500">check_circle</span>
            @TempData["SuccessMessage"]
        </div>
    }
    @if (TempData["ErrorMessage"] != null)
    {
        <div class="flex items-center gap-3 p-4 bg-red-50 border border-red-200 rounded-xl text-red-700 text-sm">
            <span class="material-icons text-red-500">error</span>
            @TempData["ErrorMessage"]
        </div>
    }

    <!-- Tab navigation -->
    <div class="flex gap-2 border-b border-slate-200">
        <a asp-page="Index"
           class="inline-flex items-center gap-2 px-4 py-2.5 text-sm font-medium border-b-2 border-emerald-500 text-emerald-600 -mb-px">
            <span class="material-icons text-base">list_alt</span>
            Tất cả yêu cầu
        </a>
        <a asp-page="Escalated"
           class="inline-flex items-center gap-2 px-4 py-2.5 text-sm font-medium border-b-2 border-transparent text-slate-500 hover:text-orange-600 hover:border-orange-400 transition-colors -mb-px">
            <span class="material-icons text-base">escalator_warning</span>
            Yêu cầu chuyển cấp
        </a>
    </div>

    <!-- Stats row -->
    <div class="grid grid-cols-2 sm:grid-cols-5 gap-4">
        <div class="bg-white rounded-xl border border-slate-200 p-4 text-center shadow-sm">
            <p class="text-2xl font-bold text-slate-800">@Model.TotalCount</p>
            <p class="text-xs text-slate-500 mt-0.5">Tổng yêu cầu</p>
        </div>
        <div class="bg-amber-50 rounded-xl border border-amber-200 p-4 text-center shadow-sm">
            <p class="text-2xl font-bold text-amber-600">@Model.PendingCount</p>
            <p class="text-xs text-amber-500 mt-0.5">Chờ xử lý</p>
        </div>
        <div class="bg-blue-50 rounded-xl border border-blue-200 p-4 text-center shadow-sm">
            <p class="text-2xl font-bold text-blue-600">@Model.InProgressCount</p>
            <p class="text-xs text-blue-500 mt-0.5">Đang xử lý</p>
        </div>
        <div class="bg-emerald-50 rounded-xl border border-emerald-200 p-4 text-center shadow-sm">
            <p class="text-2xl font-bold text-emerald-600">@Model.CompletedCount</p>
            <p class="text-xs text-emerald-500 mt-0.5">Hoàn thành</p>
        </div>
        <div class="bg-slate-50 rounded-xl border border-slate-200 p-4 text-center shadow-sm">
            <p class="text-2xl font-bold text-slate-500">@Model.ClosedCount</p>
            <p class="text-xs text-slate-400 mt-0.5">Đã đóng</p>
        </div>
    </div>

    <!-- Filter bar -->
    <div class="bg-white rounded-xl border border-slate-200 shadow-sm p-4">
        <form method="get" class="flex flex-wrap items-end gap-3">
            <!-- Search -->
            <div class="flex flex-col gap-1 flex-1 min-w-[200px]">
                <label class="text-xs font-medium text-slate-600">Tìm kiếm</label>
                <div class="relative">
                    <span class="material-icons absolute left-3 top-1/2 -translate-y-1/2 text-slate-400 text-base">search</span>
                    <input type="text" name="SearchQuery" value="@Model.SearchQuery"
                           placeholder="Mã, tiêu đề, cư dân, căn hộ..."
                           class="w-full pl-9 pr-3 py-2 border border-slate-200 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-emerald-500 bg-white" />
                </div>
            </div>

            <!-- Status filter -->
            <div class="flex flex-col gap-1 min-w-[150px]">
                <label class="text-xs font-medium text-slate-600">Trạng thái</label>
                <select name="StatusFilter"
                        class="px-3 py-2 border border-slate-200 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-emerald-500 bg-white">
                    <option value="">Tất cả</option>
                    @foreach (var s in Enum.GetValues<RequestStatus>())
                    {
                        <option value="@s" selected="@(Model.StatusFilter == s)">@s.GetDisplayName()</option>
                    }
                </select>
            </div>

            <!-- Type filter -->
            <div class="flex flex-col gap-1 min-w-[150px]">
                <label class="text-xs font-medium text-slate-600">Loại yêu cầu</label>
                <select name="TypeFilter"
                        class="px-3 py-2 border border-slate-200 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-emerald-500 bg-white">
                    <option value="">Tất cả loại</option>
                    @foreach (var t in Enum.GetValues<RequestType>())
                    {
                        <option value="@t" selected="@(Model.TypeFilter == t)">@t.GetDisplayName()</option>
                    }
                </select>
            </div>

            <!-- Priority filter -->
            <div class="flex flex-col gap-1 min-w-[140px]">
                <label class="text-xs font-medium text-slate-600">Độ ưu tiên</label>
                <select name="PriorityFilter"
                        class="px-3 py-2 border border-slate-200 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-emerald-500 bg-white">
                    <option value="">Tất cả</option>
                    @foreach (var p in Enum.GetValues<RequestPriority>())
                    {
                        <option value="@p" selected="@(Model.PriorityFilter == p)">@p.GetDisplayName()</option>
                    }
                </select>
            </div>

            <div class="flex gap-2 ml-auto">
                @if (Model.HasFilter)
                {
                    <a asp-page="Index"
                       class="inline-flex items-center gap-1.5 px-4 py-2 border border-slate-200 text-slate-600 hover:bg-slate-50 rounded-lg text-sm transition-colors">
                        <span class="material-icons text-base">close</span>
                        Xóa lọc
                    </a>
                }
                <button type="submit"
                        class="inline-flex items-center gap-1.5 px-4 py-2 bg-slate-700 hover:bg-slate-800 text-white rounded-lg text-sm font-medium transition-colors">
                    <span class="material-icons text-base">filter_list</span>
                    Lọc
                </button>
            </div>
        </form>
    </div>

    <!-- Requests table -->
    @if (!Model.Requests.Any())
    {
        <div class="bg-white rounded-xl border border-slate-200 shadow-sm p-16 text-center">
            <span class="material-icons text-5xl text-slate-300 mb-3">inbox</span>
            <p class="text-slate-500 font-medium">Không có yêu cầu nào</p>
            <p class="text-sm text-slate-400 mt-1">
                @if (Model.HasFilter)
                {
                    <span>Không có yêu cầu phù hợp với bộ lọc đã chọn.</span>
                }
                else
                {
                    <span>Hệ thống chưa có yêu cầu nào từ cư dân.</span>
                }
            </p>
        </div>
    }
    else
    {
        <div class="bg-white rounded-xl border border-slate-200 shadow-sm overflow-hidden">
            <div class="overflow-x-auto">
                <table class="w-full text-sm">
                    <thead>
                        <tr class="border-b border-slate-100 bg-slate-50">
                            <th class="text-left px-4 py-3 text-xs font-semibold text-slate-500 uppercase tracking-wide">Mã / Tiêu đề</th>
                            <th class="text-left px-4 py-3 text-xs font-semibold text-slate-500 uppercase tracking-wide">Cư dân</th>
                            <th class="text-left px-4 py-3 text-xs font-semibold text-slate-500 uppercase tracking-wide">Loại</th>
                            <th class="text-left px-4 py-3 text-xs font-semibold text-slate-500 uppercase tracking-wide">Ưu tiên</th>
                            <th class="text-left px-4 py-3 text-xs font-semibold text-slate-500 uppercase tracking-wide">Trạng thái</th>
                            <th class="text-left px-4 py-3 text-xs font-semibold text-slate-500 uppercase tracking-wide">Phụ trách</th>
                            <th class="text-left px-4 py-3 text-xs font-semibold text-slate-500 uppercase tracking-wide">Ngày tạo</th>
                            <th class="text-right px-4 py-3 text-xs font-semibold text-slate-500 uppercase tracking-wide">Thao tác</th>
                        </tr>
                    </thead>
                    <tbody class="divide-y divide-slate-100">
                        @foreach (var req in Model.Requests)
                        {
                            var (statusBg, statusText, statusIcon) = req.Status switch {
                                RequestStatus.Pending    => ("bg-amber-50 text-amber-700 border-amber-200",       "Chờ xử lý",  "schedule"),
                                RequestStatus.InProgress => ("bg-blue-50 text-blue-700 border-blue-200",          "Đang xử lý", "sync"),
                                RequestStatus.Completed  => ("bg-emerald-50 text-emerald-700 border-emerald-200", "Hoàn thành", "check_circle"),
                                RequestStatus.Cancelled  => ("bg-slate-50 text-slate-500 border-slate-200",       "Đã hủy",     "cancel"),
                                RequestStatus.Rejected   => ("bg-red-50 text-red-600 border-red-200",             "Từ chối",    "block"),
                                _ => ("bg-slate-50 text-slate-500 border-slate-200", req.Status.ToString(), "help")
                            };

                            var (priBg, priText) = req.Priority switch {
                                RequestPriority.Emergency => ("bg-red-50 text-red-600 border-red-200",         "Khẩn cấp"),
                                RequestPriority.High      => ("bg-orange-50 text-orange-600 border-orange-200","Cao"),
                                RequestPriority.Normal    => ("bg-slate-50 text-slate-500 border-slate-200",   "Bình thường"),
                                RequestPriority.Low       => ("bg-slate-50 text-slate-400 border-slate-100",   "Thấp"),
                                _ => ("bg-slate-50 text-slate-400 border-slate-100", req.Priority.ToString())
                            };
                            <tr class="hover:bg-slate-50 transition-colors">
                                <!-- Mã / Tiêu đề -->
                                <td class="px-4 py-3">
                                    <p class="text-xs font-mono text-slate-400">@req.RequestNumber</p>
                                    <p class="font-medium text-slate-800 truncate max-w-[220px]" title="@req.Title">@req.Title</p>
                                    @if (req.RequestAttachments.Any())
                                    {
                                        <span class="inline-flex items-center gap-0.5 text-xs text-slate-400">
                                            <span class="material-icons text-xs">attach_file</span>
                                            @req.RequestAttachments.Count
                                        </span>
                                    }
                                </td>

                                <!-- Cư dân -->
                                <td class="px-4 py-3">
                                    <p class="font-medium text-slate-700">@req.Resident?.FullName</p>
                                    <p class="text-xs text-slate-400 flex items-center gap-1">
                                        <span class="material-icons text-xs">home</span>
                                        Căn hộ @req.Apartment?.ApartmentNumber
                                    </p>
                                </td>

                                <!-- Loại -->
                                <td class="px-4 py-3">
                                    @if (req.RequestType.HasValue)
                                    {
                                        <span class="inline-flex items-center px-2 py-0.5 rounded-full text-xs font-medium bg-slate-100 text-slate-600 border border-slate-200">
                                            @req.RequestType.Value.GetDisplayName()
                                        </span>
                                    }
                                    else
                                    {
                                        <span class="text-slate-400 text-xs">—</span>
                                    }
                                </td>

                                <!-- Ưu tiên -->
                                <td class="px-4 py-3">
                                    @{
                                        var isClosed = req.Status is RequestStatus.Completed
                                                                   or RequestStatus.Cancelled
                                                                   or RequestStatus.Rejected;
                                    }
                                    @if (isClosed)
                                    {
                                        <span class="inline-flex items-center px-2 py-0.5 rounded-full text-xs font-medium border @priBg">
                                            @priText
                                        </span>
                                    }
                                    else
                                    {
                                        <form method="post" asp-page-handler="UpdatePriority" class="flex items-center gap-1">
                                            <input type="hidden" name="requestId" value="@req.RequestId" />
                                            <select name="newPriority"
                                                    onchange="this.form.submit()"
                                                    class="px-2 py-1 border rounded-lg text-xs focus:outline-none focus:ring-2 focus:ring-emerald-500 bg-white @priBg">
                                                @foreach (var p in Enum.GetValues<RequestPriority>())
                                                {
                                                    <option value="@p" selected="@(req.Priority == p)">@p.GetDisplayName()</option>
                                                }
                                            </select>
                                        </form>
                                    }
                                </td>

                                <!-- Trạng thái -->
                                <td class="px-4 py-3">
                                    <span class="inline-flex items-center gap-1 px-2 py-0.5 rounded-full text-xs font-medium border @statusBg">
                                        <span class="material-icons text-[11px]">@statusIcon</span>
                                        @statusText
                                    </span>
                                </td>

                                <!-- Phụ trách -->
                                <td class="px-4 py-3">
                                    @if (req.AssignedUser != null)
                                    {
                                        <span class="inline-flex items-center gap-1 text-xs text-slate-600">
                                            <span class="material-icons text-xs text-emerald-500">person</span>
                                            @req.AssignedUser.FullName
                                        </span>
                                    }
                                    else if (req.Status == RequestStatus.Pending)
                                    {
                                        <!-- Inline assign form -->
                                        <form method="post" asp-page-handler="Assign" class="flex items-center gap-1">
                                            <input type="hidden" name="requestId" value="@req.RequestId" />
                                            <select name="staffId"
                                                    class="px-2 py-1 border border-slate-200 rounded-lg text-xs focus:outline-none focus:ring-2 focus:ring-emerald-500 bg-white max-w-[140px]">
                                                <option value="">Chọn staff...</option>
                                                @foreach (var staff in Model.StaffList)
                                                {
                                                    <option value="@staff.UserId">@staff.FullName</option>
                                                }
                                            </select>
                                            <button type="submit"
                                                    class="p-1 bg-emerald-600 hover:bg-emerald-700 text-white rounded-lg transition-colors"
                                                    title="Phân công">
                                                <span class="material-icons text-sm">check</span>
                                            </button>
                                        </form>
                                    }
                                    else
                                    {
                                        <span class="text-slate-400 text-xs">—</span>
                                    }
                                </td>

                                <!-- Ngày tạo -->
                                <td class="px-4 py-3 text-xs text-slate-500 whitespace-nowrap">
                                    @req.CreatedAt.ToString("dd/MM/yyyy")
                                    <br />
                                    <span class="text-slate-400">@req.CreatedAt.ToString("HH:mm")</span>
                                </td>

                                <!-- Thao tác -->
                                <td class="px-4 py-3 text-right">
                                    <a asp-page="Details" asp-route-id="@req.RequestId"
                                       class="inline-flex items-center gap-1 px-3 py-1.5 border border-slate-200 text-slate-600 hover:bg-emerald-50 hover:border-emerald-300 hover:text-emerald-700 rounded-lg text-xs font-medium transition-colors">
                                        <span class="material-icons text-sm">visibility</span>
                                        Chi tiết
                                    </a>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>

            <!-- Footer count -->
            <div class="px-4 py-3 border-t border-slate-100 bg-slate-50">
                <p class="text-xs text-slate-400">
                    Hiển thị <span class="font-semibold text-slate-600">@Model.Requests.Count</span> yêu cầu
                    @if (Model.HasFilter)
                    {
                        <span> (đã lọc từ <span class="font-semibold">@Model.TotalCount</span>)</span>
                    }
                </p>
            </div>
        </div>
    }

</div>
