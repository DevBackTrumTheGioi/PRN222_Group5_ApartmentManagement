@page
@model PRN222_ApartmentManagement.Pages.BQL_Staff.Invoices.IndexModel
@{
    ViewData["Title"] = "Quản lý hóa đơn";
    ViewData["CurrentPage"] = "invoices";
    Layout = "_Layout";
}

<div class="space-y-6">
    <div class="bg-white rounded-xl border border-slate-200 p-6 space-y-4">
        <div class="flex flex-col gap-4 lg:flex-row lg:items-end lg:justify-between">
            <form method="get" class="grid grid-cols-1 md:grid-cols-4 gap-4 flex-1">
                <div>
                    <label class="block text-sm font-medium mb-2">Tháng</label>
                    <input asp-for="BillingMonth" type="number" min="1" max="12" class="w-full rounded-lg border border-slate-200 px-3 py-2" />
                </div>
                <div>
                    <label class="block text-sm font-medium mb-2">Năm</label>
                    <input asp-for="BillingYear" type="number" min="2024" class="w-full rounded-lg border border-slate-200 px-3 py-2" />
                </div>
                <div>
                    <label class="block text-sm font-medium mb-2">Trạng thái</label>
                    <select asp-for="Status" asp-items="Html.GetEnumSelectList<PRN222_ApartmentManagement.Models.Enums.InvoiceStatus>()" class="w-full rounded-lg border border-slate-200 px-3 py-2">
                        <option value="">Tất cả</option>
                    </select>
                </div>
                <div>
                    <label class="block text-sm font-medium mb-2">Duyệt</label>
                    <select asp-for="ApprovalStatus" asp-items="Html.GetEnumSelectList<PRN222_ApartmentManagement.Models.Enums.InvoiceApprovalStatus>()" class="w-full rounded-lg border border-slate-200 px-3 py-2">
                        <option value="">Tất cả</option>
                    </select>
                </div>
                <div class="md:col-span-4">
                    <button type="submit" class="px-4 py-2 rounded-lg bg-slate-900 text-white">Lọc</button>
                </div>
            </form>

            <form method="post" asp-page-handler="Generate" class="grid grid-cols-3 gap-3">
                <input name="billingMonth" type="number" min="1" max="12" value="@(Model.BillingMonth ?? DateTime.Now.Month)" class="rounded-lg border border-slate-200 px-3 py-2" />
                <input name="billingYear" type="number" min="2024" value="@(Model.BillingYear ?? DateTime.Now.Year)" class="rounded-lg border border-slate-200 px-3 py-2" />
                <button type="submit" class="px-4 py-2 rounded-lg bg-emerald-600 text-white">Tạo tự động</button>
            </form>
        </div>

        @if (!string.IsNullOrWhiteSpace(Model.StatusMessage))
        {
            <div class="rounded-lg bg-emerald-50 border border-emerald-200 px-4 py-3 text-sm text-emerald-700">@Model.StatusMessage</div>
        }
    </div>

    <div class="bg-white rounded-xl border border-slate-200 overflow-hidden">
        <table class="w-full text-sm">
            <thead class="bg-slate-50">
                <tr>
                    <th class="px-4 py-3 text-left">Mã hóa đơn</th>
                    <th class="px-4 py-3 text-left">Căn hộ</th>
                    <th class="px-4 py-3 text-left">Kỳ</th>
                    <th class="px-4 py-3 text-left">Duyệt</th>
                    <th class="px-4 py-3 text-left">Gửi</th>
                    <th class="px-4 py-3 text-right">Tổng tiền</th>
                    <th class="px-4 py-3 text-right">Thao tác</th>
                </tr>
            </thead>
            <tbody class="divide-y divide-slate-100">
                @foreach (var invoice in Model.Invoices)
                {
                    <tr>
                        <td class="px-4 py-3 font-medium">@invoice.InvoiceNumber</td>
                        <td class="px-4 py-3">@invoice.Apartment.ApartmentNumber</td>
                        <td class="px-4 py-3">@invoice.BillingMonth/@invoice.BillingYear</td>
                        <td class="px-4 py-3">@invoice.ApprovalStatus</td>
                        <td class="px-4 py-3">@(invoice.IsSent ? "Đã gửi" : "Chưa gửi")</td>
                        <td class="px-4 py-3 text-right font-semibold">@invoice.TotalAmount.ToString("N0")</td>
                        <td class="px-4 py-3">
                            <div class="flex justify-end gap-2">
                                <a asp-page="/Invoices/Print" asp-route-id="@invoice.InvoiceId" class="px-3 py-2 rounded-lg border border-slate-200 hover:bg-slate-50">Xem</a>
                                @if (invoice.ApprovalStatus == PRN222_ApartmentManagement.Models.Enums.InvoiceApprovalStatus.Approved && !invoice.IsSent)
                                {
                                    <form method="post" asp-page-handler="Send">
                                        <input type="hidden" name="id" value="@invoice.InvoiceId" />
                                        <button type="submit" class="px-3 py-2 rounded-lg bg-emerald-600 text-white hover:bg-emerald-700">Gửi</button>
                                    </form>
                                }
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>
