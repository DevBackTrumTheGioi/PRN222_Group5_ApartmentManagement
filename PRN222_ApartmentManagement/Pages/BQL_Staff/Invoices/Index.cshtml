@page
@using PRN222_ApartmentManagement.Models.Enums
@model PRN222_ApartmentManagement.Pages.BQL_Staff.Invoices.IndexModel
@{
    ViewData["Title"] = "Quản lý hóa đơn";
    ViewData["CurrentPage"] = "invoices";
    ViewData["PageHeader"] = new
    {
        Title = "Quản lý hóa đơn",
        BreadcrumbItems = new[]
        {
            new { Label = "BQL Staff", Href = "/BQL_Staff" },
            new { Label = "Hóa đơn", Href = "#" }
        }
    };

    var issuedCount = Model.Invoices.Count(i => i.Status == InvoiceStatus.Issued);
    var paidCount = Model.Invoices.Count(i => i.Status == InvoiceStatus.Paid);
    var partiallyPaidCount = Model.Invoices.Count(i => i.Status == InvoiceStatus.PartiallyPaid);
    var overdueCount = Model.Invoices.Count(i => i.Status == InvoiceStatus.Overdue);
    var totalAmount = Model.Invoices.Sum(i => i.TotalAmount);

    string GetPaymentLabel(InvoiceStatus status) => status switch
    {
        InvoiceStatus.Unpaid => "Chưa thanh toán",
        InvoiceStatus.Paid => "Đã thanh toán",
        InvoiceStatus.PartiallyPaid => "Thanh toán một phần",
        InvoiceStatus.Overdue => "Quá hạn",
        InvoiceStatus.Cancelled => "Đã hủy",
        InvoiceStatus.Issued => "Đã phát hành",
        _ => status.ToString()
    };

    string GetPaymentBadgeClass(InvoiceStatus status) => status switch
    {
        InvoiceStatus.Paid => "bg-emerald-50 text-emerald-700 ring-1 ring-emerald-200",
        InvoiceStatus.PartiallyPaid => "bg-amber-50 text-amber-700 ring-1 ring-amber-200",
        InvoiceStatus.Overdue => "bg-red-50 text-red-700 ring-1 ring-red-200",
        InvoiceStatus.Cancelled => "bg-slate-100 text-slate-700 ring-1 ring-slate-200",
        InvoiceStatus.Issued => "bg-sky-50 text-sky-700 ring-1 ring-sky-200",
        _ => "bg-slate-100 text-slate-700 ring-1 ring-slate-200"
    };
}

<div class="space-y-6">
    <section class="grid grid-cols-1 gap-4 md:grid-cols-2 xl:grid-cols-4">
        <div class="rounded-xl border border-slate-200 bg-white p-5 shadow-sm">
            <div class="flex items-start justify-between gap-4">
                <div>
                    <p class="text-sm font-medium text-slate-500">Tổng hóa đơn</p>
                    <p class="mt-3 text-3xl font-bold tracking-tight text-slate-900">@Model.Invoices.Count</p>
                    <p class="mt-2 text-sm text-slate-500">Theo bộ lọc hiện tại</p>
                </div>
                <div class="flex h-11 w-11 items-center justify-center rounded-xl bg-emerald-50 text-emerald-600">
                    <span class="material-icons">receipt_long</span>
                </div>
            </div>
        </div>
        <div class="rounded-xl border border-slate-200 bg-white p-5 shadow-sm">
            <div class="flex items-start justify-between gap-4">
                <div>
                    <p class="text-sm font-medium text-slate-500">Đã phát hành</p>
                    <p class="mt-3 text-3xl font-bold tracking-tight text-slate-900">@issuedCount</p>
                    <p class="mt-2 text-sm text-slate-500">Đang chờ thanh toán</p>
                </div>
                <div class="flex h-11 w-11 items-center justify-center rounded-xl bg-sky-50 text-sky-600">
                    <span class="material-icons">send</span>
                </div>
            </div>
        </div>
        <div class="rounded-xl border border-slate-200 bg-white p-5 shadow-sm">
            <div class="flex items-start justify-between gap-4">
                <div>
                    <p class="text-sm font-medium text-slate-500">Quá hạn</p>
                    <p class="mt-3 text-3xl font-bold tracking-tight text-slate-900">@overdueCount</p>
                    <p class="mt-2 text-sm text-slate-500">Cần theo dõi</p>
                </div>
                <div class="flex h-11 w-11 items-center justify-center rounded-xl bg-rose-50 text-rose-600">
                    <span class="material-icons">warning</span>
                </div>
            </div>
        </div>
        <div class="rounded-xl border border-slate-200 bg-white p-5 shadow-sm">
            <div class="flex items-start justify-between gap-4">
                <div>
                    <p class="text-sm font-medium text-slate-500">Tổng giá trị</p>
                    <p class="mt-3 text-3xl font-bold tracking-tight text-slate-900">@totalAmount.ToString("N0")</p>
                    <p class="mt-2 text-sm text-slate-500">VND trong danh sách</p>
                </div>
                <div class="flex h-11 w-11 items-center justify-center rounded-xl bg-violet-50 text-violet-600">
                    <span class="material-icons">payments</span>
                </div>
            </div>
        </div>
    </section>

    @if (!string.IsNullOrWhiteSpace(Model.StatusMessage))
    {
        <div class="rounded-xl border border-emerald-200 bg-emerald-50 px-4 py-3 text-sm text-emerald-700">
            @Model.StatusMessage
        </div>
    }

    <section class="grid grid-cols-1 gap-6 xl:grid-cols-[minmax(0,1.6fr)_minmax(320px,0.9fr)]">
        <div class="rounded-xl border border-slate-200 bg-white p-6 shadow-sm">
            <div class="mb-5 flex items-start justify-between gap-4">
                <div>
                    <h2 class="text-lg font-semibold text-slate-900">Bộ lọc hóa đơn</h2>
                    <p class="mt-1 text-sm text-slate-500">Lọc theo kỳ và trạng thái thanh toán.</p>
                </div>
                <div class="flex h-10 w-10 items-center justify-center rounded-xl bg-slate-100 text-slate-600">
                    <span class="material-icons">tune</span>
                </div>
            </div>

            <form method="get" class="grid grid-cols-1 gap-4 md:grid-cols-2 xl:grid-cols-3">
                <div class="space-y-2">
                    <label asp-for="BillingMonth" class="text-sm font-medium text-slate-700">Tháng</label>
                    <input asp-for="BillingMonth" type="number" min="1" max="12" placeholder="VD: 3"
                           class="w-full rounded-lg border border-slate-200 px-4 py-2 text-sm text-slate-900 focus:outline-none focus:ring-2 focus:ring-emerald-500" />
                </div>
                <div class="space-y-2">
                    <label asp-for="BillingYear" class="text-sm font-medium text-slate-700">Năm</label> 
                    <input asp-for="BillingYear" type="number" min="2024" placeholder="VD: 2026"
                           class="w-full rounded-lg border border-slate-200 px-4 py-2 text-sm text-slate-900 focus:outline-none focus:ring-2 focus:ring-emerald-500" />
                </div>
                <div class="space-y-2">
                    <label asp-for="Status" class="text-sm font-medium text-slate-700">Trạng thái</label>
                    <select asp-for="Status" class="w-full rounded-lg border border-slate-200 bg-white px-4 py-2 text-sm text-slate-900 focus:outline-none focus:ring-2 focus:ring-emerald-500">
                        <option value="">Tất cả</option>
                        <option value="@InvoiceStatus.Issued">Đã phát hành</option>
                        <option value="@InvoiceStatus.Paid">Đã thanh toán</option>
                        <option value="@InvoiceStatus.PartiallyPaid">Thanh toán một phần</option>
                        <option value="@InvoiceStatus.Overdue">Quá hạn</option>
                        <option value="@InvoiceStatus.Cancelled">Đã hủy</option>
                    </select>
                </div>
                <div class="md:col-span-2 xl:col-span-3 flex flex-wrap items-center gap-3 pt-2">
                    <button type="submit" class="inline-flex items-center gap-2 rounded-lg bg-emerald-600 px-4 py-2 text-sm font-medium text-white transition-colors hover:bg-emerald-700">
                        <span class="material-icons text-base">filter_alt</span>
                        Lọc danh sách
                    </button>
                    <a asp-page="./Index" class="inline-flex items-center gap-2 rounded-lg border border-slate-200 px-4 py-2 text-sm font-medium text-slate-600 transition-colors hover:bg-slate-50">
                        <span class="material-icons text-base">restart_alt</span>
                        Xóa bộ lọc
                    </a>
                </div>
            </form>
        </div>

        <div class="rounded-xl border border-slate-200 bg-white p-6 shadow-sm">
            <div class="mb-5 flex items-start justify-between gap-4">
                <div>
                    <h2 class="text-lg font-semibold text-slate-900">Tạo hóa đơn tự động</h2>
                    <p class="mt-1 text-sm text-slate-500">Sinh hóa đơn hàng loạt cho một kỳ và gửi trực tiếp cho chủ hộ.</p>
                </div>
                <div class="flex h-10 w-10 items-center justify-center rounded-xl bg-emerald-50 text-emerald-600">
                    <span class="material-icons">auto_awesome</span>
                </div>
            </div>

            <form method="post" asp-page-handler="Generate" class="space-y-4">
                <div class="grid grid-cols-1 gap-4 md:grid-cols-2">
                    <div class="space-y-2">
                        <label for="billingMonthGenerate" class="text-sm font-medium text-slate-700">Tháng lập hóa đơn</label>
                        <input id="billingMonthGenerate" name="billingMonth" type="number" min="1" max="12"
                               value="@(Model.BillingMonth ?? DateTime.Now.Month)"
                               class="w-full rounded-lg border border-slate-200 px-4 py-2 text-sm text-slate-900 focus:outline-none focus:ring-2 focus:ring-emerald-500" />
                    </div>
                    <div class="space-y-2">
                        <label for="billingYearGenerate" class="text-sm font-medium text-slate-700">Nam</label>
                        <input id="billingYearGenerate" name="billingYear" type="number" min="2024"
                               value="@(Model.BillingYear ?? DateTime.Now.Year)"
                               class="w-full rounded-lg border border-slate-200 px-4 py-2 text-sm text-slate-900 focus:outline-none focus:ring-2 focus:ring-emerald-500" />
                    </div>
                </div>


                <button type="submit" class="inline-flex w-full items-center justify-center gap-2 rounded-lg bg-emerald-600 px-4 py-2.5 text-sm font-medium text-white transition-colors hover:bg-emerald-700">
                    <span class="material-icons text-base">add_circle</span>
                    Tao hóa đơn tự động
                </button>
            </form>
        </div>
    </section>

    <section class="overflow-hidden rounded-xl border border-slate-200 bg-white shadow-sm">
        <div class="flex flex-col gap-3 border-b border-slate-200 px-6 py-5 md:flex-row md:items-center md:justify-between">
            <div>
                    <h2 class="text-lg font-semibold text-slate-900">Danh sách hóa đơn</h2>
                    <p class="mt-1 text-sm text-slate-500">Theo dõi trạng thái thanh toán của từng hóa đơn.</p>
            </div>
        </div>

        @if (Model.Invoices.Any())
        {
            <div class="overflow-x-auto">
                <table class="min-w-full text-sm">
                    <thead class="bg-slate-50 text-slate-600">
                        <tr>
                            <th class="px-6 py-3 text-left font-semibold">Hóa đơn</th>
                            <th class="px-6 py-3 text-left font-semibold">Căn hộ</th>
                            <th class="px-6 py-3 text-left font-semibold">Kỳ</th>
                            <th class="px-6 py-3 text-left font-semibold">Trạng thái</th>
                            <th class="px-6 py-3 text-right font-semibold">Tổng tiền</th>
                            <th class="px-6 py-3 text-right font-semibold">Đã trả</th>
                            <th class="px-6 py-3 text-right font-semibold">Còn phải trả</th>
                            <th class="px-6 py-3 text-right font-semibold">Thao tác</th>
                        </tr>
                    </thead>
                    <tbody class="divide-y divide-slate-100">
                        @foreach (var invoice in Model.Invoices)
                        {
                            var remaining = invoice.TotalAmount - invoice.PaidAmount;
                            <tr class="hover:bg-slate-50">
                                <td class="px-6 py-4 align-top">
                                    <div>
                                        <p class="font-semibold text-slate-900">@invoice.InvoiceNumber</p>
                                        <p class="mt-1 text-xs text-slate-500">Lập ngày @invoice.IssueDate.ToString("dd/MM/yyyy")</p>
                                    </div>
                                </td>
                                <td class="px-6 py-4 align-top">
                                    <div>
                                        <p class="font-medium text-slate-800">Căn @invoice.Apartment?.ApartmentNumber</p>
                                        <p class="mt-1 text-xs text-slate-500">@(string.IsNullOrWhiteSpace(invoice.Apartment?.BuildingBlock) ? "-" : invoice.Apartment.BuildingBlock)</p>
                                    </div>
                                </td>
                                <td class="px-6 py-4 align-top text-slate-600">@invoice.BillingMonth/@invoice.BillingYear</td>
                                <td class="px-6 py-4 align-top">
                                    <span class="inline-flex rounded-full px-3 py-1 text-xs font-semibold @GetPaymentBadgeClass(invoice.Status)">
                                        @GetPaymentLabel(invoice.Status)
                                    </span>
                                </td>
                                <td class="px-6 py-4 text-right align-top">
                                    <p class="font-semibold text-slate-900">@invoice.TotalAmount.ToString("N0")</p>
                                    <p class="mt-1 text-xs text-slate-500">VND</p>
                                </td>
                                <td class="px-6 py-4 text-right align-top">
                                    <p class="font-medium text-emerald-600">@invoice.PaidAmount.ToString("N0")</p>
                                </td>
                                <td class="px-6 py-4 text-right align-top">
                                    <p class="font-semibold @(remaining > 0 ? "text-amber-600" : "text-slate-400")">@remaining.ToString("N0")</p>
                                </td>
                                <td class="px-6 py-4 align-top">
                                    <a asp-page="/Invoices/Print" asp-route-id="@invoice.InvoiceId"
                                       class="inline-flex items-center gap-2 rounded-lg border border-slate-200 px-3 py-2 text-sm font-medium text-slate-600 transition-colors hover:bg-slate-50">
                                        <span class="material-icons text-base">visibility</span>
                                        Xem
                                    </a>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
        else
        {
            <div class="px-6 py-16 text-center">
                <div class="mx-auto flex h-16 w-16 items-center justify-center rounded-2xl bg-slate-100 text-slate-400">
                    <span class="material-icons text-3xl">receipt_long</span>
                </div>
                <h3 class="mt-4 text-lg font-semibold text-slate-900">Chưa có hóa đơn phù hợp</h3>
                <p class="mt-2 text-sm text-slate-500">Hãy điều chỉnh bộ lọc hoặc tạo hóa đơn tự động cho kỳ hiện tại.</p>
            </div>
        }
    </section>
</div>
