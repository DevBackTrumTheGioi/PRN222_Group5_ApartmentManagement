@page
@model PRN222_ApartmentManagement.Pages.BQL_Staff.Requests.AssignedModel
@using PRN222_ApartmentManagement.Models.Enums
@using PRN222_ApartmentManagement.Utils
@{
    ViewData["Title"] = "Việc được giao";
    ViewData["Subtitle"] = "Danh sách yêu cầu đang được giao cho bạn";
    ViewData["CurrentPage"] = "assigned";
}

<div class="space-y-6">

    @if (TempData["SuccessMessage"] != null)
    {
        <div class="flex items-center gap-3 p-4 bg-emerald-50 border border-emerald-200 rounded-xl text-emerald-700 text-sm">
            <span class="material-icons text-emerald-500">check_circle</span>
            @TempData["SuccessMessage"]
        </div>
    }
    @if (TempData["ErrorMessage"] != null)
    {
        <div class="flex items-center gap-3 p-4 bg-red-50 border border-red-200 rounded-xl text-red-700 text-sm">
            <span class="material-icons text-red-500">error</span>
            @TempData["ErrorMessage"]
        </div>
    }

    <!-- Stats row -->
    <div class="grid grid-cols-2 sm:grid-cols-4 gap-4">
        <div class="bg-white rounded-xl border border-slate-200 p-4 text-center shadow-sm">
            <p class="text-2xl font-bold text-slate-800">@Model.TotalCount</p>
            <p class="text-xs text-slate-500 mt-0.5">Tổng được giao</p>
        </div>
        <div class="bg-amber-50 rounded-xl border border-amber-200 p-4 text-center shadow-sm">
            <p class="text-2xl font-bold text-amber-600">@Model.PendingCount</p>
            <p class="text-xs text-amber-500 mt-0.5">Chờ xử lý</p>
        </div>
        <div class="bg-blue-50 rounded-xl border border-blue-200 p-4 text-center shadow-sm">
            <p class="text-2xl font-bold text-blue-600">@Model.InProgressCount</p>
            <p class="text-xs text-blue-500 mt-0.5">Đang xử lý</p>
        </div>
        <div class="bg-emerald-50 rounded-xl border border-emerald-200 p-4 text-center shadow-sm">
            <p class="text-2xl font-bold text-emerald-600">@Model.CompletedCount</p>
            <p class="text-xs text-emerald-500 mt-0.5">Hoàn thành</p>
        </div>
    </div>

    <!-- Filter bar -->
    <div class="bg-white rounded-xl border border-slate-200 shadow-sm p-4">
        <form method="get" class="flex flex-wrap items-end gap-3">
            <!-- Search -->
            <div class="flex flex-col gap-1 flex-1 min-w-[200px]">
                <label class="text-xs font-medium text-slate-600">Tìm kiếm</label>
                <div class="relative">
                    <span class="material-icons absolute left-3 top-1/2 -translate-y-1/2 text-slate-400 text-base">search</span>
                    <input type="text" name="SearchQuery" value="@Model.SearchQuery"
                           placeholder="Mã yêu cầu, tiêu đề, căn hộ, cư dân..."
                           class="w-full pl-9 pr-3 py-2 border border-slate-200 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-emerald-500" />
                </div>
            </div>

            <!-- Status filter -->
            <div class="flex flex-col gap-1 min-w-[160px]">
                <label class="text-xs font-medium text-slate-600">Trạng thái</label>
                <select name="StatusFilter"
                        class="px-3 py-2 border border-slate-200 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-emerald-500 bg-white">
                    <option value="">Tất cả trạng thái</option>
                    @foreach (var status in Enum.GetValues<RequestStatus>())
                    {
                        <option value="@status" selected="@(Model.StatusFilter == status)">@status.GetDisplayName()</option>
                    }
                </select>
            </div>

            <!-- Priority filter -->
            <div class="flex flex-col gap-1 min-w-[140px]">
                <label class="text-xs font-medium text-slate-600">Ưu tiên</label>
                <select name="PriorityFilter"
                        class="px-3 py-2 border border-slate-200 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-emerald-500 bg-white">
                    <option value="">Tất cả</option>
                    @foreach (var p in Enum.GetValues<RequestPriority>())
                    {
                        <option value="@p" selected="@(Model.PriorityFilter == p)">@p.GetDisplayName()</option>
                    }
                </select>
            </div>

            <div class="flex gap-2">
                @if (Model.HasFilter)
                {
                    <a asp-page="Assigned"
                       class="inline-flex items-center gap-1.5 px-4 py-2 border border-slate-200 text-slate-600 hover:bg-slate-50 rounded-lg text-sm transition-colors">
                        <span class="material-icons text-base">close</span>
                        Xóa lọc
                    </a>
                }
                <button type="submit"
                        class="inline-flex items-center gap-1.5 px-4 py-2 bg-slate-700 hover:bg-slate-800 text-white rounded-lg text-sm font-medium transition-colors">
                    <span class="material-icons text-base">filter_list</span>
                    Lọc
                </button>
            </div>
        </form>
    </div>

    <!-- Requests list -->
    @if (!Model.Requests.Any())
    {
        <div class="bg-white rounded-xl border border-slate-200 shadow-sm p-16 text-center">
            <span class="material-icons text-5xl text-slate-300 mb-3">done_all</span>
            <p class="text-slate-500 font-medium">
                @if (Model.HasFilter)
                {
                    <span>Không có yêu cầu phù hợp với bộ lọc đã chọn.</span>
                }
                else
                {
                    <span>Không có yêu cầu nào được giao cho bạn.</span>
                }
            </p>
        </div>
    }
    else
    {
        <div class="space-y-3">
            @foreach (var req in Model.Requests)
            {
                var (statusBg, statusText, statusIcon) = req.Status switch {
                    RequestStatus.Pending    => ("bg-amber-50 text-amber-700 border-amber-200",       "Chờ xử lý",  "schedule"),
                    RequestStatus.InProgress => ("bg-blue-50 text-blue-700 border-blue-200",          "Đang xử lý", "sync"),
                    RequestStatus.Completed  => ("bg-emerald-50 text-emerald-700 border-emerald-200", "Hoàn thành", "check_circle"),
                    RequestStatus.Cancelled  => ("bg-slate-50 text-slate-500 border-slate-200",       "Đã hủy",     "cancel"),
                    RequestStatus.Rejected   => ("bg-red-50 text-red-600 border-red-200",             "Từ chối",    "block"),
                    _ => ("bg-slate-50 text-slate-500 border-slate-200", req.Status.ToString(), "help")
                };

                var (priBg, priText) = req.Priority switch {
                    RequestPriority.Emergency => ("bg-red-50 text-red-600 border-red-200",          "Khẩn cấp"),
                    RequestPriority.High      => ("bg-orange-50 text-orange-600 border-orange-200", "Cao"),
                    RequestPriority.Normal    => ("bg-slate-50 text-slate-500 border-slate-200",    "Bình thường"),
                    RequestPriority.Low       => ("bg-slate-50 text-slate-400 border-slate-100",    "Thấp"),
                    _ => ("bg-slate-50 text-slate-400 border-slate-100", req.Priority.ToString())
                };

                var isClosed = req.Status is RequestStatus.Completed
                                          or RequestStatus.Cancelled
                                          or RequestStatus.Rejected;

                <div class="bg-white rounded-xl border border-slate-200 shadow-sm hover:shadow-md hover:border-emerald-200 transition-all p-5">
                    <div class="flex flex-col sm:flex-row sm:items-start gap-4">

                        <!-- Icon -->
                        <div class="shrink-0 w-10 h-10 rounded-full bg-blue-50 border border-blue-100 flex items-center justify-center">
                            <span class="material-icons text-blue-600 text-lg">
                                @(req.RequestType switch {
                                    RequestType.Repair    => "build",
                                    RequestType.Complaint => "report_problem",
                                    RequestType.Feedback  => "rate_review",
                                    RequestType.Service   => "room_service",
                                    RequestType.Security  => "security",
                                    _ => "help_outline"
                                })
                            </span>
                        </div>

                        <!-- Content -->
                        <div class="flex-1 min-w-0">
                            <div class="flex flex-wrap items-center gap-2 mb-1">
                                <span class="text-xs font-mono text-slate-400">@req.RequestNumber</span>
                                <span class="inline-flex items-center gap-1 px-2 py-0.5 rounded-full text-xs font-medium border @statusBg">
                                    <span class="material-icons text-[11px]">@statusIcon</span>
                                    @statusText
                                </span>
                                @if (req.RequestType.HasValue)
                                {
                                    <span class="inline-flex items-center px-2 py-0.5 rounded-full text-xs font-medium bg-slate-100 text-slate-600 border border-slate-200">
                                        @req.RequestType.Value.GetDisplayName()
                                    </span>
                                }
                                <span class="inline-flex items-center px-2 py-0.5 rounded-full text-xs font-medium border @priBg">
                                    @priText
                                </span>
                                @if (req.EscalatedAt.HasValue)
                                {
                                    <span class="inline-flex items-center gap-1 px-2 py-0.5 rounded-full text-xs font-medium bg-orange-50 text-orange-600 border border-orange-200">
                                        <span class="material-icons text-[11px]">escalator_warning</span>
                                        Đã escalate
                                    </span>
                                }
                            </div>

                            <p class="font-semibold text-slate-800 truncate">@req.Title</p>

                            @if (!string.IsNullOrWhiteSpace(req.Description))
                            {
                                <p class="text-sm text-slate-500 mt-0.5 line-clamp-1">@req.Description</p>
                            }

                            <div class="flex flex-wrap items-center gap-x-4 gap-y-1 mt-2 text-xs text-slate-400">
                                <span class="flex items-center gap-1">
                                    <span class="material-icons text-xs">person</span>
                                    @(req.Resident?.FullName ?? "—")
                                </span>
                                <span class="flex items-center gap-1">
                                    <span class="material-icons text-xs">home</span>
                                    Căn hộ @req.Apartment?.ApartmentNumber
                                </span>
                                <span class="flex items-center gap-1">
                                    <span class="material-icons text-xs">calendar_today</span>
                                    @req.CreatedAt.ToString("dd/MM/yyyy HH:mm")
                                </span>
                                @if (req.RequestAttachments.Any())
                                {
                                    <span class="flex items-center gap-1">
                                        <span class="material-icons text-xs">attach_file</span>
                                        @req.RequestAttachments.Count tệp
                                    </span>
                                }
                                @if (req.Comments.Any())
                                {
                                    <span class="flex items-center gap-1">
                                        <span class="material-icons text-xs">forum</span>
                                        @req.Comments.Count bình luận
                                    </span>
                                }
                                @{
                                    var isActiveReq = req.Status is RequestStatus.Pending or RequestStatus.InProgress;
                                    var waitDays = (int)(DateTime.Now - req.CreatedAt).TotalDays;
                                }
                                @if (isActiveReq && waitDays >= 1)
                                {
                                    var waitBg = waitDays >= 7 ? "bg-red-50 text-red-600 border-red-200"
                                                : waitDays >= 3 ? "bg-orange-50 text-orange-500 border-orange-200"
                                                : "bg-amber-50 text-amber-500 border-amber-200";
                                    <span class="inline-flex items-center gap-0.5 px-1.5 py-0.5 rounded text-[10px] font-medium border @waitBg">
                                        <span class="material-icons text-[9px]">hourglass_bottom</span>
                                        Chờ @waitDays ngày
                                    </span>
                                }
                            </div>
                        </div>

                        <!-- Actions -->
                        <div class="shrink-0 flex flex-col gap-2 items-end">
                            <a asp-page="/BQL_Staff/Requests/Details" asp-route-id="@req.RequestId"
                               class="inline-flex items-center gap-1.5 px-3 py-1.5 border border-slate-200 text-slate-600 hover:bg-emerald-50 hover:border-emerald-300 hover:text-emerald-700 rounded-lg text-xs font-medium transition-colors whitespace-nowrap">
                                <span class="material-icons text-sm">visibility</span>
                                Xem chi tiết
                            </a>

                            @if (!isClosed)
                            {
                                @if (req.Status == RequestStatus.Pending)
                                {
                                    <form method="post" asp-page-handler="UpdateStatus">
                                        <input type="hidden" name="requestId" value="@req.RequestId" />
                                        <input type="hidden" name="newStatus" value="@RequestStatus.InProgress" />
                                        <button type="submit"
                                                class="inline-flex items-center gap-1.5 px-3 py-1.5 bg-blue-50 hover:bg-blue-100 text-blue-700 border border-blue-200 rounded-lg text-xs font-medium transition-colors whitespace-nowrap">
                                            <span class="material-icons text-sm">sync</span>
                                            Bắt đầu xử lý
                                        </button>
                                    </form>
                                }

                                @if (req.Status == RequestStatus.InProgress)
                                {
                                    <form method="post" asp-page-handler="UpdateStatus">
                                        <input type="hidden" name="requestId" value="@req.RequestId" />
                                        <input type="hidden" name="newStatus" value="@RequestStatus.Completed" />
                                        <button type="submit"
                                                class="inline-flex items-center gap-1.5 px-3 py-1.5 bg-emerald-50 hover:bg-emerald-100 text-emerald-700 border border-emerald-200 rounded-lg text-xs font-medium transition-colors whitespace-nowrap">
                                            <span class="material-icons text-sm">check_circle</span>
                                            Hoàn thành
                                        </button>
                                    </form>
                                }

                                @if (!req.EscalatedAt.HasValue)
                                {
                                    <a asp-page="Escalate" asp-route-id="@req.RequestId"
                                       class="inline-flex items-center gap-1.5 px-3 py-1.5 bg-orange-50 hover:bg-orange-100 text-orange-600 border border-orange-200 rounded-lg text-xs font-medium transition-colors whitespace-nowrap">
                                        <span class="material-icons text-sm">escalator_warning</span>
                                        Chuyển cấp
                                    </a>
                                }
                            }
                        </div>
                    </div>
                </div>
            }
        </div>

        <p class="text-xs text-slate-400 text-center">
            Hiển thị @Model.Requests.Count yêu cầu
            @if (Model.HasFilter)
            {
                <span> (đã lọc từ @Model.TotalCount yêu cầu)</span>
            }
        </p>
    }

</div>
