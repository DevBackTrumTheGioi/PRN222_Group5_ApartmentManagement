@page
@model PRN222_ApartmentManagement.Pages.BQL_Staff.ServiceOrders.AssignedModel
@using PRN222_ApartmentManagement.Models.Enums
@using PRN222_ApartmentManagement.Utils
@{
    ViewData["Title"] = "Đơn dịch vụ được giao";
    ViewData["CurrentPage"] = "assignedservices";
}

<div class="space-y-6">
    @if (TempData["SuccessMessage"] != null)
    {
        <div class="flex items-center gap-3 rounded-xl border border-emerald-200 bg-emerald-50 p-4 text-sm text-emerald-700">
            <span class="material-icons text-emerald-500">check_circle</span>
            @TempData["SuccessMessage"]
        </div>
    }
    @if (TempData["ErrorMessage"] != null)
    {
        <div class="flex items-center gap-3 rounded-xl border border-red-200 bg-red-50 p-4 text-sm text-red-700">
            <span class="material-icons text-red-500">error</span>
            @TempData["ErrorMessage"]
        </div>
    }

    <div class="grid grid-cols-2 gap-4 lg:grid-cols-4">
        <div class="rounded-xl border border-slate-200 bg-white p-4 text-center shadow-sm">
            <p class="text-2xl font-bold text-slate-800">@Model.TotalCount</p>
            <p class="mt-1 text-xs text-slate-500">Tổng được giao</p>
        </div>
        <div class="rounded-xl border border-amber-200 bg-amber-50 p-4 text-center shadow-sm">
            <p class="text-2xl font-bold text-amber-600">@Model.PendingCount</p>
            <p class="mt-1 text-xs text-amber-600">Chờ xác nhận</p>
        </div>
        <div class="rounded-xl border border-blue-200 bg-blue-50 p-4 text-center shadow-sm">
            <p class="text-2xl font-bold text-blue-600">@Model.InProgressCount</p>
            <p class="mt-1 text-xs text-blue-600">Đang xử lý</p>
        </div>
        <div class="rounded-xl border border-emerald-200 bg-emerald-50 p-4 text-center shadow-sm">
            <p class="text-2xl font-bold text-emerald-600">@Model.CompletedCount</p>
            <p class="mt-1 text-xs text-emerald-600">Hoàn thành</p>
        </div>
    </div>

    <div class="rounded-xl border border-slate-200 bg-white p-4 shadow-sm">
        <form method="get" class="flex flex-wrap items-end gap-3">
            <div class="min-w-[220px] flex-1 space-y-1">
                <label class="text-xs font-medium text-slate-600">Tìm kiếm</label>
                <input type="text" name="SearchQuery" value="@Model.SearchQuery" placeholder="Mã đơn, cư dân, căn hộ..."
                       class="w-full rounded-lg border border-slate-200 px-3 py-2 text-sm focus:border-emerald-500 focus:outline-none focus:ring-2 focus:ring-emerald-500/20" />
            </div>
            <div class="min-w-[180px] space-y-1">
                <label class="text-xs font-medium text-slate-600">Trạng thái</label>
                <select name="StatusFilter" class="w-full rounded-lg border border-slate-200 px-3 py-2 text-sm focus:border-emerald-500 focus:outline-none focus:ring-2 focus:ring-emerald-500/20">
                    <option value="">Tất cả trạng thái</option>
                    @foreach (var status in Enum.GetValues<ServiceOrderStatus>())
                    {
                        <option value="@status" selected="@(Model.StatusFilter == status)">@status.GetDisplayName()</option>
                    }
                </select>
            </div>
            <div class="ml-auto flex gap-2">
                @if (Model.HasFilter)
                {
                    <a asp-page="Assigned" class="inline-flex items-center gap-1 rounded-lg border border-slate-200 px-4 py-2 text-sm font-medium text-slate-600 transition-colors hover:bg-slate-50">
                        <span class="material-icons text-base">close</span>
                        Xóa lọc
                    </a>
                }
                <button type="submit" class="inline-flex items-center gap-1 rounded-lg bg-slate-700 px-4 py-2 text-sm font-medium text-white transition-colors hover:bg-slate-800">
                    <span class="material-icons text-base">filter_list</span>
                    Lọc
                </button>
            </div>
        </form>
    </div>

    @if (!Model.Orders.Any())
    {
        <div class="rounded-xl border border-slate-200 bg-white p-16 text-center shadow-sm">
            <span class="material-icons text-5xl text-slate-300">fact_check</span>
            <p class="mt-3 font-medium text-slate-600">Không có đơn nào được giao cho bạn.</p>
        </div>
    }
    else
    {
        <div class="space-y-3">
            @foreach (var order in Model.Orders)
            {
                var statusStyle = order.Status switch
                {
                    ServiceOrderStatus.Pending => "border-amber-200 bg-amber-50 text-amber-700",
                    ServiceOrderStatus.Confirmed => "border-blue-200 bg-blue-50 text-blue-700",
                    ServiceOrderStatus.InProgress => "border-blue-200 bg-blue-50 text-blue-700",
                    ServiceOrderStatus.Completed => "border-emerald-200 bg-emerald-50 text-emerald-700",
                    ServiceOrderStatus.Cancelled => "border-slate-200 bg-slate-50 text-slate-500",
                    ServiceOrderStatus.Rejected => "border-red-200 bg-red-50 text-red-600",
                    _ => "border-slate-200 bg-slate-50 text-slate-500"
                };

                <div class="rounded-xl border border-slate-200 bg-white p-5 shadow-sm transition-all hover:border-emerald-200 hover:shadow-md">
                    <div class="flex flex-col gap-4 sm:flex-row sm:items-start">
                        <div class="flex h-10 w-10 items-center justify-center rounded-full border border-blue-100 bg-blue-50">
                            <span class="material-icons text-blue-600">engineering</span>
                        </div>
                        <div class="min-w-0 flex-1">
                            <div class="flex flex-wrap items-center gap-2">
                                <span class="text-xs font-mono text-slate-400">@order.OrderNumber</span>
                                <span class="rounded-full border px-2 py-1 text-xs font-medium @statusStyle">@order.Status.GetDisplayName()</span>
                            </div>
                            <p class="mt-2 font-semibold text-slate-800">@order.ServiceType.ServiceTypeName</p>
                            <div class="mt-2 flex flex-wrap gap-x-4 gap-y-1 text-xs text-slate-400">
                                <span>@order.Resident.FullName</span>
                                <span>Căn hộ @order.Apartment.ApartmentNumber</span>
                                <span>@order.RequestedDate.ToString("dd/MM/yyyy") - @order.RequestedTimeSlot</span>
                            </div>
                        </div>
                        <div class="flex shrink-0 flex-col items-end gap-2">
                            <a asp-page="Details" asp-route-id="@order.ServiceOrderId"
                               class="inline-flex items-center gap-1 rounded-lg border border-slate-200 px-3 py-2 text-xs font-medium text-slate-600 transition-colors hover:border-emerald-300 hover:bg-emerald-50 hover:text-emerald-700">
                                <span class="material-icons text-sm">visibility</span>
                                Chi tiết
                            </a>
                            @if (order.Status == ServiceOrderStatus.Pending)
                            {
                                <form method="post" asp-page-handler="UpdateStatus">
                                    <input type="hidden" name="serviceOrderId" value="@order.ServiceOrderId" />
                                    <input type="hidden" name="newStatus" value="@ServiceOrderStatus.Confirmed" />
                                    <button type="submit" class="rounded-lg bg-blue-600 px-3 py-2 text-xs font-semibold text-white transition-colors hover:bg-blue-700">Tiếp nhận đơn</button>
                                </form>
                            }
                            else if (order.Status == ServiceOrderStatus.Confirmed)
                            {
                                <form method="post" asp-page-handler="UpdateStatus">
                                    <input type="hidden" name="serviceOrderId" value="@order.ServiceOrderId" />
                                    <input type="hidden" name="newStatus" value="@ServiceOrderStatus.InProgress" />
                                    <button type="submit" class="rounded-lg bg-indigo-600 px-3 py-2 text-xs font-semibold text-white transition-colors hover:bg-indigo-700">Bắt đầu xử lý</button>
                                </form>
                            }
                        </div>
                    </div>
                </div>
            }
        </div>
    }
</div>
