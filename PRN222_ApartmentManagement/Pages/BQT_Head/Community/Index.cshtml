@page
@model PRN222_ApartmentManagement.Pages.BQT_Head.Community.IndexModel
@using PRN222_ApartmentManagement.Models.Enums
@using PRN222_ApartmentManagement.Utils
@{
    ViewData["Title"] = "Khảo sát & bỏ phiếu";
    ViewData["Subtitle"] = "Tạo chiến dịch lấy ý kiến và theo dõi kết quả cư dân";
    ViewData["CurrentPage"] = "community";
}

<div class="space-y-6">
    @if (TempData["SuccessMessage"] != null)
    {
        <div class="rounded-xl border border-emerald-200 bg-emerald-50 px-4 py-3 text-sm text-emerald-700">@TempData["SuccessMessage"]</div>
    }
    @if (TempData["ErrorMessage"] != null)
    {
        <div class="rounded-xl border border-red-200 bg-red-50 px-4 py-3 text-sm text-red-700">@TempData["ErrorMessage"]</div>
    }

    <div class="flex items-center justify-between gap-4 rounded-2xl border border-slate-200 bg-white p-5 shadow-sm">
        <form method="get" class="flex flex-1 flex-wrap items-end gap-3">
            <div class="min-w-[220px] flex-1">
                <label class="mb-1 block text-xs font-medium text-slate-600">Tìm kiếm</label>
                <input asp-for="SearchTerm" class="w-full rounded-lg border border-slate-200 px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-emerald-500" placeholder="Tên chiến dịch, câu hỏi..." />
            </div>
            <div class="min-w-[180px]">
                <label class="mb-1 block text-xs font-medium text-slate-600">Loại</label>
                <select asp-for="TypeFilter" class="w-full rounded-lg border border-slate-200 px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-emerald-500">
                    <option value="">Tất cả</option>
                    @foreach (var item in Enum.GetValues<CommunityCampaignType>())
                    {
                        <option value="@item">@item.GetDisplayName()</option>
                    }
                </select>
            </div>
            <button type="submit" class="rounded-lg bg-slate-700 px-4 py-2.5 text-sm font-semibold text-white hover:bg-slate-800">Lọc</button>
        </form>
        <a asp-page="Create" class="rounded-lg bg-emerald-600 px-4 py-2.5 text-sm font-semibold text-white transition hover:bg-emerald-700">Tạo chiến dịch</a>
    </div>

    <div class="grid gap-4">
        @if (!Model.Campaigns.Any())
        {
            <div class="rounded-2xl border border-slate-200 bg-white p-12 text-center text-slate-400 shadow-sm">
                Chưa có khảo sát hoặc bỏ phiếu nào.
            </div>
        }
        else
        {
            @foreach (var item in Model.Campaigns)
            {
                var badgeClass = item.CampaignType == CommunityCampaignType.Vote
                    ? "border-blue-200 bg-blue-50 text-blue-700"
                    : "border-amber-200 bg-amber-50 text-amber-700";
                var statusClass = item.Status == CommunityCampaignStatus.Published
                    ? "border-emerald-200 bg-emerald-50 text-emerald-700"
                    : "border-slate-200 bg-slate-50 text-slate-600";

                <div class="rounded-2xl border border-slate-200 bg-white p-5 shadow-sm">
                    <div class="flex flex-wrap items-start justify-between gap-4">
                        <div>
                            <div class="flex flex-wrap items-center gap-2">
                                <h3 class="text-lg font-bold text-slate-900">@item.Title</h3>
                                <span class="rounded-full border px-2 py-0.5 text-xs font-medium @badgeClass">@item.CampaignType.GetDisplayName()</span>
                                <span class="rounded-full border px-2 py-0.5 text-xs font-medium @statusClass">@item.Status.GetDisplayName()</span>
                            </div>
                            <p class="mt-2 text-sm text-slate-600">@item.QuestionText</p>
                            <p class="mt-3 text-xs text-slate-400">Từ @item.StartsAt.ToString("dd/MM/yyyy HH:mm") đến @item.EndsAt.ToString("dd/MM/yyyy HH:mm")</p>
                        </div>
                        <div class="text-right text-sm">
                            <p class="font-semibold text-slate-900">@item.TotalResponses phản hồi</p>
                            <p class="text-slate-400">Tạo lúc @item.CreatedAt.ToString("dd/MM/yyyy HH:mm")</p>
                        </div>
                    </div>
                    <div class="mt-4 flex flex-wrap justify-end gap-2">
                        @if (item.Status == CommunityCampaignStatus.Published)
                        {
                            <form method="post" asp-page-handler="Close" asp-route-id="@item.CampaignId">
                                <button type="submit" class="rounded-lg border border-slate-200 px-3 py-2 text-sm font-medium text-slate-600 hover:bg-slate-50">Đóng chiến dịch</button>
                            </form>
                        }
                        <a asp-page="Results" asp-route-id="@item.CampaignId" class="rounded-lg bg-slate-900 px-3 py-2 text-sm font-medium text-white hover:bg-slate-800">Xem kết quả</a>
                    </div>
                </div>
            }
        }
    </div>
</div>
