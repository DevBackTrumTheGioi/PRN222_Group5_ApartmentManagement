@page
@model PRN222_ApartmentManagement.Pages.BQT_Head.Meetings.CreateModel
@using PRN222_ApartmentManagement.Models.Enums
@using PRN222_ApartmentManagement.Utils
@{
    ViewData["Title"] = "Tạo cuộc họp";
    ViewData["Subtitle"] = "Lên lịch và gửi thông báo cho cư dân";
    ViewData["CurrentPage"] = "meetings";
}

<div class="max-w-4xl space-y-6">
    <div>
        <h1 class="text-2xl font-bold tracking-tight text-slate-900">Tạo cuộc họp</h1>
        <p class="text-sm text-slate-500">Lên lịch họp BQT hoặc họp cư dân và gửi thông báo.</p>
    </div>

    <form method="post" class="bg-white border border-slate-200 rounded-xl shadow-sm overflow-hidden">
        <div class="p-6 space-y-6">
            <div asp-validation-summary="ModelOnly" class="text-sm text-red-600"></div>

            <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                <div class="md:col-span-2">
                    <label asp-for="Input.Title" class="block text-sm font-medium text-slate-700 mb-1"></label>
                    <input asp-for="Input.Title" class="w-full px-3 py-2 border border-slate-200 rounded-lg focus:outline-none focus:ring-2 focus:ring-emerald-500" />
                    <span asp-validation-for="Input.Title" class="text-xs text-red-600"></span>
                </div>

                <div class="md:col-span-2">
                    <label asp-for="Input.Description" class="block text-sm font-medium text-slate-700 mb-1">Nội dung / mục đích</label>
                    <textarea asp-for="Input.Description" rows="4" class="w-full px-3 py-2 border border-slate-200 rounded-lg focus:outline-none focus:ring-2 focus:ring-emerald-500"></textarea>
                    <span asp-validation-for="Input.Description" class="text-xs text-red-600"></span>
                </div>

                <div>
                    <label asp-for="Input.MeetingType" class="block text-sm font-medium text-slate-700 mb-1">Loại cuộc họp</label>
                    <select asp-for="Input.MeetingType" class="w-full px-3 py-2 border border-slate-200 rounded-lg focus:outline-none focus:ring-2 focus:ring-emerald-500">
                        @foreach (var item in Enum.GetValues<MeetingType>())
                        {
                            <option value="@item">@item.GetDisplayName()</option>
                        }
                    </select>
                    <span asp-validation-for="Input.MeetingType" class="text-xs text-red-600"></span>
                </div>

                <div>
                    <label asp-for="Input.Status" class="block text-sm font-medium text-slate-700 mb-1">Trạng thái</label>
                    <select asp-for="Input.Status" class="w-full px-3 py-2 border border-slate-200 rounded-lg focus:outline-none focus:ring-2 focus:ring-emerald-500">
                        @foreach (var item in Enum.GetValues<MeetingStatus>())
                        {
                            <option value="@item">@item.GetDisplayName()</option>
                        }
                    </select>
                    <span asp-validation-for="Input.Status" class="text-xs text-red-600"></span>
                </div>

                <div>
                    <label asp-for="Input.ScheduledDate" class="block text-sm font-medium text-slate-700 mb-1">Thời gian họp</label>
                    <input asp-for="Input.ScheduledDate" type="datetime-local" class="w-full px-3 py-2 border border-slate-200 rounded-lg focus:outline-none focus:ring-2 focus:ring-emerald-500" />
                    <span asp-validation-for="Input.ScheduledDate" class="text-xs text-red-600"></span>
                </div>

                <div>
                    <label asp-for="Input.Location" class="block text-sm font-medium text-slate-700 mb-1">Địa điểm</label>
                    <input asp-for="Input.Location" class="w-full px-3 py-2 border border-slate-200 rounded-lg focus:outline-none focus:ring-2 focus:ring-emerald-500" placeholder="Phòng họp, sảnh, sân..." />
                    <span asp-validation-for="Input.Location" class="text-xs text-red-600"></span>
                </div>

                <div>
                    <label asp-for="Input.StartTime" class="block text-sm font-medium text-slate-700 mb-1">Giờ bắt đầu</label>
                    <input asp-for="Input.StartTime" type="time" class="w-full px-3 py-2 border border-slate-200 rounded-lg focus:outline-none focus:ring-2 focus:ring-emerald-500" />
                    <span asp-validation-for="Input.StartTime" class="text-xs text-red-600"></span>
                </div>

                <div>
                    <label asp-for="Input.EndTime" class="block text-sm font-medium text-slate-700 mb-1">Giờ kết thúc</label>
                    <input asp-for="Input.EndTime" type="time" class="w-full px-3 py-2 border border-slate-200 rounded-lg focus:outline-none focus:ring-2 focus:ring-emerald-500" />
                    <span asp-validation-for="Input.EndTime" class="text-xs text-red-600"></span>
                </div>
            </div>

            <label class="flex items-center gap-3 text-sm text-slate-700">
                <input asp-for="Input.SendNotificationToResidents" type="checkbox" class="h-4 w-4 rounded border-slate-300 text-emerald-600 focus:ring-emerald-500" />
                Gửi thông báo cho cư dân
            </label>
        </div>

        <div class="px-6 py-4 bg-slate-50 border-t border-slate-200 flex items-center justify-end gap-3">
            <a asp-page="Index" class="px-4 py-2 text-sm font-medium rounded-lg border border-slate-200 text-slate-600 hover:bg-white">Hủy</a>
            <button type="submit" class="px-4 py-2 text-sm font-medium rounded-lg bg-emerald-600 text-white hover:bg-emerald-700">Tạo cuộc họp</button>
        </div>
    </form>
</div>
