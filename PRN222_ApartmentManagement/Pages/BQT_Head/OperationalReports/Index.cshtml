@page
@model PRN222_ApartmentManagement.Pages.BQT_Head.OperationalReports.IndexModel
@using PRN222_ApartmentManagement.Models.Enums
@using PRN222_ApartmentManagement.Utils
@{
    ViewData["Title"] = "Báo cáo vận hành";
    ViewData["Subtitle"] = "Theo dõi yêu cầu, sự cố và hiệu suất xử lý theo kỳ";
    ViewData["CurrentPage"] = "operationalreports";
}

<div class="space-y-6">
    <div class="rounded-2xl border border-slate-200 bg-white p-5 shadow-sm">
        <form method="get" class="grid gap-4 md:grid-cols-4">
            <div>
                <label class="mb-1 block text-xs font-medium text-slate-600">Kỳ báo cáo</label>
                <select asp-for="Filter.PeriodType" class="w-full rounded-lg border border-slate-200 px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-emerald-500">
                    @foreach (var item in Enum.GetValues<ReportingPeriodType>())
                    {
                        <option value="@item">@item.GetDisplayName()</option>
                    }
                </select>
            </div>
            <div>
                <label class="mb-1 block text-xs font-medium text-slate-600">Năm</label>
                <input asp-for="Filter.Year" type="number" min="2020" max="2100" class="w-full rounded-lg border border-slate-200 px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-emerald-500" />
            </div>
            <div>
                <label class="mb-1 block text-xs font-medium text-slate-600">Tháng</label>
                <select asp-for="Filter.Month" class="w-full rounded-lg border border-slate-200 px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-emerald-500">
                    @for (var month = 1; month <= 12; month++)
                    {
                        <option value="@month">Tháng @month</option>
                    }
                </select>
            </div>
            <div>
                <label class="mb-1 block text-xs font-medium text-slate-600">Quý</label>
                <select asp-for="Filter.Quarter" class="w-full rounded-lg border border-slate-200 px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-emerald-500">
                    @for (var quarter = 1; quarter <= 4; quarter++)
                    {
                        <option value="@quarter">Quý @quarter</option>
                    }
                </select>
            </div>
            <div class="md:col-span-4 flex justify-end">
                <button type="submit" class="rounded-lg bg-emerald-600 px-4 py-2.5 text-sm font-semibold text-white transition hover:bg-emerald-700">
                    Cập nhật báo cáo
                </button>
            </div>
        </form>
    </div>

    <div class="rounded-2xl border border-slate-200 bg-slate-900 p-6 text-white shadow-sm">
        <p class="text-sm text-slate-300">Đang xem</p>
        <h2 class="mt-1 text-2xl font-bold">@Model.Report.CurrentPeriodLabel</h2>
        <p class="mt-2 text-sm text-slate-300">
            So sánh với <span class="font-semibold text-white">@Model.Report.PreviousPeriodLabel</span>
        </p>
    </div>

    <div class="grid gap-4 md:grid-cols-2 xl:grid-cols-4">
        @foreach (var metric in Model.Report.Metrics)
        {
            var trendClass = metric.DeltaValue >= 0 ? "text-emerald-600" : "text-red-600";
            var trendPrefix = metric.DeltaValue >= 0 ? "+" : string.Empty;
            <div class="rounded-2xl border border-slate-200 bg-white p-5 shadow-sm">
                <div class="flex items-center justify-between">
                    <div>
                        <p class="text-sm text-slate-500">@metric.Label</p>
                        <p class="mt-2 text-3xl font-bold text-slate-900">@metric.CurrentValue.ToString("0.#")@metric.UnitSuffix</p>
                    </div>
                    <div class="flex h-12 w-12 items-center justify-center rounded-2xl bg-emerald-50 text-emerald-600">
                        <span class="material-icons">@metric.Icon</span>
                    </div>
                </div>
                <div class="mt-4 flex items-center justify-between text-xs">
                    <span class="text-slate-400">Kỳ trước: @metric.PreviousValue.ToString("0.#")@metric.UnitSuffix</span>
                    <span class="font-semibold @trendClass">@trendPrefix@metric.DeltaPercent.ToString("0.#")%</span>
                </div>
            </div>
        }
    </div>

    <div class="grid gap-6 lg:grid-cols-2">
        <div class="rounded-2xl border border-slate-200 bg-white p-6 shadow-sm">
            <h3 class="text-lg font-bold text-slate-900">Phân rã trạng thái yêu cầu</h3>
            <div class="mt-5 overflow-x-auto">
                <table class="w-full text-sm">
                    <thead class="bg-slate-50 text-slate-500">
                        <tr>
                            <th class="px-4 py-3 text-left">Trạng thái</th>
                            <th class="px-4 py-3 text-right">@Model.Report.CurrentPeriodLabel</th>
                            <th class="px-4 py-3 text-right">@Model.Report.PreviousPeriodLabel</th>
                        </tr>
                    </thead>
                    <tbody class="divide-y divide-slate-100">
                        @foreach (var item in Model.Report.RequestStatusBreakdown)
                        {
                            <tr>
                                <td class="px-4 py-3 font-medium text-slate-700">@item.Label</td>
                                <td class="px-4 py-3 text-right text-slate-900">@item.CurrentCount</td>
                                <td class="px-4 py-3 text-right text-slate-500">@item.PreviousCount</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>

        <div class="rounded-2xl border border-slate-200 bg-white p-6 shadow-sm">
            <h3 class="text-lg font-bold text-slate-900">Phân rã đơn dịch vụ</h3>
            <div class="mt-5 overflow-x-auto">
                <table class="w-full text-sm">
                    <thead class="bg-slate-50 text-slate-500">
                        <tr>
                            <th class="px-4 py-3 text-left">Trạng thái</th>
                            <th class="px-4 py-3 text-right">@Model.Report.CurrentPeriodLabel</th>
                            <th class="px-4 py-3 text-right">@Model.Report.PreviousPeriodLabel</th>
                        </tr>
                    </thead>
                    <tbody class="divide-y divide-slate-100">
                        @foreach (var item in Model.Report.ServiceOrderBreakdown)
                        {
                            <tr>
                                <td class="px-4 py-3 font-medium text-slate-700">@item.Label</td>
                                <td class="px-4 py-3 text-right text-slate-900">@item.CurrentCount</td>
                                <td class="px-4 py-3 text-right text-slate-500">@item.PreviousCount</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>
