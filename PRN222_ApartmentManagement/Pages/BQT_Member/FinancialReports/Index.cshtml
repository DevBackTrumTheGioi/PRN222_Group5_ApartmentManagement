@page
@model PRN222_ApartmentManagement.Pages.BQT_Member.FinancialReports.IndexModel
@{
    ViewData["Title"] = "Báo cáo tài chính";
    ViewData["CurrentPage"] = "financialreports";
    Layout = "_Layout";
    ViewData["PageHeader"] = new
    {
        Title = "Báo cáo tài chính",
        BreadcrumbItems = new[]
        {
            new { Label = "BQT Member", Href = "/BQT_Member" },
            new { Label = "Xem báo cáo", Href = "#" }
        }
    };

    var chartMax = Model.Report.MonthlyTrend.Any()
        ? Math.Max(Model.Report.MonthlyTrend.Max(x => Math.Max(x.BilledAmount, x.CollectedAmount)), 1)
        : 1;
}

<div class="space-y-6">
    <div class="rounded-xl border border-slate-200 bg-slate-50 px-4 py-3 text-sm text-slate-600">
        Vai trò thành viên BQT chỉ có quyền xem báo cáo và giám sát số liệu, không có quyền xuất file hay chỉnh sửa dữ liệu tài chính.
    </div>

    <section class="rounded-xl border border-slate-200 bg-white p-6 shadow-sm">
        <div class="mb-5">
            <h2 class="text-lg font-semibold text-slate-900">Bộ lọc xem báo cáo</h2>
            <p class="mt-1 text-sm text-slate-500">Lọc theo năm và tháng để theo dõi tình hình thu phí của tòa nhà.</p>
        </div>

        <form method="get" class="grid grid-cols-1 gap-4 md:grid-cols-4">
            <div class="space-y-2">
                <label asp-for="Year" class="text-sm font-medium text-slate-700">Năm</label>
                <input asp-for="Year" type="number" min="2024" class="w-full rounded-lg border border-slate-200 px-4 py-2 text-sm" />
            </div>
            <div class="space-y-2">
                <label asp-for="Month" class="text-sm font-medium text-slate-700">Tháng</label>
                <select asp-for="Month" class="w-full rounded-lg border border-slate-200 bg-white px-4 py-2 text-sm">
                    <option value="">Toàn năm</option>
                    @for (var month = 1; month <= 12; month++)
                    {
                        <option value="@month">Tháng @month</option>
                    }
                </select>
            </div>
            <div class="md:col-span-2 flex items-end gap-3">
                <button type="submit" class="inline-flex items-center gap-2 rounded-lg bg-emerald-600 px-4 py-2 text-sm font-medium text-white hover:bg-emerald-700">
                    <span class="material-icons text-base">filter_alt</span>
                    Lọc báo cáo
                </button>
                <a asp-page="./Index" class="inline-flex items-center gap-2 rounded-lg border border-slate-200 px-4 py-2 text-sm font-medium text-slate-600 hover:bg-slate-50">
                    <span class="material-icons text-base">restart_alt</span>
                    Đặt lại
                </a>
            </div>
        </form>
    </section>

    <section class="grid grid-cols-1 gap-4 md:grid-cols-2 xl:grid-cols-4">
        <div class="rounded-xl border border-slate-200 bg-white p-5 shadow-sm">
            <p class="text-sm font-medium text-slate-500">Tổng phát hành</p>
            <p class="mt-3 text-3xl font-bold tracking-tight text-slate-900">@Model.Report.TotalBilled.ToString("N0")</p>
        </div>
        <div class="rounded-xl border border-slate-200 bg-white p-5 shadow-sm">
            <p class="text-sm font-medium text-slate-500">Tổng thu</p>
            <p class="mt-3 text-3xl font-bold tracking-tight text-emerald-700">@Model.Report.TotalCollected.ToString("N0")</p>
        </div>
        <div class="rounded-xl border border-slate-200 bg-white p-5 shadow-sm">
            <p class="text-sm font-medium text-slate-500">Công nợ</p>
            <p class="mt-3 text-3xl font-bold tracking-tight text-amber-700">@Model.Report.TotalOutstanding.ToString("N0")</p>
        </div>
        <div class="rounded-xl border border-slate-200 bg-white p-5 shadow-sm">
            <p class="text-sm font-medium text-slate-500">Tỷ lệ thu</p>
            <p class="mt-3 text-3xl font-bold tracking-tight text-slate-900">@Model.Report.CollectionRate.ToString("N2")%</p>
        </div>
    </section>

    <section class="rounded-xl border border-slate-200 bg-white p-6 shadow-sm">
        <div class="mb-5">
            <h2 class="text-lg font-semibold text-slate-900">Dashboard tài chính</h2>
            <p class="mt-1 text-sm text-slate-500">So sánh phát hành và đã thu theo tháng.</p>
        </div>

        <div class="grid grid-cols-12 gap-3 items-end h-72">
            @foreach (var point in Model.Report.MonthlyTrend)
            {
                var billedHeight = Math.Max(8, (int)Math.Round(point.BilledAmount / chartMax * 220m));
                var collectedHeight = Math.Max(8, (int)Math.Round(point.CollectedAmount / chartMax * 220m));
                <div class="flex flex-col items-center gap-2">
                    <div class="flex items-end gap-1 h-56">
                        <div class="w-3 rounded-t bg-slate-300" style="height:@(billedHeight)px"></div>
                        <div class="w-3 rounded-t bg-emerald-500" style="height:@(collectedHeight)px"></div>
                    </div>
                    <span class="text-xs font-medium text-slate-500">@point.Month</span>
                </div>
            }
        </div>
    </section>

    <section class="overflow-hidden rounded-xl border border-slate-200 bg-white shadow-sm">
        <div class="border-b border-slate-200 px-6 py-5">
            <h2 class="text-lg font-semibold text-slate-900">Báo cáo theo tháng</h2>
        </div>
        <div class="overflow-x-auto">
            <table class="min-w-full text-sm">
                <thead class="bg-slate-50 text-slate-600">
                    <tr>
                        <th class="px-6 py-3 text-left font-semibold">Tháng</th>
                        <th class="px-6 py-3 text-right font-semibold">Phát hành</th>
                        <th class="px-6 py-3 text-right font-semibold">Đã thu</th>
                        <th class="px-6 py-3 text-right font-semibold">Công nợ</th>
                        <th class="px-6 py-3 text-right font-semibold">Hóa đơn</th>
                    </tr>
                </thead>
                <tbody class="divide-y divide-slate-100">
                    @foreach (var row in Model.Report.MonthlyRows)
                    {
                        <tr class="hover:bg-slate-50">
                            <td class="px-6 py-4 font-medium text-slate-900">@row.Label</td>
                            <td class="px-6 py-4 text-right text-slate-700">@row.BilledAmount.ToString("N0")</td>
                            <td class="px-6 py-4 text-right font-semibold text-emerald-700">@row.CollectedAmount.ToString("N0")</td>
                            <td class="px-6 py-4 text-right font-semibold text-amber-700">@row.OutstandingAmount.ToString("N0")</td>
                            <td class="px-6 py-4 text-right text-slate-600">@row.InvoiceCount</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </section>
</div>
