@page
@model PRN222_ApartmentManagement.Pages.BQT_Member.Requests.IndexModel
@using PRN222_ApartmentManagement.Models.Enums
@using PRN222_ApartmentManagement.Utils
@{
    ViewData["Title"] = "Yêu cầu tồn đọng";
    ViewData["Subtitle"] = "Theo dõi các yêu cầu chưa đóng, không bao gồm khiếu nại";
    ViewData["CurrentPage"] = "bqtrequests";
}

<div class="space-y-6">
    @if (TempData["ErrorMessage"] != null)
    {
        <div class="flex items-center gap-3 rounded-xl border border-red-200 bg-red-50 p-4 text-sm text-red-700">
            <span class="material-icons text-red-500">error</span>
            @TempData["ErrorMessage"]
        </div>
    }

    @if (TempData["SuccessMessage"] != null)
    {
        <div class="flex items-center gap-3 rounded-xl border border-emerald-200 bg-emerald-50 p-4 text-sm text-emerald-700">
            <span class="material-icons text-emerald-500">check_circle</span>
            @TempData["SuccessMessage"]
        </div>
    }

    <div class="grid grid-cols-2 gap-4 sm:grid-cols-4">
        <div class="rounded-xl border border-slate-200 bg-white p-4 text-center shadow-sm">
            <p class="text-2xl font-bold text-slate-800">@Model.TotalCount</p>
            <p class="mt-0.5 text-xs text-slate-500">Tổng yêu cầu tồn đọng</p>
        </div>
        <div class="rounded-xl border border-amber-200 bg-amber-50 p-4 text-center shadow-sm">
            <p class="text-2xl font-bold text-amber-600">@Model.PendingCount</p>
            <p class="mt-0.5 text-xs text-amber-500">Chờ xử lý</p>
        </div>
        <div class="rounded-xl border border-blue-200 bg-blue-50 p-4 text-center shadow-sm">
            <p class="text-2xl font-bold text-blue-600">@Model.InProgressCount</p>
            <p class="mt-0.5 text-xs text-blue-500">Đang xử lý</p>
        </div>
        <div class="rounded-xl border border-orange-200 bg-orange-50 p-4 text-center shadow-sm">
            <p class="text-2xl font-bold text-orange-600">@Model.HighPriorityCount</p>
            <p class="mt-0.5 text-xs text-orange-500">Ưu tiên cao / khẩn</p>
        </div>
    </div>

    <div class="rounded-xl border border-slate-200 bg-white p-4 shadow-sm">
        <form method="get" class="flex flex-wrap items-end gap-3">
            <div class="flex min-w-[220px] flex-1 flex-col gap-1">
                <label class="text-xs font-medium text-slate-600">Tìm kiếm</label>
                <div class="relative">
                    <span class="material-icons absolute left-3 top-1/2 -translate-y-1/2 text-base text-slate-400">search</span>
                    <input type="text" name="SearchQuery" value="@Model.SearchQuery"
                           placeholder="Mã yêu cầu, tiêu đề, cư dân, căn hộ..."
                           class="w-full rounded-lg border border-slate-200 bg-white py-2 pl-9 pr-3 text-sm focus:outline-none focus:ring-2 focus:ring-emerald-500" />
                </div>
            </div>

            <div class="flex min-w-[160px] flex-col gap-1">
                <label class="text-xs font-medium text-slate-600">Loại yêu cầu</label>
                <select name="TypeFilter" class="rounded-lg border border-slate-200 bg-white px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-emerald-500">
                    <option value="">Tất cả</option>
                    @foreach (var item in Enum.GetValues<RequestType>().Where(t => t != RequestType.Complaint))
                    {
                        <option value="@item" selected="@(Model.TypeFilter == item)">@item.GetDisplayName()</option>
                    }
                </select>
            </div>

            <div class="flex min-w-[160px] flex-col gap-1">
                <label class="text-xs font-medium text-slate-600">Ưu tiên</label>
                <select name="PriorityFilter" class="rounded-lg border border-slate-200 bg-white px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-emerald-500">
                    <option value="">Tất cả</option>
                    @foreach (var item in Enum.GetValues<RequestPriority>())
                    {
                        <option value="@item" selected="@(Model.PriorityFilter == item)">@item.GetDisplayName()</option>
                    }
                </select>
            </div>

            <div class="ml-auto flex gap-2">
                @if (Model.HasFilter)
                {
                    <a asp-page="Index" class="inline-flex items-center gap-1.5 rounded-lg border border-slate-200 px-4 py-2 text-sm text-slate-600 transition-colors hover:bg-slate-50">
                        <span class="material-icons text-base">close</span>
                        Xóa lọc
                    </a>
                }
                <button type="submit" class="inline-flex items-center gap-1.5 rounded-lg bg-slate-700 px-4 py-2 text-sm font-medium text-white transition-colors hover:bg-slate-800">
                    <span class="material-icons text-base">filter_list</span>
                    Lọc
                </button>
            </div>
        </form>
    </div>

    @if (!Model.Requests.Any())
    {
        <div class="rounded-xl border border-slate-200 bg-white p-16 text-center shadow-sm">
            <span class="material-icons mb-3 text-5xl text-slate-300">assignment_turned_in</span>
            <p class="font-medium text-slate-500">Không có yêu cầu tồn đọng nào</p>
            <p class="mt-1 text-sm text-slate-400">
                @if (Model.HasFilter)
                {
                    <span>Không có dữ liệu phù hợp với bộ lọc hiện tại.</span>
                }
                else
                {
                    <span>Hiện không có yêu cầu nào ngoài khiếu nại đang chờ xử lý.</span>
                }
            </p>
        </div>
    }
    else
    {
        <div class="overflow-hidden rounded-xl border border-slate-200 bg-white shadow-sm">
            <div class="overflow-x-auto">
                <table class="w-full text-sm">
                    <thead>
                        <tr class="border-b border-slate-100 bg-slate-50">
                            <th class="px-4 py-3 text-left text-xs font-semibold uppercase tracking-wide text-slate-500">Mã / Tiêu đề</th>
                            <th class="px-4 py-3 text-left text-xs font-semibold uppercase tracking-wide text-slate-500">Loại</th>
                            <th class="px-4 py-3 text-left text-xs font-semibold uppercase tracking-wide text-slate-500">Cư dân</th>
                            <th class="px-4 py-3 text-left text-xs font-semibold uppercase tracking-wide text-slate-500">Ưu tiên</th>
                            <th class="px-4 py-3 text-left text-xs font-semibold uppercase tracking-wide text-slate-500">Trạng thái</th>
                            <th class="px-4 py-3 text-left text-xs font-semibold uppercase tracking-wide text-slate-500">Ngày gửi</th>
                            <th class="px-4 py-3 text-right text-xs font-semibold uppercase tracking-wide text-slate-500">Thao tác</th>
                        </tr>
                    </thead>
                    <tbody class="divide-y divide-slate-100">
                        @foreach (var req in Model.Requests)
                        {
                            var (statusBg, statusText, statusIcon) = req.Status switch
                            {
                                RequestStatus.Pending => ("bg-amber-50 text-amber-700 border-amber-200", "Chờ xử lý", "schedule"),
                                RequestStatus.InProgress => ("bg-blue-50 text-blue-700 border-blue-200", "Đang xử lý", "sync"),
                                _ => ("bg-slate-50 text-slate-500 border-slate-200", req.Status.ToString(), "help")
                            };

                            var (priBg, priText) = req.Priority switch
                            {
                                RequestPriority.Emergency => ("bg-red-50 text-red-600 border-red-200", "Khẩn cấp"),
                                RequestPriority.High => ("bg-orange-50 text-orange-600 border-orange-200", "Cao"),
                                RequestPriority.Normal => ("bg-slate-50 text-slate-500 border-slate-200", "Bình thường"),
                                RequestPriority.Low => ("bg-slate-50 text-slate-400 border-slate-100", "Thấp"),
                                _ => ("bg-slate-50 text-slate-400 border-slate-100", req.Priority.ToString())
                            };

                            <tr class="transition-colors hover:bg-slate-50">
                                <td class="px-4 py-3">
                                    <p class="text-xs font-mono text-slate-400">@req.RequestNumber</p>
                                    <p class="max-w-[280px] truncate font-medium text-slate-800" title="@req.Title">@req.Title</p>
                                </td>
                                <td class="px-4 py-3">
                                    <span class="inline-flex items-center rounded-full border border-slate-200 bg-slate-100 px-2 py-0.5 text-xs font-medium text-slate-600">
                                        @(req.RequestType?.GetDisplayName() ?? "Khác")
                                    </span>
                                </td>
                                <td class="px-4 py-3">
                                    <p class="font-medium text-slate-700">@req.Resident?.FullName</p>
                                    <p class="flex items-center gap-1 text-xs text-slate-400">
                                        <span class="material-icons text-xs">home</span>
                                        Căn hộ @req.Apartment?.ApartmentNumber
                                    </p>
                                </td>
                                <td class="px-4 py-3">
                                    <span class="inline-flex items-center rounded-full border px-2 py-0.5 text-xs font-medium @priBg">
                                        @priText
                                    </span>
                                </td>
                                <td class="px-4 py-3">
                                    <span class="inline-flex items-center gap-1 rounded-full border px-2 py-0.5 text-xs font-medium @statusBg">
                                        <span class="material-icons text-[11px]">@statusIcon</span>
                                        @statusText
                                    </span>
                                </td>
                                <td class="whitespace-nowrap px-4 py-3 text-xs text-slate-500">
                                    @req.CreatedAt.ToString("dd/MM/yyyy")
                                    <br />
                                    <span class="text-slate-400">@req.CreatedAt.ToString("HH:mm")</span>
                                </td>
                                <td class="px-4 py-3 text-right">
                                    <a asp-page="Details" asp-route-id="@req.RequestId"
                                       class="inline-flex items-center gap-1 rounded-lg border border-slate-200 px-3 py-1.5 text-xs font-medium text-slate-600 transition-colors hover:border-emerald-300 hover:bg-emerald-50 hover:text-emerald-700">
                                        <span class="material-icons text-sm">visibility</span>
                                        Xem chi tiết
                                    </a>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>

            <div class="border-t border-slate-100 bg-slate-50 px-4 py-3">
                <p class="text-xs text-slate-400">
                    Hiển thị <span class="font-semibold text-slate-600">@Model.Requests.Count</span> yêu cầu tồn đọng
                    @if (Model.HasFilter)
                    {
                        <span>(lọc từ <span class="font-semibold">@Model.TotalCount</span>)</span>
                    }
                </p>
            </div>
        </div>
    }
</div>
