<!-- Page Header -->
<partial name="Components/PageHeader" model='new { 
    Title = "User Management",
    BreadcrumbItems = breadcrumbs,
    NotificationCount = 3
}' />

<!-- Data Table -->
<partial name="Components/DataTable" model='new { 
    Columns = columns, 
    Rows = rows,
    CurrentPage = 1,
    TotalPages = 6,
    TotalItems = 24,
    ItemsPerPage = 4,
    ShowSearch = true,
    ShowActions = true,
    ShowPagination = true
}' />

