@page
@model PRN222_ApartmentManagement.Pages.Resident.Amenities.BookModel
@{
    ViewData["Title"] = "Đặt tiện ích";
}

<div class="max-w-2xl">
    <div class="bg-white p-6 rounded-xl border shadow-sm">
        <h2 class="text-lg font-bold mb-4">Đặt tiện ích</h2>
        <form method="post">
            <div class="space-y-4">
                <fieldset class="p-4 bg-slate-50 border rounded-lg">
                    <legend class="text-sm font-medium text-slate-700 px-2">Chọn tiện ích & thời gian</legend>
                    <div class="grid grid-cols-1 md:grid-cols-2 gap-4 mt-2">
                        <div>
                            <label class="block text-sm text-slate-700">Tiện ích</label>
                            <select asp-for="Input.AmenityId" class="form-select w-full">
                                <option value="">-- Chọn tiện ích --</option>
                                @foreach (var a in Model.Amenities)
                                {
                                    <option value="@a.AmenityId">@a.AmenityName</option>
                                }
                            </select>
                            <span asp-validation-for="Input.AmenityId" class="text-rose-600 text-sm"></span>
                        </div>

                        <div>
                            <label class="block text-sm text-slate-700">Ngày</label>
                            <input asp-for="Input.BookingDate" type="date" class="form-input w-full" />
                            <span asp-validation-for="Input.BookingDate" class="text-rose-600 text-sm"></span>
                        </div>

                        <div>
                            <label class="block text-sm text-slate-700">Bắt đầu</label>
                            <input asp-for="Input.StartTime" type="time" class="form-input w-full" />
                            <span asp-validation-for="Input.StartTime" class="text-rose-600 text-sm"></span>
                        </div>

                        <div>
                            <label class="block text-sm text-slate-700">Kết thúc</label>
                            <input asp-for="Input.EndTime" type="time" class="form-input w-full" />
                            <span asp-validation-for="Input.EndTime" class="text-rose-600 text-sm"></span>
                        </div>
                    </div>
                </fieldset>

                <fieldset class="p-4 bg-slate-50 border rounded-lg">
                    <legend class="text-sm font-medium text-slate-700 px-2">Ghi chú</legend>
                    <div class="mt-2">
                        <label class="block text-sm text-slate-700">Ghi chú (tuỳ chọn)</label>
                        <textarea asp-for="Input.Notes" class="form-textarea w-full"></textarea>
                    </div>
                </fieldset>

                <div class="flex items-center gap-3">
                    <button type="submit" class="btn btn-primary">Xác nhận đặt</button>
                    <a asp-page="Index" class="btn btn-secondary">Hủy</a>
                </div>
            </div>
        </form>
    </div>
</div>

@section Scripts{
    <partial name="_ValidationScriptsPartial" />
}
