@page
@model PRN222_ApartmentManagement.Pages.Resident.Amenities.IndexModel
@{
    ViewData["Title"] = "Tiện ích";
}

<div class="bg-white p-6 rounded-xl border">
    <div class="flex items-center justify-between mb-4">
        <h2 class="text-lg font-bold">Tiện ích</h2>
        <div class="flex items-center gap-2">
            <a class="btn btn-outline" href="@Url.Page("/Resident/Amenities/MyBookings")">Lịch của tôi</a>
            <a class="btn btn-primary" href="@Url.Page("/Resident/Amenities/Book")">Đặt tiện ích</a>
        </div>
    </div>

    <!-- Compact inline search + type filter -->
    <div class="mb-4 flex items-center gap-4">
        <div class="flex items-center w-full max-w-3xl bg-white rounded-md border border-slate-200 shadow-sm">
            <span class="material-icons text-slate-400 px-3">search</span>
            <input id="amenitySearch" class="flex-1 form-input border-0 py-2 px-2" placeholder="Tìm theo tên tiện ích" />
            <select id="amenityTypeFilter" class="form-select ml-3 mr-2 w-48">
                <option value="">Tất cả loại</option>
                @foreach (var t in Model.AmenityTypes)
                {
                    <option value="@t.AmenityTypeId" selected="@(Model.AmenityFilter==t.AmenityTypeId)">@t.TypeName</option>
                }
            </select>
            <button id="clearSearchBtn" type="button" title="Xóa" class="text-slate-400 hover:text-slate-600 pr-3" style="display:none;">
                <span class="material-icons">close</span>
            </button>
        </div>

        <div class="ml-auto text-sm text-slate-500">Tìm thấy <span class="font-semibold">@Model.TotalItems</span> tiện ích</div>
    </div>

    @if (!Model.Amenities.Any())
    {
        <div class="p-6 text-center text-slate-500">Không có tiện ích khả dụng vào lúc này.</div>
    }
    else
    {
        <div class="overflow-x-auto">
            <table class="w-full table-fixed text-sm">
                <colgroup>
                    <col style="width:35%" />
                    <col style="width:20%" />
                    <col style="width:8%" />
                    <col style="width:12%" />
                    <col style="width:15%" />
                    <col style="width:10%" />
                </colgroup>
                <thead>
                    <tr class="bg-slate-100 text-left text-slate-700">
                        <th class="px-3 py-2 font-semibold">Tên</th>
                        <th class="px-3 py-2 font-semibold">Loại</th>
                        <th class="px-3 py-2 font-semibold text-center">Sức chứa</th>
                        <th class="px-3 py-2 font-semibold text-center">Giá/giờ</th>
                        <th class="px-3 py-2 font-semibold">Vị trí</th>
                        <th class="px-3 py-2 font-semibold text-center">Hành động</th>
                    </tr>
                </thead>
                <tbody id="amenityTableBody">
                    @foreach (var a in Model.Amenities)
                    {
                        <tr data-amenity-id="@a.AmenityId" data-type-id="@a.AmenityTypeId" class="border-t hover:bg-slate-50">
                            <td class="px-3 py-3 align-middle">
                                <div class="font-medium">@a.AmenityName</div>
                                @if (!string.IsNullOrEmpty(a.Description))
                                {
                                    <div class="text-xs text-slate-400 mt-1">@a.Description</div>
                                }
                            </td>
                            <td class="px-3 py-3 text-slate-600 align-middle">@a.AmenityType?.TypeName</td>
                            <td class="px-3 py-3 text-center align-middle">@a.Capacity</td>
                            <td class="px-3 py-3 text-center align-middle">@String.Format("{0:N0}", a.PricePerHour ?? 0)</td>
                            <td class="px-3 py-3 align-middle">@a.Location</td>
                            <td class="px-3 py-3 text-center align-middle whitespace-nowrap">
                                <a href="@Url.Page("/Resident/Amenities/Book", new { amenityId = a.AmenityId })" class="inline-flex items-center gap-2 bg-emerald-600 hover:bg-emerald-700 text-white px-3 py-1 rounded-md">Đặt</a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>

        <div class="mt-4 px-4 py-3 bg-slate-50/30 border-t border-slate-100 flex items-center justify-between">
            <div>
                <p class="text-sm text-slate-500">Hiển thị <span class="font-medium text-slate-900">@((Model.PageIndex-1)*Model.PageSize+1)</span> - <span class="font-medium text-slate-900">@Math.Min(Model.PageIndex*Model.PageSize, Model.TotalItems)</span> trong tổng số <span class="font-medium text-slate-900">@Model.TotalItems</span> bản ghi</p>
            </div>
            <div class="flex items-center gap-2">
                <form method="get" class="inline-flex items-center gap-2">
                    <input type="hidden" name="AmenityFilter" value="@Model.AmenityFilter" />
                    <input type="hidden" name="PageIndex" value="@(Model.PageIndex-1)" />
                    <input type="hidden" name="PageSize" value="@Model.PageSize" />
                    <button class="px-3 py-1 bg-white border border-slate-200 rounded-lg text-sm" @(Model.PageIndex==1?"disabled":"")>Trước</button>
                </form>

                <div class="flex items-center gap-1">
                    @for (int i=1;i<=Model.TotalPages;i++)
                    {
                        <a href="?AmenityFilter=@Model.AmenityFilter&pageIndex=@i&pageSize=@Model.PageSize" class="w-8 h-8 rounded-lg text-sm font-medium flex items-center justify-center transition-colors @(i==Model.PageIndex?"bg-primary-600 text-white font-bold":"text-slate-600 hover:bg-slate-100")">@i</a>
                    }
                </div>

                <form method="get" class="inline-flex items-center gap-2">
                    <input type="hidden" name="AmenityFilter" value="@Model.AmenityFilter" />
                    <input type="hidden" name="PageIndex" value="@(Model.PageIndex+1)" />
                    <input type="hidden" name="PageSize" value="@Model.PageSize" />
                    <button class="px-3 py-1 bg-white border border-slate-200 rounded-lg text-sm" @(Model.PageIndex==Model.TotalPages?"disabled":"")>Sau</button>
                </form>

                <div class="ml-4">
                    <form method="get">
                        <input type="hidden" name="AmenityFilter" value="@Model.AmenityFilter" />
                        <label class="text-xs text-slate-500 mr-2">Số lượng</label>
                        <select name="PageSize" onchange="this.form.submit()" class="px-2 py-1 border rounded">
                            <option value="10" selected="@(Model.PageSize==10)">10</option>
                            <option value="20" selected="@(Model.PageSize==20)">20</option>
                            <option value="50" selected="@(Model.PageSize==50)">50</option>
                            <option value="100" selected="@(Model.PageSize==100)">100</option>
                        </select>
                    </form>
                </div>
            </div>
        </div>
    }
</div>

@section Scripts {
    <script>
        document.addEventListener('DOMContentLoaded', function () {
            const typeFilter = document.getElementById('amenityTypeFilter');
            const searchInput = document.getElementById('amenitySearch');
            const clearBtn = document.getElementById('clearSearchBtn');

            function debounce(fn, delay) {
                let t;
                return function (...args) {
                    clearTimeout(t);
                    t = setTimeout(() => fn.apply(this, args), delay);
                };
            }

            function applyFilters() {
                const typeVal = typeFilter.value;
                const text = searchInput.value.trim().toLowerCase();
                const rows = document.querySelectorAll('#amenityTableBody tr');
                rows.forEach(r => {
                    const typeId = r.getAttribute('data-type-id') || '';
                    const name = r.querySelector('td')?.innerText.trim().toLowerCase() || '';

                    const matchesType = !typeVal || typeId === typeVal;
                    const matchesText = !text || name.indexOf(text) !== -1;

                    r.style.display = (matchesType && matchesText) ? '' : 'none';
                });

                clearBtn.style.display = searchInput.value ? 'inline-block' : 'none';
            }

            const debouncedApply = debounce(applyFilters, 250);

            searchInput.addEventListener('input', debouncedApply);
            clearBtn.addEventListener('click', function () { searchInput.value = ''; applyFilters(); searchInput.focus(); });
            typeFilter.addEventListener('change', applyFilters);
        });
    </script>
}