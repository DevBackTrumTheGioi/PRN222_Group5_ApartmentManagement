@page
@model PRN222_ApartmentManagement.Pages.Amenities.IndexModel
@{
    ViewData["Title"] = "Tiện ích";

    bool isAdmin = User.Identity?.IsAuthenticated == true &&
        (User.IsInRole("Admin") || User.IsInRole("BQL_Manager") || User.IsInRole("BQT_Head"));
}
@if (isAdmin)
{
    ViewData["Title"] = "Admin Dashboard";
    ViewData["Subtitle"] = "Quản trị hệ thống và cấu hình";

    <div class="space-y-6">
        <!-- Quick Stats -->
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6">
            <div class="bg-white p-6 rounded-2xl border border-slate-200 shadow-sm">
                <div class="flex items-center gap-4">
                    <div class="w-12 h-12 bg-blue-50 text-blue-600 rounded-xl flex items-center justify-center">
                        <span class="material-icons">group</span>
                    </div>
                    <div>
                        <p class="text-sm text-slate-500 font-medium">Người dùng</p>
                        <h3 class="text-2xl font-bold">@Model.DashboardData.TotalUsers</h3>
                    </div>
                </div>
                <div class="mt-4 text-xs text-emerald-500 font-medium">
                    @Model.DashboardData.ActiveUsers Đang hoạt động
                </div>
            </div>

            <div class="bg-white p-6 rounded-2xl border border-slate-200 shadow-sm">
                <div class="flex items-center gap-4">
                    <div class="w-12 h-12 bg-emerald-50 text-emerald-600 rounded-xl flex items-center justify-center">
                        <span class="material-icons">domain</span>
                    </div>
                    <div>
                        <p class="text-sm text-slate-500 font-medium">Căn hộ</p>
                        <h3 class="text-2xl font-bold">@Model.DashboardData.TotalApartments</h3>
                    </div>
                </div>
                <div class="mt-4 text-xs text-slate-500">
                    @Model.DashboardData.OccupiedApartments / @Model.DashboardData.TotalApartments Đã có người ở
                </div>
            </div>

            <div class="bg-white p-6 rounded-2xl border border-slate-200 shadow-sm">
                <div class="flex items-center gap-4">
                    <div class="w-12 h-12 bg-amber-50 text-amber-600 rounded-xl flex items-center justify-center">
                        <span class="material-icons">security</span>
                    </div>
                    <div>
                        <p class="text-sm text-slate-500 font-medium">Vai trò</p>
                        <h3 class="text-2xl font-bold">@Model.DashboardData.UsersByRole.Count</h3>
                    </div>
                </div>
            </div>

            <div class="bg-white p-6 rounded-2xl border border-slate-200 shadow-sm">
                <div class="flex items-center gap-4">
                    <div class="w-12 h-12 bg-rose-50 text-rose-600 rounded-xl flex items-center justify-center">
                        <span class="material-icons">history</span>
                    </div>
                    <div>
                        <p class="text-sm text-slate-500 font-medium">Log Hệ thống</p>
                        <h3 class="text-2xl font-bold">Logs</h3>
                    </div>
                </div>
                <div class="mt-4 text-xs">
                    <a href="/Admin/ActivityLogs" class="text-rose-600 hover:underline">Xem tất cả hoạt động</a>
                </div>
            </div>
        </div>

        <!-- Shortcut -->
        <div class="bg-white p-6 rounded-2xl border border-slate-200 shadow-sm">
            <h3 class="text-lg font-bold mb-4">Quản lý tiện ích</h3>
            <a href="/Admin/Amenities" class="btn btn-primary">Đi đến trang quản lý tiện ích</a>
        </div>
    </div>
}
else
{
    <div class="bg-white p-6 rounded-xl border">
        <div class="flex items-center justify-between mb-4">
            <h2 class="text-lg font-bold">Lịch tiện ích</h2>
            <a class="btn btn-primary" href="/Resident/Amenities/Book">Đặt tiện ích</a>
        </div>

        <div class="mb-4">
            <label class="text-sm">Chọn tiện ích</label>
            <select id="amenityFilter" class="form-select w-64">
                <option value="">Tất cả</option>
                @foreach (var a in Model.Amenities)
                {
                    <option value="@a.AmenityId">@a.AmenityName</option>
                }
            </select>
        </div>

        @if (TempData["Success"] != null)
        {
            <div class="mb-4 text-emerald-600">@TempData["Success"]</div>
        }

        <div id="calendar"></div>
    </div>

    @section Scripts {
        <link href="https://cdn.jsdelivr.net/npm/fullcalendar@6.1.8/main.min.css" rel="stylesheet" />
        <script src="https://cdn.jsdelivr.net/npm/fullcalendar@6.1.8/main.min.js"></script>

        <script>
            document.addEventListener('DOMContentLoaded', function () {

                function pad(n) { return n < 10 ? '0' + n : n; }
                function formatDateLocal(d) {
                    return d.getFullYear() + '-' + pad(d.getMonth() + 1) + '-' + pad(d.getDate());
                }
                function formatTimeLocal(d) {
                    return pad(d.getHours()) + ':' + pad(d.getMinutes());
                }

                var calendar = new FullCalendar.Calendar(document.getElementById('calendar'), {
                    initialView: 'dayGridMonth',
                    selectable: true,
                    headerToolbar: { left: 'prev,next today', center: 'title', right: 'dayGridMonth,timeGridWeek,timeGridDay' },

                    events: function (info, successCallback, failureCallback) {
                        var amenityId = document.getElementById('amenityFilter').value;

                        var params = new URLSearchParams();
                        params.set('handler', 'Events');
                        params.set('start', info.startStr);
                        params.set('end', info.endStr);
                        if (amenityId) params.set('amenityId', amenityId);

                        fetch('/Amenities?' + params.toString())
                            .then(r => r.json())
                            .then(data => successCallback(data))
                            .catch(err => failureCallback(err));
                    },

                    select: function (info) {
                        var params = new URLSearchParams();
                        params.set('date', formatDateLocal(info.start));
                        params.set('start', formatTimeLocal(info.start));
                        params.set('end', formatTimeLocal(info.end));

                        window.location.href = '/Resident/Amenities/Book?' + params.toString();
                    }
                });

                calendar.render();

                document.getElementById('amenityFilter')
                    .addEventListener('change', () => calendar.refetchEvents());
            });
        </script>
    }
}