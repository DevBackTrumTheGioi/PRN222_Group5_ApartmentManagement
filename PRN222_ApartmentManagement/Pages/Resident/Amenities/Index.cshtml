@page
@model PRN222_ApartmentManagement.Pages.Resident.Amenities.IndexModel
@{
    ViewData["Title"] = "Tiện ích cư dân";
    ViewData["Subtitle"] = "Xem tiện ích mở tự do và tra cứu slot còn trống để đặt";
    ViewData["CurrentPage"] = "amenities";
}

<div class="space-y-6">
    @if (TempData["SuccessMessage"] != null)
    {
        <div class="flex items-center gap-3 rounded-xl border border-emerald-200 bg-emerald-50 p-4 text-sm text-emerald-700">
            <span class="material-icons text-emerald-500">check_circle</span>
            @TempData["SuccessMessage"]
        </div>
    }
    @if (TempData["ErrorMessage"] != null)
    {
        <div class="flex items-center gap-3 rounded-xl border border-red-200 bg-red-50 p-4 text-sm text-red-700">
            <span class="material-icons text-red-500">error</span>
            @TempData["ErrorMessage"]
        </div>
    }

    @if (!Model.HasApartment)
    {
        <div class="rounded-xl border border-amber-200 bg-amber-50 p-4 text-sm text-amber-800">
            Bạn chưa được gán căn hộ nên chưa thể đặt tiện ích cần giữ chỗ. Vẫn có thể xem các tiện ích mở tự do bên dưới.
        </div>
    }

    <div class="rounded-xl border border-slate-200 bg-white p-4 shadow-sm">
        <form method="get" class="flex flex-wrap items-end gap-3">
            <div class="min-w-[220px] flex-1">
                <label class="mb-1 block text-xs font-medium text-slate-600">Tìm kiếm tiện ích</label>
                <div class="relative">
                    <span class="material-icons absolute left-3 top-1/2 -translate-y-1/2 text-base text-slate-400">search</span>
                    <input asp-for="SearchTerm"
                           class="w-full rounded-lg border border-slate-200 bg-white py-2 pl-9 pr-3 text-sm focus:outline-none focus:ring-2 focus:ring-emerald-500"
                           placeholder="Gym, BBQ, phòng họp..." />
                </div>
            </div>

            <div class="min-w-[190px]">
                <label class="mb-1 block text-xs font-medium text-slate-600">Ngày xem lịch</label>
                <input asp-for="BookingDate" type="date"
                       class="w-full rounded-lg border border-slate-200 bg-white px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-emerald-500" />
            </div>

            <div class="ml-auto flex gap-2">
                <button type="submit"
                        class="inline-flex items-center gap-1.5 rounded-lg bg-slate-700 px-4 py-2 text-sm font-medium text-white transition-colors hover:bg-slate-800">
                    <span class="material-icons text-base">filter_list</span>
                    Cập nhật
                </button>
                <a asp-page="MyBookings"
                   class="inline-flex items-center gap-1.5 rounded-lg bg-emerald-600 px-4 py-2 text-sm font-semibold text-white transition-colors hover:bg-emerald-700">
                    <span class="material-icons text-base">event_note</span>
                    Booking của tôi
                </a>
            </div>
        </form>
    </div>

    @if (!Model.Amenities.Any())
    {
        <div class="rounded-xl border border-slate-200 bg-white p-16 text-center shadow-sm">
            <span class="material-icons mb-3 text-5xl text-slate-300">pool</span>
            <p class="font-medium text-slate-500">Chưa có tiện ích nào phù hợp.</p>
        </div>
    }
    else
    {
        <div class="grid gap-6 lg:grid-cols-[1.1fr_0.9fr]">
            <div class="space-y-4">
                @foreach (var amenity in Model.Amenities)
                {
                    var isSelected = amenity.AmenityId == Model.SelectedAmenityId;
                    var badgeCss = amenity.RequiresBooking
                        ? "bg-blue-50 text-blue-700 border-blue-200"
                        : "bg-amber-50 text-amber-700 border-amber-200";

                    <a asp-page="Index"
                       asp-route-selectedAmenityId="@amenity.AmenityId"
                       asp-route-bookingDate="@Model.BookingDate?.ToString("yyyy-MM-dd")"
                       asp-route-searchTerm="@Model.SearchTerm"
                       class="block rounded-2xl border p-5 shadow-sm transition-all @(isSelected ? "border-emerald-300 bg-emerald-50/40" : "border-slate-200 bg-white hover:border-emerald-200 hover:shadow-md")">
                        <div class="flex items-start justify-between gap-4">
                            <div>
                                <div class="flex items-center gap-2">
                                    <h3 class="text-lg font-semibold text-slate-900">@amenity.AmenityName</h3>
                                    <span class="inline-flex items-center rounded-full border px-2 py-0.5 text-xs font-medium @badgeCss">
                                        @(amenity.RequiresBooking ? "Cần đặt trước" : "Mở tự do")
                                    </span>
                                </div>
                                <p class="mt-1 text-sm text-slate-500">@(!string.IsNullOrWhiteSpace(amenity.Description) ? amenity.Description : "Chưa có mô tả.")</p>
                            </div>
                            <span class="material-icons text-slate-300">chevron_right</span>
                        </div>

                        <div class="mt-4 grid grid-cols-2 gap-3 text-xs text-slate-500 sm:grid-cols-4">
                            <div class="rounded-xl bg-slate-50 p-3">
                                <p class="text-slate-400">Loại</p>
                                <p class="mt-1 font-medium text-slate-700">@(amenity.AmenityType?.TypeName ?? "Chưa phân loại")</p>
                            </div>
                            <div class="rounded-xl bg-slate-50 p-3">
                                <p class="text-slate-400">Giờ mở cửa</p>
                                <p class="mt-1 font-medium text-slate-700">@amenity.OpenTime.ToString(@"hh\:mm") - @amenity.CloseTime.ToString(@"hh\:mm")</p>
                            </div>
                            <div class="rounded-xl bg-slate-50 p-3">
                                <p class="text-slate-400">Sức chứa</p>
                                <p class="mt-1 font-medium text-slate-700">@(amenity.Capacity?.ToString() ?? "—") người</p>
                            </div>
                            <div class="rounded-xl bg-slate-50 p-3">
                                <p class="text-slate-400">Chi phí</p>
                                <p class="mt-1 font-medium text-slate-700">@(amenity.RequiresBooking ? string.Format("{0:N0} đ/giờ", amenity.PricePerHour ?? 0) : "Miễn phí")</p>
                            </div>
                        </div>
                    </a>
                }
            </div>

            <div class="rounded-2xl border border-slate-200 bg-white p-5 shadow-sm">
                @if (Model.SelectedAmenity == null)
                {
                    <div class="py-12 text-center text-slate-400">
                        Chọn một tiện ích để xem chi tiết.
                    </div>
                }
                else if (!Model.SelectedAmenity.RequiresBooking)
                {
                    <div class="space-y-4">
                        <div class="flex items-start justify-between gap-3">
                            <div>
                                <h3 class="text-lg font-semibold text-slate-900">@Model.SelectedAmenity.AmenityName</h3>
                                <p class="mt-1 text-sm text-slate-500">@(!string.IsNullOrWhiteSpace(Model.SelectedAmenity.Location) ? Model.SelectedAmenity.Location : "Chưa cập nhật vị trí")</p>
                            </div>
                            <span class="inline-flex items-center rounded-full border border-amber-200 bg-amber-50 px-2 py-0.5 text-xs font-medium text-amber-700">Mở tự do</span>
                        </div>

                        <div class="rounded-xl border border-emerald-200 bg-emerald-50 p-4 text-sm text-emerald-800">
                            Tiện ích này mở cửa cho mọi cư dân trong khung giờ <strong>@Model.SelectedAmenity.OpenTime.ToString(@"hh\:mm") - @Model.SelectedAmenity.CloseTime.ToString(@"hh\:mm")</strong>.
                            Bạn không cần đặt slot trước.
                        </div>

                        <div class="grid grid-cols-2 gap-3 text-sm text-slate-600">
                            <div class="rounded-xl bg-slate-50 p-4">
                                <p class="text-xs text-slate-400">Sức chứa tối đa</p>
                                <p class="mt-1 font-semibold text-slate-800">@(Model.SelectedAmenity.Capacity?.ToString() ?? "—") người</p>
                            </div>
                            <div class="rounded-xl bg-slate-50 p-4">
                                <p class="text-xs text-slate-400">Chi phí</p>
                                <p class="mt-1 font-semibold text-slate-800">Miễn phí</p>
                            </div>
                        </div>
                    </div>
                }
                else
                {
                    <div class="space-y-4">
                        <div class="flex items-start justify-between gap-3">
                            <div>
                                <h3 class="text-lg font-semibold text-slate-900">@Model.SelectedAmenity.AmenityName</h3>
                                <p class="mt-1 text-sm text-slate-500">@(!string.IsNullOrWhiteSpace(Model.SelectedAmenity.Location) ? Model.SelectedAmenity.Location : "Chưa cập nhật vị trí")</p>
                            </div>
                            <span class="inline-flex items-center rounded-full border border-blue-200 bg-blue-50 px-2 py-0.5 text-xs font-medium text-blue-700">Cần đặt trước</span>
                        </div>

                        <div class="grid grid-cols-2 gap-3 text-sm text-slate-600">
                            <div class="rounded-xl bg-slate-50 p-4">
                                <p class="text-xs text-slate-400">Giờ mở cửa</p>
                                <p class="mt-1 font-semibold text-slate-800">@Model.SelectedAmenity.OpenTime.ToString(@"hh\:mm") - @Model.SelectedAmenity.CloseTime.ToString(@"hh\:mm")</p>
                            </div>
                            <div class="rounded-xl bg-slate-50 p-4">
                                <p class="text-xs text-slate-400">Hạn hủy</p>
                                <p class="mt-1 font-semibold text-slate-800">@Model.SelectedAmenity.CancellationDeadlineHours giờ trước khi dùng</p>
                            </div>
                        </div>

                        <div>
                            <div class="mb-2 flex items-center justify-between">
                                <p class="text-sm font-semibold text-slate-800">Lịch slot ngày @Model.BookingDate?.ToString("dd/MM/yyyy")</p>
                                <a asp-page="Book"
                                   asp-route-id="@Model.SelectedAmenity.AmenityId"
                                   asp-route-date="@Model.BookingDate?.ToString("yyyy-MM-dd")"
                                   class="inline-flex items-center gap-1 rounded-lg bg-emerald-600 px-3 py-1.5 text-xs font-semibold text-white transition-colors hover:bg-emerald-700 @(Model.HasApartment ? string.Empty : "pointer-events-none opacity-50")">
                                    <span class="material-icons text-sm">add</span>
                                    Đặt slot
                                </a>
                            </div>

                            <div class="grid grid-cols-2 gap-2 sm:grid-cols-3">
                                @foreach (var slot in Model.Slots)
                                {
                                    var slotCss = slot.IsAvailable
                                        ? "border-emerald-200 bg-emerald-50 text-emerald-700"
                                        : "border-red-200 bg-red-50 text-red-700";

                                    <div class="rounded-xl border p-3 text-sm @slotCss">
                                        <p class="font-semibold">@slot.StartTime.ToString(@"hh\:mm") - @slot.EndTime.ToString(@"hh\:mm")</p>
                                        <p class="mt-1 text-xs">@slot.StatusLabel</p>
                                    </div>
                                }
                            </div>
                        </div>
                    </div>
                }
            </div>
        </div>
    }
</div>
