@page
@model PRN222_ApartmentManagement.Pages.Resident.Amenities.MyBookingsModel
@{
    ViewData["Title"] = "Booking của tôi";
}

<div class="max-w-4xl">
    <div class="bg-white p-6 rounded-xl border shadow-sm">
        <h2 class="text-lg font-bold mb-4">Booking của tôi</h2>

        @if (TempData["Error"] != null)
        {
            <div class="text-rose-600 mb-4">@TempData["Error"]</div>
        }
        @if (TempData["Success"] != null)
        {
            <div class="text-emerald-600 mb-4">@TempData["Success"]</div>
        }

        <div class="overflow-x-auto">
            <table class="w-full text-sm bg-white rounded border-collapse table-auto">
                <thead>
                    <tr class="text-left text-xs text-slate-500 uppercase">
                        <th class="px-4 py-3">Tiện ích</th>
                        <th class="px-4 py-3">Ngày</th>
                        <th class="px-4 py-3">Giờ</th>
                        <th class="px-4 py-3">Số giờ</th>
                        <th class="px-4 py-3">Tổng</th>
                        <th class="px-4 py-3">Trạng thái</th>
                        <th class="px-4 py-3">Hành động</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var b in Model.Bookings)
                    {
                        <tr class="border-t">
                            <td class="px-4 py-3">@b.Amenity.AmenityName</td>
                            <td class="px-4 py-3">@b.BookingDate:dd/MM/yyyy</td>
                            <td class="px-4 py-3">@b.StartTime:hh\:mm - @b.EndTime:hh\:mm</td>
                            <td class="px-4 py-3">@b.TotalHours</td>
                            <td class="px-4 py-3">@String.Format("{0:N0}", b.TotalAmount ?? 0)</td>
                            <td class="px-4 py-3">@b.Status</td>
                            <td class="px-4 py-3">
                                @if (b.Status != "Cancelled")
                                {
                                    <form method="post" asp-page-handler="Cancel" onsubmit="return confirm('Bạn muốn hủy booking này?');">
                                        <input type="hidden" name="id" value="@b.BookingId" />
                                        <button type="submit" class="text-rose-600 hover:underline">Hủy</button>
                                    </form>
                                }
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>

        <div class="mt-4 flex items-center justify-between">
            <div class="text-sm text-slate-500">Hiển thị <span class="font-medium">@((Model.PageIndex-1)*Model.PageSize+1)</span> - <span class="font-medium">@Math.Min(Model.PageIndex*Model.PageSize, Model.TotalCount)</span> trong tổng <span class="font-medium">@Model.TotalCount</span></div>

            <div class="flex items-center gap-2">
                <form method="get" class="inline-flex items-center gap-2">
                    <input type="hidden" name="PageIndex" value="@(Model.PageIndex-1)" />
                    <input type="hidden" name="PageSize" value="@Model.PageSize" />
                    <button class="px-3 py-1 bg-white border border-slate-200 rounded-lg" @(Model.PageIndex==1?"disabled":"")>Trước</button>
                </form>

                <div class="flex items-center gap-1">
                    @for (int i=1;i<=Math.Max(1, (int)Math.Ceiling(Model.TotalCount/(double)Model.PageSize)); i++)
                    {
                        <a href="?pageIndex=@i&pageSize=@Model.PageSize" class="w-8 h-8 rounded-lg text-sm font-medium flex items-center justify-center transition-colors @(i==Model.PageIndex?"bg-primary-600 text-white":"text-slate-600 hover:bg-slate-100")">@i</a>
                    }
                </div>

                <form method="get" class="inline-flex items-center gap-2">
                    <input type="hidden" name="PageIndex" value="@(Model.PageIndex+1)" />
                    <input type="hidden" name="PageSize" value="@Model.PageSize" />
                    <button class="px-3 py-1 bg-white border border-slate-200 rounded-lg" @(Model.PageIndex*Model.PageSize>=Model.TotalCount?"disabled":"")>Sau</button>
                </form>

                <form method="get" class="inline-flex items-center gap-2 ml-4">
                    <label class="text-xs text-slate-500">Số lượng</label>
                    <select name="PageSize" onchange="this.form.submit()" class="px-2 py-1 border rounded">
                        <option value="10" selected="@(Model.PageSize==10)">10</option>
                        <option value="20" selected="@(Model.PageSize==20)">20</option>
                        <option value="50" selected="@(Model.PageSize==50)">50</option>
                    </select>
                </form>
            </div>
        </div>

    </div>
</div>
