@page
@model PRN222_ApartmentManagement.Pages.Resident.Amenities.MyBookingsModel
@using PRN222_ApartmentManagement.Utils
@{
    ViewData["Title"] = "Booking của tôi";
    ViewData["Subtitle"] = "Theo dõi lịch đặt tiện ích và chủ động hủy trước hạn";
    ViewData["CurrentPage"] = "amenitybookings";
}

<div class="space-y-6">
    @if (TempData["SuccessMessage"] != null)
    {
        <div class="flex items-center gap-3 rounded-xl border border-emerald-200 bg-emerald-50 p-4 text-sm text-emerald-700">
            <span class="material-icons text-emerald-500">check_circle</span>
            @TempData["SuccessMessage"]
        </div>
    }
    @if (TempData["ErrorMessage"] != null)
    {
        <div class="flex items-center gap-3 rounded-xl border border-red-200 bg-red-50 p-4 text-sm text-red-700">
            <span class="material-icons text-red-500">error</span>
            @TempData["ErrorMessage"]
        </div>
    }

    <div class="grid grid-cols-2 gap-4 sm:grid-cols-4">
        <div class="rounded-xl border border-slate-200 bg-white p-4 text-center shadow-sm">
            <p class="text-2xl font-bold text-slate-800">@Model.TotalCount</p>
            <p class="mt-0.5 text-xs text-slate-500">Tổng booking</p>
        </div>
        <div class="rounded-xl border border-blue-200 bg-blue-50 p-4 text-center shadow-sm">
            <p class="text-2xl font-bold text-blue-700">@Model.ConfirmedCount</p>
            <p class="mt-0.5 text-xs text-blue-600">Đã xác nhận</p>
        </div>
        <div class="rounded-xl border border-emerald-200 bg-emerald-50 p-4 text-center shadow-sm">
            <p class="text-2xl font-bold text-emerald-700">@Model.CompletedCount</p>
            <p class="mt-0.5 text-xs text-emerald-600">Hoàn tất</p>
        </div>
        <div class="rounded-xl border border-red-200 bg-red-50 p-4 text-center shadow-sm">
            <p class="text-2xl font-bold text-red-700">@Model.CancelledCount</p>
            <p class="mt-0.5 text-xs text-red-600">Đã hủy</p>
        </div>
    </div>

    <div class="rounded-xl border border-emerald-200 bg-white p-5 shadow-sm">
        <div class="flex flex-col gap-2 sm:flex-row sm:items-center sm:justify-between">
            <div>
                <h3 class="text-base font-semibold text-slate-900">Booking còn hiệu lực</h3>
                <p class="mt-1 text-sm text-slate-500">Các booking hôm nay hoặc sắp tới mà bạn vẫn có thể sử dụng.</p>
            </div>
            <span class="inline-flex items-center rounded-full border border-emerald-200 bg-emerald-50 px-3 py-1 text-sm font-semibold text-emerald-700">
                @Model.ActiveWindowCount booking
            </span>
        </div>

        @if (!Model.ActiveBookings.Any())
        {
            <div class="mt-4 rounded-xl border border-dashed border-slate-200 bg-slate-50 p-4 text-sm text-slate-500">
                Hiện không có booking nào còn hiệu lực.
            </div>
        }
        else
        {
            <div class="mt-4 grid gap-3 lg:grid-cols-2">
                @foreach (var booking in Model.ActiveBookings.Take(4))
                {
                    <div class="rounded-xl border border-emerald-100 bg-emerald-50/40 p-4">
                        <div class="flex items-start justify-between gap-3">
                            <div>
                                <p class="font-semibold text-slate-900">@booking.Amenity.AmenityName</p>
                                <p class="mt-1 text-sm text-slate-500">Căn @booking.Apartment.ApartmentNumber</p>
                            </div>
                            <span class="inline-flex items-center rounded-full border border-emerald-200 bg-white px-2 py-0.5 text-[11px] font-medium text-emerald-700">
                                Còn hiệu lực
                            </span>
                        </div>
                        <div class="mt-3 flex flex-wrap gap-x-4 gap-y-1 text-sm text-slate-600">
                            <span class="flex items-center gap-1">
                                <span class="material-icons text-sm">calendar_today</span>
                                @booking.BookingDate.ToString("dd/MM/yyyy")
                            </span>
                            <span class="flex items-center gap-1">
                                <span class="material-icons text-sm">schedule</span>
                                @booking.StartTime.ToString(@"hh\:mm") - @booking.EndTime.ToString(@"hh\:mm")
                            </span>
                        </div>
                    </div>
                }
            </div>
        }
    </div>

    <div class="rounded-xl border border-slate-200 bg-white p-4 shadow-sm">
        <form method="get" class="flex flex-wrap items-end gap-3">
            <div class="min-w-[200px]">
                <label class="mb-1 block text-xs font-medium text-slate-600">Trạng thái</label>
                <select asp-for="StatusFilter"
                        class="w-full rounded-lg border border-slate-200 bg-white px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-emerald-500">
                    <option value="">Tất cả</option>
                    <option value="@AmenityBookingStatusHelper.Confirmed">Đã xác nhận</option>
                    <option value="@AmenityBookingStatusHelper.Completed">Hoàn tất</option>
                    <option value="@AmenityBookingStatusHelper.Cancelled">Đã hủy</option>
                </select>
            </div>

            <div class="ml-auto flex gap-2">
                <button type="submit"
                        class="inline-flex items-center gap-1.5 rounded-lg bg-slate-700 px-4 py-2 text-sm font-medium text-white transition-colors hover:bg-slate-800">
                    <span class="material-icons text-base">filter_list</span>
                    Lọc
                </button>
                <a asp-page="Index"
                   class="inline-flex items-center gap-1.5 rounded-lg bg-emerald-600 px-4 py-2 text-sm font-semibold text-white transition-colors hover:bg-emerald-700">
                    <span class="material-icons text-base">add</span>
                    Đặt tiện ích mới
                </a>
            </div>
        </form>
    </div>

    @if (!Model.Bookings.Any())
    {
        <div class="rounded-xl border border-slate-200 bg-white p-16 text-center shadow-sm">
            <span class="material-icons mb-3 text-5xl text-slate-300">event_busy</span>
            <p class="font-medium text-slate-500">Không có booking nào phù hợp.</p>
        </div>
    }
    else
    {
        <div class="space-y-3">
            @foreach (var booking in Model.Bookings)
            {
                var badgeCss = AmenityBookingStatusHelper.GetBadgeCss(booking.Status);
                var badgeIcon = AmenityBookingStatusHelper.GetIcon(booking.Status);
                var canCancel = booking.Status == AmenityBookingStatusHelper.Confirmed;

                <div class="rounded-xl border border-slate-200 bg-white p-5 shadow-sm transition-all hover:border-emerald-200 hover:shadow-md">
                    <div class="flex flex-col gap-4 md:flex-row md:items-start md:justify-between">
                        <div class="space-y-2">
                            <div class="flex flex-wrap items-center gap-2">
                                <h3 class="text-lg font-semibold text-slate-900">@booking.Amenity.AmenityName</h3>
                                <span class="inline-flex items-center gap-1 rounded-full border px-2 py-0.5 text-xs font-medium @badgeCss">
                                    <span class="material-icons text-[11px]">@badgeIcon</span>
                                    @AmenityBookingStatusHelper.GetDisplayName(booking.Status)
                                </span>
                            </div>

                            <div class="flex flex-wrap gap-x-4 gap-y-1 text-sm text-slate-500">
                                <span class="flex items-center gap-1">
                                    <span class="material-icons text-sm">calendar_today</span>
                                    @booking.BookingDate.ToString("dd/MM/yyyy")
                                </span>
                                <span class="flex items-center gap-1">
                                    <span class="material-icons text-sm">schedule</span>
                                    @booking.StartTime.ToString(@"hh\:mm") - @booking.EndTime.ToString(@"hh\:mm")
                                </span>
                                <span class="flex items-center gap-1">
                                    <span class="material-icons text-sm">group</span>
                                    @booking.ParticipantCount người
                                </span>
                                <span class="flex items-center gap-1">
                                    <span class="material-icons text-sm">payments</span>
                                    @string.Format("{0:N0} đ", booking.TotalAmount ?? 0)
                                </span>
                            </div>

                            @if (!string.IsNullOrWhiteSpace(booking.Notes))
                            {
                                <p class="text-sm text-slate-600">@booking.Notes</p>
                            }
                        </div>

                        <div class="flex flex-col items-start gap-2 md:items-end">
                            <p class="text-xs text-slate-400">Tạo lúc @booking.CreatedAt.ToString("dd/MM/yyyy HH:mm")</p>
                            @if (canCancel)
                            {
                                <form method="post" asp-page-handler="Cancel" onsubmit="return confirm('Bạn có chắc muốn hủy booking này?');">
                                    <input type="hidden" name="bookingId" value="@booking.BookingId" />
                                    <button type="submit"
                                            class="inline-flex items-center gap-1 rounded-lg border border-red-200 px-3 py-1.5 text-xs font-medium text-red-600 transition-colors hover:bg-red-50">
                                        <span class="material-icons text-sm">cancel</span>
                                        Hủy booking
                                    </button>
                                </form>
                            }
                        </div>
                    </div>
                </div>
            }
        </div>
    }
</div>
