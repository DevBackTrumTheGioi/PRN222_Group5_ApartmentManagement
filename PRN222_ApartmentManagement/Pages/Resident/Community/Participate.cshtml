@page "{id:int}"
@model PRN222_ApartmentManagement.Pages.Resident.Community.ParticipateModel
@using PRN222_ApartmentManagement.Models.Enums
@using PRN222_ApartmentManagement.Utils
@{
    ViewData["Title"] = "Tham gia chiến dịch";
    ViewData["Subtitle"] = "Gửi phản hồi cho khảo sát hoặc bỏ phiếu đang mở";
    ViewData["CurrentPage"] = "community";
}

<div class="space-y-6">
    <div class="rounded-2xl border border-slate-200 bg-white p-6 shadow-sm">
        <div class="flex items-center gap-2">
            <h2 class="text-2xl font-bold text-slate-900">@Model.Campaign.Title</h2>
            <span class="rounded-full border border-slate-200 bg-slate-50 px-2 py-0.5 text-xs font-medium text-slate-600">@Model.Campaign.CampaignType.GetDisplayName()</span>
        </div>
        <p class="mt-2 text-sm text-slate-600">@Model.Campaign.QuestionText</p>
        @if (!string.IsNullOrWhiteSpace(Model.Campaign.Description))
        {
            <p class="mt-2 text-sm text-slate-500">@Model.Campaign.Description</p>
        }
        <p class="mt-4 text-xs text-slate-400">Hiệu lực từ @Model.Campaign.StartsAt.ToString("dd/MM/yyyy HH:mm") đến @Model.Campaign.EndsAt.ToString("dd/MM/yyyy HH:mm")</p>
    </div>

    @if (!Model.Campaign.CanParticipate && !Model.Campaign.HasResponded)
    {
        <div class="rounded-xl border border-amber-200 bg-amber-50 px-4 py-3 text-sm text-amber-700">
            Chiến dịch này hiện không còn nhận phản hồi.
        </div>
    }

    @if (!ModelState.IsValid)
    {
        <div class="rounded-xl border border-red-200 bg-red-50 px-4 py-3 text-sm text-red-700">
            <div asp-validation-summary="All"></div>
        </div>
    }

    <div class="rounded-2xl border border-slate-200 bg-white p-6 shadow-sm">
        @if (Model.Campaign.HasResponded)
        {
            <h3 class="text-lg font-bold text-slate-900">Phản hồi của bạn</h3>
            <ul class="mt-4 space-y-2 text-sm text-slate-600">
                @foreach (var option in Model.Campaign.Options.Where(o => Model.Campaign.SelectedOptionIds.Contains(o.OptionId)))
                {
                    <li class="rounded-lg border border-emerald-200 bg-emerald-50 px-3 py-2">@option.OptionText</li>
                }
            </ul>
            <div class="mt-4 rounded-lg border border-slate-200 bg-slate-50 px-4 py-3 text-sm text-slate-600">
                <span class="font-medium text-slate-700">Ghi chú:</span> @(!string.IsNullOrWhiteSpace(Model.Campaign.ExistingComment) ? Model.Campaign.ExistingComment : "Không có")
            </div>
        }
        else
        {
            <form method="post" class="space-y-5">
                <div class="space-y-3">
                    <label class="block text-sm font-medium text-slate-700">Chọn đáp án</label>
                    @foreach (var option in Model.Campaign.Options)
                    {
                        <label class="flex items-start gap-3 rounded-xl border border-slate-200 px-4 py-3 hover:border-emerald-200 hover:bg-emerald-50/40">
                            @if (Model.Campaign.AllowMultipleChoices)
                            {
                                <input type="checkbox" name="Input.SelectedOptionIds" value="@option.OptionId" class="mt-1 h-4 w-4 rounded border-slate-300 text-emerald-600 focus:ring-emerald-500" />
                            }
                            else
                            {
                                <input type="radio" name="Input.SelectedOptionIds" value="@option.OptionId" class="mt-1 h-4 w-4 border-slate-300 text-emerald-600 focus:ring-emerald-500" />
                            }
                            <span class="text-sm text-slate-700">@option.OptionText</span>
                        </label>
                    }
                </div>

                <div>
                    <label asp-for="Input.Comment" class="mb-1 block text-sm font-medium text-slate-700"></label>
                    <textarea asp-for="Input.Comment" rows="4" class="w-full rounded-lg border border-slate-200 px-3 py-2 focus:outline-none focus:ring-2 focus:ring-emerald-500" placeholder="Bạn có thể ghi chú thêm ý kiến tại đây"></textarea>
                </div>

                <div class="flex justify-end gap-3">
                    <a asp-page="Index" class="rounded-lg border border-slate-200 px-4 py-2.5 text-sm font-medium text-slate-600 hover:bg-slate-50">Quay lại</a>
                    <button type="submit" class="rounded-lg bg-emerald-600 px-4 py-2.5 text-sm font-semibold text-white hover:bg-emerald-700" @(Model.Campaign.CanParticipate ? null : "disabled")>
                        Gửi phản hồi
                    </button>
                </div>
            </form>
        }
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
