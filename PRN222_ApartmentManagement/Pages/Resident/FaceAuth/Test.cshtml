@page
@model PRN222_ApartmentManagement.Pages.Resident.FaceAuth.TestModel
@{
    ViewData["Title"] = "Test Face ID";
    Layout = "_Layout";
}

<div class="mx-auto max-w-2xl p-6">
    <div class="rounded-2xl border border-amber-200 bg-amber-50 p-6 text-center shadow-sm">
        <div class="mx-auto flex h-14 w-14 items-center justify-center rounded-full bg-amber-100 text-amber-600">
            <span class="material-icons text-3xl">warning</span>
        </div>
        <h1 class="mt-4 text-2xl font-bold text-slate-900">Trang test da duoc vo hieu hoa</h1>
        <p class="mt-2 text-sm text-slate-600">
            Tinh nang test Face ID cu da duoc khoa de tranh lo du lieu sinh trac hoc.
            Vui long su dung cac trang quan ly Face ID moi danh cho staff va manager.
        </p>
        <div class="mt-6 flex flex-wrap justify-center gap-3">
            <a href="/BQL_Staff/FaceAuth" class="inline-flex items-center gap-2 rounded-lg bg-emerald-600 px-4 py-2 text-sm font-medium text-white hover:bg-emerald-700">
                <span class="material-icons text-base">face</span>
                Quan ly Face ID
            </a>
            <a href="/FaceAuth/Logs" class="inline-flex items-center gap-2 rounded-lg border border-slate-200 px-4 py-2 text-sm font-medium text-slate-600 hover:bg-slate-50">
                <span class="material-icons text-base">history</span>
                Lich su xac thuc
            </a>
        </div>
    </div>
</div>