@page
@model PRN222_ApartmentManagement.Pages.Resident.FamilyMembers.DetailsModel
@using PRN222_ApartmentManagement.Models.Enums;
@{
    ViewData["Title"] = "Chi tiết căn hộ";
    ViewData["CurrentPage"] = "family-members";
}

<div class="max-w-5xl mx-auto space-y-6">

    @* Back link *@
    <div>
        <a href="/Resident/FamilyMembers/Index" class="inline-flex items-center gap-1.5 text-sm text-slate-500 hover:text-emerald-600 transition-colors">
            <span class="material-icons text-base">arrow_back</span>
            Quay về danh sách căn hộ
        </a>
    </div>

    @if (TempData["SuccessMessage"] != null)
    {
        <div class="flex items-center gap-3 p-4 bg-emerald-50 border border-emerald-200 rounded-xl text-emerald-700 text-sm">
            <span class="material-icons text-emerald-500">check_circle</span>
            @TempData["SuccessMessage"]
        </div>
    }

    @if (TempData["ErrorMessage"] != null)
    {
        <div class="flex items-center gap-3 p-4 bg-red-50 border border-red-200 rounded-xl text-red-700 text-sm">
            <span class="material-icons text-red-500">error</span>
            @TempData["ErrorMessage"]
        </div>
    }

    @if (Model.Apartment != null)
    {
        @* ── Apartment info card ─────────────────────────── *@
        <div class="bg-white rounded-xl shadow-sm border border-slate-200 overflow-hidden">
            <div class="px-6 py-4 border-b border-slate-100 flex items-center justify-between">
                <div class="flex items-center gap-3">
                    <div class="flex items-center justify-center w-11 h-11 rounded-xl bg-gradient-to-br from-emerald-400 to-emerald-600 text-white shadow-sm">
                        <span class="material-icons text-xl">home</span>
                    </div>
                    <div>
                        <h2 class="text-base font-bold text-slate-800">Căn @Model.Apartment.ApartmentNumber</h2>
                        <p class="text-xs text-slate-400 mt-0.5">
                            Tầng @Model.Apartment.Floor
                            @(string.IsNullOrWhiteSpace(Model.Apartment.BuildingBlock) ? "" : $" · Block {Model.Apartment.BuildingBlock}")
                        </p>
                    </div>
                </div>
                <div class="flex items-center gap-2">
                    @if (Model.Apartment.Status == ApartmentStatus.Occupied)
                    {
                        <span class="inline-flex items-center gap-1 px-2.5 py-1 rounded-full text-xs font-medium bg-emerald-50 text-emerald-600 border border-emerald-100">
                            <span class="w-1.5 h-1.5 rounded-full bg-emerald-400"></span> Đang sử dụng
                        </span>
                    }
                    else
                    {
                        <span class="inline-flex items-center gap-1 px-2.5 py-1 rounded-full text-xs font-medium bg-slate-50 text-slate-500 border border-slate-200">
                            @Model.Apartment.Status
                        </span>
                    }
                </div>
            </div>

            <div class="px-6 py-5 grid grid-cols-2 md:grid-cols-4 gap-5 text-sm">
                <div>
                    <span class="text-slate-400 text-xs">Loại cư trú</span>
                    <p class="font-semibold text-slate-800 mt-0.5">
                        @(Model.Apartment.ResidencyType switch
                        {
                            ResidencyType.Owner => "Chủ sở hữu",
                            ResidencyType.Tenant => "Người thuê",
                            _ => Model.Apartment.ResidencyType.ToString()
                        })
                    </p>
                </div>
                <div>
                    <span class="text-slate-400 text-xs">Loại hợp đồng</span>
                    <p class="font-semibold text-slate-800 mt-0.5">
                        @(Model.Apartment.ContractType switch
                        {
                            ContractType.Rental => "Thuê",
                            ContractType.Purchase => "Mua",
                            _ => "—"
                        })
                    </p>
                </div>
                <div>
                    <span class="text-slate-400 text-xs">Diện tích</span>
                    <p class="font-semibold text-slate-800 mt-0.5">@(Model.Apartment.Area.HasValue ? $"{Model.Apartment.Area.Value:F1} m²" : "—")</p>
                </div>
                <div>
                    <span class="text-slate-400 text-xs">Loại căn hộ</span>
                    <p class="font-semibold text-slate-800 mt-0.5">@(string.IsNullOrWhiteSpace(Model.Apartment.ApartmentType) ? "—" : Model.Apartment.ApartmentType)</p>
                </div>

                @if (!string.IsNullOrWhiteSpace(Model.Apartment.ContractNumber))
                {
                    <div>
                        <span class="text-slate-400 text-xs">Số hợp đồng</span>
                        <p class="font-semibold text-slate-800 mt-0.5">@Model.Apartment.ContractNumber</p>
                    </div>
                }

                <div>
                    <span class="text-slate-400 text-xs">Ngày bắt đầu</span>
                    <p class="font-semibold text-slate-800 mt-0.5">@(Model.Apartment.ContractStartDate?.ToString("dd/MM/yyyy") ?? "—")</p>
                </div>

                @if (Model.Apartment.ContractType == ContractType.Rental)
                {
                    <div>
                        <span class="text-slate-400 text-xs">Ngày kết thúc</span>
                        <p class="font-semibold text-slate-800 mt-0.5">@(Model.Apartment.ContractEndDate?.ToString("dd/MM/yyyy") ?? "—")</p>
                    </div>
                    <div>
                        <span class="text-slate-400 text-xs">Giá thuê/tháng</span>
                        <p class="font-semibold text-slate-800 mt-0.5">@(Model.Apartment.MonthlyRent.HasValue ? $"{Model.Apartment.MonthlyRent.Value:N0} VNĐ" : "—")</p>
                    </div>
                }
                else if (Model.Apartment.ContractType == ContractType.Purchase)
                {
                    <div>
                        <span class="text-slate-400 text-xs">Giá mua</span>
                        <p class="font-semibold text-slate-800 mt-0.5">@(Model.Apartment.PurchasePrice.HasValue ? $"{Model.Apartment.PurchasePrice.Value:N0} VNĐ" : "—")</p>
                    </div>
                }
            </div>
        </div>

        @* ── Residents list ─────────────────────────── *@
        <div class="bg-white rounded-xl shadow-sm border border-slate-200 overflow-hidden">
            <div class="px-6 py-4 border-b border-slate-100 flex items-center justify-between">
                <div>
                    <h2 class="text-base font-semibold text-slate-800">Danh sách cư dân</h2>
                    <p class="text-xs text-slate-400 mt-0.5">@Model.Residents.Count thành viên</p>
                </div>
                @if (Model.CurrentUserResidencyType != ResidencyType.FamilyMember)
                {
                    <a href="/Resident/FamilyMembers/AddFamilyMember?apartmentId=@Model.Apartment.ApartmentId"
                   class="inline-flex items-center gap-2 px-4 py-2 bg-emerald-600 hover:bg-emerald-700 text-white rounded-lg transition-colors text-sm font-semibold shadow-sm">
                    <span class="material-icons text-base">person_add</span>
                    Gắn thành viên
                </a>
                }
            </div>

            @if (Model.Residents.Count == 0)
            {
                <div class="p-12 text-center">
                    <span class="material-icons text-5xl text-slate-200">group_off</span>
                    <p class="mt-3 text-sm font-medium text-slate-500">Chưa có cư dân nào</p>
                    <p class="mt-1 text-xs text-slate-400">Bấm "Gắn thành viên" để thêm người thân vào căn hộ này</p>
                </div>
            }
            else
            {
                <div class="overflow-x-auto">
                    <table class="w-full text-sm">
                        <thead class="bg-slate-50 text-slate-500 text-xs uppercase tracking-wider">
                            <tr>
                                <th class="px-5 py-3 text-left font-semibold">Tài khoản</th>
                                <th class="px-5 py-3 text-left font-semibold">Họ tên</th>
                                <th class="px-5 py-3 text-left font-semibold">Loại</th>
                                <th class="px-5 py-3 text-left font-semibold">CCCD</th>
                                <th class="px-5 py-3 text-left font-semibold">Email</th>
                                <th class="px-5 py-3 text-left font-semibold">SĐT</th>
                                <th class="px-5 py-3 text-left font-semibold">Ngày sinh</th>
                                <th class="px-5 py-3 text-left font-semibold">Trạng thái</th>
                                <th class="px-5 py-3 text-left font-semibold">Ngày tạo</th>
                            </tr>
                        </thead>
                        <tbody class="divide-y divide-slate-100">
                            @foreach (var member in Model.Residents)
                            {
                                var typeBadgeClass = member.ResidencyType switch
                                {
                                    ResidencyType.Owner => "bg-violet-50 text-violet-700 ring-1 ring-violet-200",
                                    ResidencyType.Tenant => "bg-blue-50 text-blue-700 ring-1 ring-blue-200",
                                    ResidencyType.FamilyMember => "bg-emerald-50 text-emerald-700 ring-1 ring-emerald-200",
                                    _ => "bg-slate-100 text-slate-600 ring-1 ring-slate-200"
                                };
                                <tr class="hover:bg-slate-50 transition-colors">
                                    <td class="px-5 py-3.5">
                                        <span class="font-mono text-slate-700 font-medium">@member.Username</span>
                                    </td>
                                    <td class="px-5 py-3.5 text-slate-700">@member.FullName</td>
                                    <td class="px-5 py-3.5">
                                        <span class="inline-flex items-center px-2 py-0.5 rounded-full text-xs font-medium @typeBadgeClass">
                                            @member.ResidencyTypeName
                                        </span>
                                    </td>
                                    <td class="px-5 py-3.5 text-slate-500">@(string.IsNullOrWhiteSpace(member.IdentityCardNumber) ? "—" : member.IdentityCardNumber)</td>
                                    <td class="px-5 py-3.5 text-slate-500">
                                        @(string.IsNullOrWhiteSpace(member.Email) ? "—" : member.Email)
                                    </td>
                                    <td class="px-5 py-3.5 text-slate-500">@(string.IsNullOrWhiteSpace(member.PhoneNumber) ? "—" : member.PhoneNumber)</td>
                                    <td class="px-5 py-3.5 text-slate-500">
                                        @(member.DateOfBirth?.ToString("dd/MM/yyyy") ?? "—")
                                    </td>
                                    <td class="px-5 py-3.5">
                                        @if (member.IsActive)
                                        {
                                            <span class="inline-flex items-center gap-1 px-2 py-0.5 rounded-full text-xs font-medium bg-emerald-50 text-emerald-600">
                                                <span class="w-1.5 h-1.5 rounded-full bg-emerald-400"></span>
                                                Đã kích hoạt
                                            </span>
                                        }
                                        else
                                        {
                                            <span class="inline-flex items-center gap-1 px-2 py-0.5 rounded-full text-xs font-medium bg-amber-50 text-amber-600">
                                                <span class="w-1.5 h-1.5 rounded-full bg-amber-400"></span>
                                                Chưa kích hoạt
                                            </span>
                                        }
                                    </td>
                                    <td class="px-5 py-3.5 text-slate-400 text-xs">
                                        @member.CreatedAt.ToString("dd/MM/yyyy")
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
        </div>
    }

</div>
