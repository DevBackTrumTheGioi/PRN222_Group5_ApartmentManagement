@page "{id:int}"
@model PRN222_ApartmentManagement.Pages.Resident.Meetings.DetailsModel
@using PRN222_ApartmentManagement.Utils
@{
    ViewData["Title"] = "Chi tiết lịch họp";
    ViewData["Subtitle"] = "Xem thông tin cuộc họp";
    ViewData["CurrentPage"] = "meetings";
}

<div class="max-w-5xl space-y-6">
    <div class="flex items-start justify-between gap-4 flex-wrap">
        <div>
            <h1 class="text-2xl font-bold tracking-tight text-slate-900">@Model.Meeting.Title</h1>
            <p class="text-sm text-slate-500">@Model.Meeting.MeetingType.GetDisplayName() · @Model.Meeting.Status.GetDisplayName()</p>
        </div>
        <a asp-page="Index" class="px-4 py-2 rounded-lg border border-slate-200 text-slate-600 hover:bg-slate-50 text-sm font-medium">Quay lại</a>
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-3 gap-6">
        <div class="lg:col-span-2 bg-white border border-slate-200 rounded-xl shadow-sm p-6 space-y-4">
            <div>
                <p class="text-xs uppercase text-slate-400 font-semibold">Mô tả</p>
                <p class="mt-2 text-sm text-slate-700 whitespace-pre-line">@(string.IsNullOrWhiteSpace(Model.Meeting.Description) ? "Không có mô tả" : Model.Meeting.Description)</p>
            </div>

            <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                <div class="rounded-xl bg-slate-50 border border-slate-100 p-4">
                    <p class="text-xs text-slate-400 uppercase font-semibold">Thời gian</p>
                    <p class="mt-1 font-semibold text-slate-900">@Model.Meeting.ScheduledDate.ToString("dd/MM/yyyy")</p>
                    <p class="text-sm text-slate-500">@MeetingUtils.GetMeetingTime(Model.Meeting)</p>
                </div>
                <div class="rounded-xl bg-slate-50 border border-slate-100 p-4">
                    <p class="text-xs text-slate-400 uppercase font-semibold">Địa điểm</p>
                    <p class="mt-1 font-semibold text-slate-900">@(string.IsNullOrWhiteSpace(Model.Meeting.Location) ? "—" : Model.Meeting.Location)</p>
                </div>
            </div>
        </div>

        <div class="bg-white border border-slate-200 rounded-xl shadow-sm p-6 space-y-4">
            <div>
                <p class="text-xs uppercase text-slate-400 font-semibold">Biên bản họp</p>
                <div class="mt-3 text-sm text-slate-700 whitespace-pre-wrap">
                    @(string.IsNullOrWhiteSpace(Model.Meeting.MinutesContent) ? "Chưa có biên bản công khai." : Model.Meeting.MinutesContent)
                </div>
                @if (!string.IsNullOrWhiteSpace(Model.Meeting.MinutesFilePath))
                {
                    <a href="@Model.Meeting.MinutesFilePath" target="_blank" class="mt-3 inline-flex items-center gap-2 text-sm text-emerald-700 hover:text-emerald-800">
                        <span class="material-icons text-base">attachment</span>
                        @(string.IsNullOrWhiteSpace(Model.Meeting.MinutesFileName) ? "Tải biên bản" : Model.Meeting.MinutesFileName)
                    </a>
                }
            </div>
        </div>
    </div>
</div>
