@page
@model PRN222_ApartmentManagement.Pages.Resident.Requests.MyRequestsModel
@using PRN222_ApartmentManagement.Models.Enums
@using PRN222_ApartmentManagement.Utils
@{
    ViewData["Title"] = "Yêu cầu của tôi";
    ViewData["Subtitle"] = "Theo dõi trạng thái các yêu cầu bạn đã gửi";
    ViewData["CurrentPage"] = "requests";
}

<div class="space-y-6">

    <!-- Success / Error TempData -->
    @if (TempData["SuccessMessage"] != null)
    {
        <div class="flex items-center gap-3 p-4 bg-emerald-50 border border-emerald-200 rounded-xl text-emerald-700 text-sm">
            <span class="material-icons text-emerald-500">check_circle</span>
            @TempData["SuccessMessage"]
        </div>
    }
    @if (TempData["ErrorMessage"] != null)
    {
        <div class="flex items-center gap-3 p-4 bg-red-50 border border-red-200 rounded-xl text-red-700 text-sm">
            <span class="material-icons text-red-500">error</span>
            @TempData["ErrorMessage"]
        </div>
    }

    <!-- Stats row -->
    <div class="grid grid-cols-2 sm:grid-cols-5 gap-4">
        <div class="bg-white rounded-xl border border-slate-200 p-4 text-center shadow-sm">
            <p class="text-2xl font-bold text-slate-800">@Model.TotalCount</p>
            <p class="text-xs text-slate-500 mt-0.5">Tổng yêu cầu</p>
        </div>
        <div class="bg-amber-50 rounded-xl border border-amber-200 p-4 text-center shadow-sm">
            <p class="text-2xl font-bold text-amber-600">@Model.PendingCount</p>
            <p class="text-xs text-amber-500 mt-0.5">Chờ xử lý</p>
        </div>
        <div class="bg-blue-50 rounded-xl border border-blue-200 p-4 text-center shadow-sm">
            <p class="text-2xl font-bold text-blue-600">@Model.InProgressCount</p>
            <p class="text-xs text-blue-500 mt-0.5">Đang xử lý</p>
        </div>
        <div class="bg-emerald-50 rounded-xl border border-emerald-200 p-4 text-center shadow-sm">
            <p class="text-2xl font-bold text-emerald-600">@Model.CompletedCount</p>
            <p class="text-xs text-emerald-500 mt-0.5">Hoàn thành</p>
        </div>
        <div class="bg-slate-50 rounded-xl border border-slate-200 p-4 text-center shadow-sm">
            <p class="text-2xl font-bold text-slate-500">@Model.ClosedCount</p>
            <p class="text-xs text-slate-400 mt-0.5">Đã đóng</p>
        </div>
    </div>

    <!-- Filter bar + New button -->
    <div class="bg-white rounded-xl border border-slate-200 shadow-sm p-4">
        <form method="get" class="flex flex-wrap items-end gap-3">
            <!-- Status filter -->
            <div class="flex flex-col gap-1 min-w-[160px]">
                <label class="text-xs font-medium text-slate-600">Trạng thái</label>
                <select name="StatusFilter"
                        class="px-3 py-2 border border-slate-200 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-emerald-500 bg-white">
                    <option value="">Tất cả trạng thái</option>
                    @foreach (var status in Enum.GetValues<RequestStatus>())
                    {
                        <option value="@status" selected="@(Model.StatusFilter == status)">@status.GetDisplayName()</option>
                    }
                </select>
            </div>

            <!-- Type filter -->
            <div class="flex flex-col gap-1 min-w-[160px]">
                <label class="text-xs font-medium text-slate-600">Loại yêu cầu</label>
                <select name="TypeFilter"
                        class="px-3 py-2 border border-slate-200 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-emerald-500 bg-white">
                    <option value="">Tất cả loại</option>
                    @foreach (var type in Enum.GetValues<RequestType>())
                    {
                        <option value="@type" selected="@(Model.TypeFilter == type)">@type.GetDisplayName()</option>
                    }
                </select>
            </div>

            <div class="flex gap-2 ml-auto">
                @if (Model.StatusFilter.HasValue || Model.TypeFilter.HasValue)
                {
                    <a asp-page="MyRequests"
                       class="inline-flex items-center gap-1.5 px-4 py-2 border border-slate-200 text-slate-600 hover:bg-slate-50 rounded-lg text-sm transition-colors">
                        <span class="material-icons text-base">close</span>
                        Xóa lọc
                    </a>
                }
                <button type="submit"
                        class="inline-flex items-center gap-1.5 px-4 py-2 bg-slate-700 hover:bg-slate-800 text-white rounded-lg text-sm font-medium transition-colors">
                    <span class="material-icons text-base">filter_list</span>
                    Lọc
                </button>
                <a asp-page="Create"
                   class="inline-flex items-center gap-1.5 px-4 py-2 bg-emerald-600 hover:bg-emerald-700 text-white rounded-lg text-sm font-semibold shadow-sm transition-colors">
                    <span class="material-icons text-base">add</span>
                    Gửi yêu cầu mới
                </a>
            </div>
        </form>
    </div>

    <!-- Requests list -->
    @if (!Model.Requests.Any())
    {
        <div class="bg-white rounded-xl border border-slate-200 shadow-sm p-16 text-center">
            <span class="material-icons text-5xl text-slate-300 mb-3">inbox</span>
            <p class="text-slate-500 font-medium">Không có yêu cầu nào</p>
            <p class="text-sm text-slate-400 mt-1">
                @if (Model.StatusFilter.HasValue || Model.TypeFilter.HasValue)
                {
                    <span>Không có yêu cầu phù hợp với bộ lọc đã chọn.</span>
                }
                else
                {
                    <span>Bạn chưa gửi yêu cầu nào. Nhấn "Gửi yêu cầu mới" để bắt đầu.</span>
                }
            </p>
            @if (!Model.StatusFilter.HasValue && !Model.TypeFilter.HasValue)
            {
                <a asp-page="Create"
                   class="mt-4 inline-flex items-center gap-2 px-5 py-2 bg-emerald-600 hover:bg-emerald-700 text-white rounded-lg text-sm font-semibold transition-colors">
                    <span class="material-icons text-base">add</span>
                    Gửi yêu cầu mới
                </a>
            }
        </div>
    }
    else
    {
        <div class="space-y-3">
            @foreach (var req in Model.Requests)
            {
                <div class="bg-white rounded-xl border border-slate-200 shadow-sm hover:shadow-md hover:border-emerald-200 transition-all p-5">
                    <div class="flex flex-col sm:flex-row sm:items-start gap-4">

                        <!-- Left: icon -->
                        <div class="shrink-0 w-10 h-10 rounded-full bg-emerald-50 border border-emerald-100 flex items-center justify-center">
                            <span class="material-icons text-emerald-600 text-lg">
                                @(req.RequestType switch {
                                    RequestType.Repair => "build",
                                    RequestType.Complaint => "report_problem",
                                    RequestType.Feedback => "rate_review",
                                    RequestType.Service => "room_service",
                                    RequestType.Security => "security",
                                    _ => "help_outline"
                                })
                            </span>
                        </div>

                        <!-- Center: content -->
                        <div class="flex-1 min-w-0">
                            <div class="flex flex-wrap items-center gap-2 mb-1">
                                <span class="text-xs font-mono text-slate-400">@req.RequestNumber</span>
                                @{
                                    var (statusBg, statusText, statusIcon) = req.Status switch {
                                        RequestStatus.Pending    => ("bg-amber-50 text-amber-700 border-amber-200",   "Chờ xử lý",    "schedule"),
                                        RequestStatus.InProgress => ("bg-blue-50 text-blue-700 border-blue-200",      "Đang xử lý",   "sync"),
                                        RequestStatus.Completed  => ("bg-emerald-50 text-emerald-700 border-emerald-200", "Hoàn thành","check_circle"),
                                        RequestStatus.Cancelled  => ("bg-slate-50 text-slate-500 border-slate-200",   "Đã hủy",       "cancel"),
                                        RequestStatus.Rejected   => ("bg-red-50 text-red-600 border-red-200",         "Đã từ chối",   "block"),
                                        _ => ("bg-slate-50 text-slate-500 border-slate-200", req.Status.ToString(),   "help")
                                    };
                                }
                                <span class="inline-flex items-center gap-1 px-2 py-0.5 rounded-full text-xs font-medium border @statusBg">
                                    <span class="material-icons text-[11px]">@statusIcon</span>
                                    @statusText
                                </span>
                                @if (req.RequestType.HasValue)
                                {
                                    <span class="inline-flex items-center px-2 py-0.5 rounded-full text-xs font-medium bg-slate-100 text-slate-600 border border-slate-200">
                                        @req.RequestType.Value.GetDisplayName()
                                    </span>
                                }
                            </div>

                            <p class="font-semibold text-slate-800 truncate">@req.Title</p>

                            @if (!string.IsNullOrWhiteSpace(req.Description))
                            {
                                <p class="text-sm text-slate-500 mt-0.5 line-clamp-1">@req.Description</p>
                            }

                            <div class="flex flex-wrap items-center gap-x-4 gap-y-1 mt-2 text-xs text-slate-400">
                                <span class="flex items-center gap-1">
                                    <span class="material-icons text-xs">home</span>
                                    Căn hộ @req.Apartment?.ApartmentNumber
                                </span>
                                <span class="flex items-center gap-1">
                                    <span class="material-icons text-xs">calendar_today</span>
                                    @req.CreatedAt.ToString("dd/MM/yyyy HH:mm")
                                </span>
                                @if (req.AssignedUser != null)
                                {
                                    <span class="flex items-center gap-1">
                                        <span class="material-icons text-xs">person</span>
                                        @req.AssignedUser.FullName
                                    </span>
                                }
                                @if (req.RequestAttachments.Any())
                                {
                                    <span class="flex items-center gap-1">
                                        <span class="material-icons text-xs">attach_file</span>
                                        @req.RequestAttachments.Count tệp đính kèm
                                    </span>
                                }
                            </div>
                        </div>

                        <!-- Right: action -->
                        <div class="shrink-0">
                            <a asp-page="Details" asp-route-id="@req.RequestId"
                               class="inline-flex items-center gap-1.5 px-3 py-1.5 border border-slate-200 text-slate-600 hover:bg-emerald-50 hover:border-emerald-300 hover:text-emerald-700 rounded-lg text-xs font-medium transition-colors">
                                <span class="material-icons text-sm">visibility</span>
                                Xem chi tiết
                            </a>
                        </div>
                    </div>
                </div>
            }
        </div>

        <!-- Result count -->
        <p class="text-xs text-slate-400 text-center">
            Hiển thị @Model.Requests.Count yêu cầu
            @if (Model.StatusFilter.HasValue || Model.TypeFilter.HasValue)
            {
                <span> (đã lọc từ @Model.TotalCount yêu cầu)</span>
            }
        </p>
    }

</div>
