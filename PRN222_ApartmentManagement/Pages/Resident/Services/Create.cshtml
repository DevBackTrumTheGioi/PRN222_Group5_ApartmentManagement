@page
@model PRN222_ApartmentManagement.Pages.Resident.Services.CreateModel
@{
    ViewData["Title"] = "Tạo đơn dịch vụ";
    ViewData["Subtitle"] = "Chọn loại dịch vụ, ngày và thông tin cần thực hiện";
    ViewData["CurrentPage"] = "services";
}

<div class="mx-auto max-w-3xl space-y-6">
    <a asp-page="Index" class="inline-flex items-center text-sm text-slate-500 transition-colors hover:text-emerald-600">
        <span class="material-icons mr-1 text-lg">arrow_back</span>
        Quay lại danh sách dịch vụ
    </a>

    <form method="post" class="overflow-hidden rounded-xl border border-slate-200 bg-white shadow-sm">
        <div class="space-y-6 p-6">
            @if (!Model.ActiveServices.Any())
            {
                <div class="rounded-lg border border-amber-200 bg-amber-50 p-4 text-sm text-amber-700">
                    Hiện tại chưa có dịch vụ nào đang hoạt động.
                </div>
            }

            @if (!ModelState.IsValid)
            {
                <div class="flex gap-3 rounded-lg border border-red-200 bg-red-50 p-4">
                    <span class="material-icons mt-0.5 shrink-0 text-lg text-red-500">error_outline</span>
                    <div asp-validation-summary="All" class="space-y-1 text-sm text-red-600"></div>
                </div>
            }

            @if (Model.SelectedService != null)
            {
                var currentPrice = Model.GetCurrentPrice(Model.SelectedService);
                <div class="rounded-xl border border-slate-200 bg-slate-50 p-4">
                    <div class="flex flex-wrap items-start justify-between gap-3">
                        <div>
                            <p class="text-sm font-semibold text-slate-900">@Model.SelectedService.ServiceTypeName</p>
                            <p class="mt-1 text-xs text-slate-500">@(string.IsNullOrWhiteSpace(Model.SelectedService.Description) ? "Dịch vụ theo yêu cầu" : Model.SelectedService.Description)</p>
                        </div>
                        <div class="text-right">
                            <p class="text-xs text-slate-500">Giá hiện hành</p>
                            <p class="text-lg font-bold text-slate-900">@(currentPrice == null ? "Chưa có giá" : string.Format("{0:N0} đ", currentPrice.UnitPrice))</p>
                        </div>
                    </div>
                </div>
            }

            <div class="grid grid-cols-1 gap-6 md:grid-cols-2">
                <div class="space-y-1.5 md:col-span-2">
                    <label asp-for="Input.ApartmentId" class="text-sm font-medium text-slate-700"></label>
                    <select asp-for="Input.ApartmentId" asp-items="Model.ApartmentOptions"
                            class="w-full rounded-lg border border-slate-200 bg-white px-4 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-emerald-500">
                        <option value="">-- Chọn căn hộ --</option>
                    </select>
                    <span asp-validation-for="Input.ApartmentId" class="text-xs text-red-500"></span>
                </div>

                <div class="space-y-1.5 md:col-span-2">
                    <label asp-for="Input.ServiceTypeId" class="text-sm font-medium text-slate-700"></label>
                    <select asp-for="Input.ServiceTypeId" asp-items="Model.ServiceOptions"
                            class="w-full rounded-lg border border-slate-200 bg-white px-4 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-emerald-500">
                        <option value="">-- Chọn dịch vụ --</option>
                    </select>
                    <span asp-validation-for="Input.ServiceTypeId" class="text-xs text-red-500"></span>
                </div>

                <div class="space-y-1.5">
                    <label asp-for="Input.RequestedDate" class="text-sm font-medium text-slate-700"></label>
                    <input asp-for="Input.RequestedDate" class="w-full rounded-lg border border-slate-200 px-4 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-emerald-500" />
                    <span asp-validation-for="Input.RequestedDate" class="text-xs text-red-500"></span>
                </div>

                <div class="space-y-1.5">
                    <label asp-for="Input.RequestedTimeSlot" class="text-sm font-medium text-slate-700"></label>
                    <select asp-for="Input.RequestedTimeSlot" asp-items="Model.TimeSlotOptions"
                            class="w-full rounded-lg border border-slate-200 bg-white px-4 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-emerald-500">
                        <option value="">-- Chọn khung giờ --</option>
                    </select>
                    <span asp-validation-for="Input.RequestedTimeSlot" class="text-xs text-red-500"></span>
                </div>

                <div class="space-y-1.5 md:col-span-2">
                    <label asp-for="Input.Description" class="text-sm font-medium text-slate-700"></label>
                    <textarea asp-for="Input.Description" rows="5"
                              class="w-full rounded-lg border border-slate-200 px-4 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-emerald-500"
                              placeholder="Mô tả nhu cầu cụ thể, vị trí, ghi chú cho nhân viên..."></textarea>
                    <span asp-validation-for="Input.Description" class="text-xs text-red-500"></span>
                </div>
            </div>
        </div>

        <div class="flex items-center justify-end gap-3 border-t border-slate-200 bg-slate-50 px-6 py-4">
            <a asp-page="Index" class="rounded-lg px-4 py-2 text-sm font-medium text-slate-600 transition-colors hover:bg-slate-100">Hủy</a>
            <button type="submit" class="inline-flex items-center gap-2 rounded-lg bg-emerald-600 px-5 py-2 text-sm font-semibold text-white transition-colors hover:bg-emerald-700">
                <span class="material-icons text-base">send</span>
                Gửi đơn
            </button>
        </div>
    </form>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
