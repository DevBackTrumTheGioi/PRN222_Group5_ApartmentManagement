@page
@model PRN222_ApartmentManagement.Pages.Resident.Services.IndexModel
@{
    ViewData["Title"] = "Dịch vụ theo yêu cầu";
    ViewData["Subtitle"] = "Đặt các dịch vụ đang hoạt động cho căn hộ của bạn";
    ViewData["CurrentPage"] = "services";
}

<div class="space-y-6">
    <div class="rounded-xl border border-slate-200 bg-white p-4 shadow-sm">
        <form method="get" class="flex flex-wrap items-end gap-3">
            <div class="min-w-[220px] flex-1">
                <label class="mb-1 block text-xs font-medium text-slate-600">Tìm dịch vụ</label>
                <div class="relative">
                    <span class="material-icons absolute left-3 top-1/2 -translate-y-1/2 text-base text-slate-400">search</span>
                    <input asp-for="SearchTerm"
                           class="w-full rounded-lg border border-slate-200 bg-white py-2 pl-9 pr-3 text-sm focus:outline-none focus:ring-2 focus:ring-emerald-500"
                           placeholder="Tên dịch vụ, mô tả..." />
                </div>
            </div>

            <div class="flex gap-2">
                <button type="submit"
                        class="inline-flex items-center gap-1.5 rounded-lg bg-slate-700 px-4 py-2 text-sm font-medium text-white transition-colors hover:bg-slate-800">
                    <span class="material-icons text-base">filter_list</span>
                    Lọc
                </button>
                <a asp-page="MyOrders"
                   class="inline-flex items-center gap-1.5 rounded-lg border border-slate-200 px-4 py-2 text-sm font-medium text-slate-600 transition-colors hover:bg-slate-50">
                    <span class="material-icons text-base">list_alt</span>
                    Đơn của tôi
                </a>
            </div>
        </form>
    </div>

    @if (!Model.Services.Any())
    {
        <div class="rounded-xl border border-slate-200 bg-white p-16 text-center shadow-sm">
            <span class="material-icons mb-3 text-5xl text-slate-300">cleaning_services</span>
            <p class="font-medium text-slate-500">Không tìm thấy dịch vụ phù hợp.</p>
        </div>
    }
    else
    {
        <div class="grid grid-cols-1 gap-4 md:grid-cols-2 xl:grid-cols-3">
            @foreach (var service in Model.Services)
            {
                var currentPrice = Model.GetCurrentPrice(service);
                <div class="flex h-full flex-col rounded-xl border border-slate-200 bg-white p-5 shadow-sm transition-all hover:-translate-y-0.5 hover:border-emerald-200 hover:shadow-md">
                    <div class="mb-3 flex items-start justify-between gap-3">
                        <div>
                            <h3 class="text-lg font-semibold text-slate-900">@service.ServiceTypeName</h3>
                            <p class="mt-1 text-xs text-slate-500">@(string.IsNullOrWhiteSpace(service.MeasurementUnit) ? "Theo đơn" : service.MeasurementUnit)</p>
                        </div>
                        <span class="inline-flex items-center rounded-full border border-emerald-200 bg-emerald-50 px-2 py-0.5 text-xs font-medium text-emerald-700">
                            Đang mở
                        </span>
                    </div>

                    <p class="mb-4 flex-1 text-sm text-slate-600">
                        @(string.IsNullOrWhiteSpace(service.Description) ? "Dịch vụ đã sẵn sàng để cư dân đặt lịch thực hiện." : service.Description)
                    </p>

                    <div class="mb-4 rounded-lg bg-slate-50 p-3">
                        <p class="text-xs text-slate-500">Giá dự kiến</p>
                        <p class="mt-1 text-lg font-bold text-slate-900">@(currentPrice == null ? "Liên hệ Ban Quản lý" : string.Format("{0:N0} đ", currentPrice.UnitPrice))</p>
                    </div>

                    <div class="flex items-center justify-between gap-3">
                        <span class="text-xs text-slate-400">Giá sẽ được chốt tại thời điểm gửi đơn</span>
                        <a asp-page="Create" asp-route-serviceTypeId="@service.ServiceTypeId"
                           class="inline-flex items-center gap-1.5 rounded-lg bg-emerald-600 px-4 py-2 text-sm font-semibold text-white transition-colors hover:bg-emerald-700">
                            <span class="material-icons text-base">add_task</span>
                            Đặt dịch vụ
                        </a>
                    </div>
                </div>
            }
        </div>
    }
</div>
