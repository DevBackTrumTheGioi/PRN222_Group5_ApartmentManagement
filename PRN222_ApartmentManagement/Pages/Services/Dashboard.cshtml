@page
@model PRN222_ApartmentManagement.Pages.Services.DashboardModel
@{
    ViewData["Title"] = "Thống kê dịch vụ";
}

<div class="space-y-6">
    <div class="bg-white p-6 rounded-2xl border border-slate-200 shadow-sm">
        <div class="flex justify-between items-center mb-4">
            <h2 class="text-lg font-bold">Thống kê dịch vụ theo yêu cầu</h2>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-3 lg:grid-cols-4 gap-4">
            <div class="p-4 bg-slate-50 rounded-lg">
                <p class="text-sm text-slate-500">Tổng đơn</p>
                <h3 class="text-2xl font-bold">@Model.Data.TotalOrders</h3>
                <p class="text-xs text-slate-400">Tổng cộng: @Model.Data.TotalOrders đơn</p>
            </div>
            <div class="p-4 bg-slate-50 rounded-lg">
                <p class="text-sm text-slate500">Đang chờ</p>
                <h3 class="text-2xl font-bold">@Model.Data.Pending</h3>
            </div>
            <div class="p-4 bg-slate-50 rounded-lg">
                <p class="text-sm text-slate-500">Đang xử lý</p>
                <h3 class="text-2xl font-bold">@Model.Data.InProgress</h3>
            </div>
            <div class="p-4 bg-slate-50 rounded-lg">
                <p class="text-sm text-slate-500">Đã hoàn thành</p>
                <h3 class="text-2xl font-bold">@Model.Data.Completed</h3>
            </div>
        </div>

        <div class="mt-6">
            <h4 class="text-sm font-semibold mb-2">Đơn gần đây</h4>
            <div class="space-y-3">
                @foreach(var o in Model.RecentOrders)
                {
                    <div class="p-3 bg-white border rounded-lg flex items-center justify-between">
                        <div>
                            <div class="text-sm font-semibold">@o.OrderNumber</div>
                            <div class="text-xs text-slate-500">@o.ServiceType?.ServiceTypeName — @o.RequestedDate.ToString("dd/MM/yyyy")</div>
                        </div>
                        <div class="text-sm text-slate-700">@o.Status</div>
                    </div>
                }
            </div>
        </div>
    </div>
</div></div>