@page
@model PRN222_ApartmentManagement.Pages.Services.IndexModel
@{
    ViewData["Title"] = "Dịch vụ";
}

<div class="space-y-4">
    <div class="bg-white rounded-lg shadow p-4">
        <h2 class="text-lg font-bold mb-4">Danh sách dịch vụ</h2>
        <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
            @foreach (var s in Model.Services)
            {
                <div class="p-4 border rounded-lg bg-slate-50">
                    <div class="flex justify-between items-start">
                        <div>
                            <h3 class="font-bold">@s.ServiceType.ServiceTypeName</h3>
                            <p class="text-sm text-slate-500">@s.ServiceType.Description</p>
                        </div>
                        <div class="text-right">
                            <p class="font-black text-emerald-600">@((s.CurrentPrice ?? 0).ToString("N0")) đ</p>
                            <a class="text-sm text-emerald-600 font-semibold" href="/Services/Order?serviceTypeId=@s.ServiceType.ServiceTypeId">Đặt</a>
                        </div>
                    </div>
                </div>
            }
        </div>
    </div>
</div>
