@model dynamic

@{
    var model = (object)Model;
    var dict = model?.GetType().GetProperties().ToDictionary(p => p.Name, p => p.GetValue(model)?.ToString());
    
    string variant = dict?.ContainsKey("Variant") == true ? dict["Variant"] : "info";
    string title = dict?.ContainsKey("Title") == true ? dict["Title"] : "";
    string message = dict?.ContainsKey("Message") == true ? dict["Message"] : "";
    
    var variantClasses = variant switch
    {
        "success" => "bg-emerald-50 border border-emerald-200 text-emerald-900",
        "warning" => "bg-amber-50 border border-amber-200 text-amber-900",
        "error" => "bg-red-50 border border-red-200 text-red-900",
        _ => "bg-blue-50 border border-blue-200 text-blue-900"
    };
    
    var iconColor = variant switch
    {
        "success" => "text-emerald-600",
        "warning" => "text-amber-600",
        "error" => "text-red-600",
        _ => "text-blue-600"
    };
    
    var iconName = variant switch
    {
        "success" => "check_circle",
        "warning" => "warning",
        "error" => "error",
        _ => "info"
    };
}

<div class="@variantClasses rounded-lg p-4 flex items-start gap-3">
    <span class="material-icons @iconColor">@iconName</span>
    <div>
        @if (!string.IsNullOrEmpty(title))
        {
            <h3 class="font-semibold text-sm">@title</h3>
        }
        <p class="text-sm opacity-90">@message</p>
    </div>
</div>
