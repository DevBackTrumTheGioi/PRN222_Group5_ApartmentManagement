@{
    var variant = ViewBag.Variant ?? "info"; // info, success, warning, error
    var title = ViewBag.Title ?? "";
    var message = ViewBag.Message ?? "";
    var icon = ViewBag.Icon ?? "";
}

<div class="fixed inset-0 bg-black/50 hidden items-center justify-center z-50" id="modalOverlay">
    <div class="bg-white dark:bg-slate-800 rounded-xl shadow-xl max-w-md w-full mx-4">
        <div class="p-6">
            @if (!string.IsNullOrEmpty(icon) || !string.IsNullOrEmpty(title))
            {
                <div class="flex items-start gap-4 mb-4">
                    @if (!string.IsNullOrEmpty(icon))
                    {
                        <div class="w-12 h-12 rounded-full flex items-center justify-center flex-shrink-0 @(variant switch {
                            "success" => "bg-emerald-100 dark:bg-emerald-900/30",
                            "warning" => "bg-amber-100 dark:bg-amber-900/30",
                            "error" => "bg-red-100 dark:bg-red-900/30",
                            _ => "bg-blue-100 dark:bg-blue-900/30"
                        })">
                            <span class="material-icons text-xl @(variant switch {
                                "success" => "text-emerald-600 dark:text-emerald-400",
                                "warning" => "text-amber-600 dark:text-amber-400",
                                "error" => "text-red-600 dark:text-red-400",
                                _ => "text-blue-600 dark:text-blue-400"
                            })">@icon</span>
                        </div>
                    }
                    
                    <div class="flex-1">
                        @if (!string.IsNullOrEmpty(title))
                        {
                            <h2 class="text-lg font-semibold text-slate-900 dark:text-white">@title</h2>
                        }
                    </div>
                </div>
            }
            
            <div class="mb-6 text-slate-700 dark:text-slate-300 text-sm" id="modalBody">
                @if (!string.IsNullOrEmpty(message))
                {
                    @message
                }
            </div>
        </div>
        
        <div class="bg-slate-50 dark:bg-slate-900/50 border-t border-slate-200 dark:border-slate-700 px-6 py-4 flex gap-3 justify-end rounded-b-xl">
            <button onclick="document.getElementById('modalOverlay').remove()" class="px-4 py-2 text-slate-600 dark:text-slate-400 hover:bg-slate-100 dark:hover:bg-slate-800 rounded-lg transition-colors text-sm font-medium">
                Close
            </button>
            <button class="px-4 py-2 bg-blue-600 text-white hover:bg-blue-700 rounded-lg transition-colors text-sm font-medium">
                Confirm
            </button>
        </div>
    </div>
</div>
