@model dynamic

@{
    var model = (object)Model;
    var dict = model?.GetType().GetProperties().ToDictionary(p => p.Name, p => p.GetValue(model));
    
    string title = dict?.ContainsKey("Title") == true ? dict["Title"]?.ToString() : "";
    string subtitle = dict?.ContainsKey("Subtitle") == true ? dict["Subtitle"]?.ToString() : "";
    string buttonText = dict?.ContainsKey("ButtonText") == true ? dict["ButtonText"]?.ToString() : "";
    string buttonIcon = dict?.ContainsKey("ButtonIcon") == true ? dict["ButtonIcon"]?.ToString() : "add";
    string buttonHref = dict?.ContainsKey("ButtonHref") == true ? dict["ButtonHref"]?.ToString() : "#";
    bool showButton = dict?.ContainsKey("ShowButton") == true && dict["ShowButton"] is bool sb && sb;
    int notificationCount = dict?.ContainsKey("NotificationCount") == true && dict["NotificationCount"] is int nc ? nc : 0;
    
    var breadcrumbItems = dict?.ContainsKey("BreadcrumbItems") == true ? dict["BreadcrumbItems"] as System.Collections.IEnumerable : null;
}

<header class="flex justify-between items-start mb-2">
    <!-- Left: Breadcrumb + Title -->
    <div>
        @if (breadcrumbItems != null)
        {
            <nav class="flex text-sm text-slate-500 mb-1 gap-1.5 items-center">
                @{
                    var itemList = breadcrumbItems.Cast<object>().ToList();
                    for (int i = 0; i < itemList.Count; i++)
                    {
                        var item = itemList[i];
                        var itemDict = item?.GetType().GetProperties().ToDictionary(p => p.Name, p => p.GetValue(item)?.ToString());
                        string label = itemDict?.ContainsKey("Label") == true ? itemDict["Label"] : "";
                        string href = itemDict?.ContainsKey("Href") == true ? itemDict["Href"] : "";
                        bool isLast = i == itemList.Count - 1;
                        
                        if (isLast)
                        {
                            <span class="text-slate-900 font-medium">@label</span>
                        }
                        else
                        {
                            <a class="hover:text-emerald-600 transition-colors" href="@href">@label</a>
                            <span class="material-icons text-base text-slate-400">chevron_right</span>
                        }
                    }
                }
            </nav>
        }
        <h1 class="text-2xl font-bold text-slate-900 tracking-tight">@title</h1>
        @if (!string.IsNullOrWhiteSpace(subtitle))
        {
            <p class="mt-1 text-sm text-slate-500">@subtitle</p>
        }
    </div>
    
    <!-- Right: Notification + Action Button -->
    <div class="flex items-center gap-3">
        <div class="relative" id="notifBellWrapper">
            <button id="notifBellBtn"
                    type="button"
                    class="relative flex h-10 w-10 items-center justify-center rounded-full border border-slate-200 bg-white transition-all hover:border-emerald-400 hover:bg-emerald-50"
                    onclick="toggleNotifDropdown()">
                <span class="material-icons text-slate-500">notifications</span>
                <span id="notifBadge"
                      class="absolute -top-1 -right-1 min-w-[18px] h-[18px] bg-red-500 text-white text-[10px] font-bold rounded-full flex items-center justify-center border-2 border-white @(notificationCount > 0 ? "" : "hidden")">
                    @(notificationCount > 99 ? "99+" : notificationCount.ToString())
                </span>
            </button>

            <div id="notifDropdown" class="absolute right-0 top-full z-50 mt-2 hidden w-96 overflow-hidden rounded-xl border border-slate-200 bg-white shadow-xl">
                <div class="flex items-center justify-between border-b border-slate-200 bg-slate-50 px-4 py-3">
                    <h3 class="text-sm font-semibold text-slate-900">Thông báo</h3>
                    <button type="button"
                            onclick="markAllReadFromDropdown()"
                            class="text-xs font-medium text-emerald-600 hover:text-emerald-700">
                        Đánh dấu tất cả đã đọc
                    </button>
                </div>
                <div id="notifDropdownList" class="max-h-80 overflow-y-auto">
                    <div class="flex items-center justify-center py-8 text-slate-400">
                        <span class="material-icons mr-2 animate-spin">refresh</span> Đang tải...
                    </div>
                </div>
                <a href="/Notifications" class="block border-t border-slate-200 py-3 text-center text-sm font-medium text-emerald-600 transition-colors hover:bg-emerald-50">
                    Xem tất cả thông báo
                </a>
            </div>
        </div>
        
        <!-- Primary Action Button -->
        @if (showButton && !string.IsNullOrEmpty(buttonText))
        {
            <a href="@buttonHref" class="bg-emerald-500 text-white px-4 py-2.5 rounded-lg font-semibold text-sm flex items-center gap-2 hover:bg-emerald-600 transition-all">
                <span class="material-icons text-lg">@buttonIcon</span>
                @buttonText
            </a>
        }
    </div>
</header>
