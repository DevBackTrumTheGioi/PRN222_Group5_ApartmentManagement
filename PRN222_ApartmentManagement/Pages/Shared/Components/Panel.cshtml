@{
    var title = ViewBag.Title ?? "Section Title";
}

<div class="bg-white dark:bg-slate-800 border border-slate-200 dark:border-slate-700 rounded-xl overflow-hidden shadow-sm">
    @if (!string.IsNullOrEmpty(title))
    {
        <div class="px-6 py-4 border-b border-slate-200 dark:border-slate-700">
            <h2 class="text-lg font-semibold text-slate-900 dark:text-white">@title</h2>
        </div>
    }
    
    <div class="px-6 py-4">
        @RenderBody()
    </div>
</div>

