@{
    var label = ViewBag.Label ?? "";
    var cssClass = ViewBag.CssClass ?? "";
    var isRequired = ViewBag.IsRequired ?? false;
}

<div class="@cssClass">
    @if (!string.IsNullOrEmpty(label))
    {
        <label class="block text-sm font-semibold text-slate-900 dark:text-slate-100 mb-2">
            @label
            @if (isRequired)
            {
                <span class="text-red-600">*</span>
            }
        </label>
    }
    
    <select class="w-full px-4 py-2.5 bg-slate-50 dark:bg-slate-800 border border-slate-200 dark:border-slate-700 rounded-lg focus:ring-2 focus:ring-blue-500/40 focus:border-blue-500 focus:bg-white dark:focus:bg-slate-700 transition-all cursor-pointer">
        @RenderBody()
    </select>
</div>

