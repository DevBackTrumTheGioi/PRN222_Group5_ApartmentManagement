@page
@model TailwindDemoModel

@{
    
    ViewData["Title"] = "Home page - Tailwind CSS";
}

<div class="min-h-screen bg-gradient-to-br from-blue-50 to-indigo-100">
    <!-- Hero Section -->
    <div class="container mx-auto px-4 py-20">
        <div class="text-center mb-12">
            <h1 class="text-5xl font-bold text-gray-900 mb-6">
                Chào mừng đến <span class="text-transparent bg-clip-text bg-gradient-to-r from-blue-600 to-indigo-600">Tailwind CSS</span>
            </h1>
            <p class="text-xl text-gray-600 mb-8">
                Tailwind CSS đã được cài đặt thành công vào dự án của bạn!
            </p>
            <div class="flex gap-4 justify-center">
                <a href="#" class="px-8 py-3 bg-blue-600 text-white font-semibold rounded-lg hover:bg-blue-700 transition-colors">
                    Bắt Đầu
                </a>
                <a href="https://tailwindcss.com" target="_blank" class="px-8 py-3 bg-white text-blue-600 font-semibold rounded-lg border border-blue-200 hover:bg-gray-50 transition-colors">
                    Tài Liệu Tailwind
                </a>
            </div>
        </div>

        <!-- Feature Cards -->
        <div class="grid md:grid-cols-3 gap-8 mt-20">
            <div class="bg-white rounded-lg shadow-lg p-8 hover:shadow-xl transition-shadow">
                <div class="text-4xl mb-4">🎨</div>
                <h3 class="text-xl font-bold text-gray-900 mb-3">Utility-First CSS</h3>
                <p class="text-gray-600">
                    Xây dựng thiết kế tùy chỉnh mà không cần rời khỏi HTML của bạn với các lớp tiện ích tái sử dụng.
                </p>
            </div>

            <div class="bg-white rounded-lg shadow-lg p-8 hover:shadow-xl transition-shadow">
                <div class="text-4xl mb-4">⚡</div>
                <h3 class="text-xl font-bold text-gray-900 mb-3">Hiệu Suất Cao</h3>
                <p class="text-gray-600">
                    Chỉ tạo CSS cho các utility mà bạn thực sự sử dụng. Loại bỏ tất cả CSS không sử dụng.
                </p>
            </div>

            <div class="bg-white rounded-lg shadow-lg p-8 hover:shadow-xl transition-shadow">
                <div class="text-4xl mb-4">🚀</div>
                <h3 class="text-xl font-bold text-gray-900 mb-3">Phát Triển Nhanh</h3>
                <p class="text-gray-600">
                    Xây dựng các giao diện phức tạp mà không phải viết CSS tùy chỉnh. Lên đến gấp 5 lần nhanh hơn.
                </p>
            </div>
        </div>

        <!-- Info Section -->
        <div class="mt-20 bg-white rounded-lg shadow-lg p-8">
            <h2 class="text-3xl font-bold text-gray-900 mb-6">Các Bước Tiếp Theo</h2>
            <div class="space-y-4">
                <div class="flex items-start">
                    <div class="flex-shrink-0">
                        <div class="flex items-center justify-center h-12 w-12 rounded-md bg-blue-500 text-white">
                            1
                        </div>
                    </div>
                    <div class="ml-4">
                        <h3 class="text-lg font-medium text-gray-900">Chạy Watch Mode</h3>
                        <p class="text-gray-600 mt-2">
                            Chạy <code class="bg-gray-100 px-2 py-1 rounded">npm run watch:css</code> để tự động rebuild CSS khi bạn thay đổi HTML.
                        </p>
                    </div>
                </div>

                <div class="flex items-start">
                    <div class="flex-shrink-0">
                        <div class="flex items-center justify-center h-12 w-12 rounded-md bg-blue-500 text-white">
                            2
                        </div>
                    </div>
                    <div class="ml-4">
                        <h3 class="text-lg font-medium text-gray-900">Bắt Đầu Styling</h3>
                        <p class="text-gray-600 mt-2">
                            Sử dụng các lớp Tailwind utility trong HTML của bạn. Ví dụ: <code class="bg-gray-100 px-2 py-1 rounded">class="text-blue-600 font-bold"</code>
                        </p>
                    </div>
                </div>

                <div class="flex items-start">
                    <div class="flex-shrink-0">
                        <div class="flex items-center justify-center h-12 w-12 rounded-md bg-blue-500 text-white">
                            3
                        </div>
                    </div>
                    <div class="ml-4">
                        <h3 class="text-lg font-medium text-gray-900">Tùy Chỉnh Theme</h3>
                        <p class="text-gray-600 mt-2">
                            Chỉnh sửa <code class="bg-gray-100 px-2 py-1 rounded">tailwind.config.js</code> để tùy chỉnh màu sắc, font chữ và nhiều hơn nữa.
                        </p>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>



