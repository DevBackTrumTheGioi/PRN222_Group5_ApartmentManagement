@page
@model PRN222_ApartmentManagement.Pages.Visitors.CheckInModel
@{
    ViewData["Title"] = "Check-in khách";
}

<div class="max-w-2xl mx-auto p-6 bg-white rounded-xl border">
    <h2 class="text-lg font-bold mb-4">Check-in khách</h2>

    <div class="space-y-3">
        <div><strong>Tên:</strong> @Model.Visitor?.VisitorName</div>
        <div><strong>Sđt:</strong> @Model.Visitor?.PhoneNumber</div>
        <div><strong>Ngày:</strong> @Model.Visitor?.VisitDate.ToString("dd/MM/yyyy")</div>
        <div><strong>Ghi chú:</strong> @Model.Visitor?.Notes</div>

        <form method="post">
            <button type="submit" class="btn btn-primary">Xác nhận check-in</button>
            <a asp-page="Index" class="btn btn-secondary">Hủy</a>
        </form>
    </div>
</div>
