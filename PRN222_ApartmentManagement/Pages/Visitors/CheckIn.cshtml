@page
@model PRN222_ApartmentManagement.Pages.Visitors.CheckInModel
@{
    ViewData["Title"] = "Check-in khách";
}

<div class="max-w-2xl mx-auto p-6 bg-white rounded-xl border shadow-sm">
    <h2 class="text-xl font-semibold mb-6">Check-in khách</h2>

    <div class="grid grid-cols-2 gap-y-3 text-sm">

        <div class="text-slate-500">Tên</div>
        <div class="font-medium">@Model.Visitor?.VisitorName</div>

        <div class="text-slate-500">SĐT</div>
        <div>@Model.Visitor?.PhoneNumber</div>

        <div class="text-slate-500">CMND/CCCD</div>
        <div>@Model.Visitor?.IdentityCard</div>

        <div class="text-slate-500">Căn hộ</div>
        <div>@Model.Visitor?.Apartment?.ApartmentNumber</div>

        <div class="text-slate-500">Ngày</div>
        <div>@Model.Visitor?.VisitDate.ToString("dd/MM/yyyy")</div>

        <div class="text-slate-500">Giờ dự kiến</div>
        <div>@Model.Visitor?.CheckInTime?.ToString("HH:mm")</div>

        <div class="text-slate-500">Người đăng ký</div>
        <div>@Model.Visitor?.RegisteredByUser?.FullName</div>

        <div class="text-slate-500">Ghi chú</div>
        <div>@Model.Visitor?.Notes</div>

    </div>

    <div class="mt-6 flex justify-end gap-2">
        <a asp-page="Index"
           class="px-4 py-2 border border-slate-300 rounded-lg hover:bg-slate-100">
            Hủy
        </a>

        <form method="post">
            <button type="submit"
                    class="px-4 py-2 bg-emerald-600 text-white rounded-lg hover:bg-emerald-700">
                Xác nhận check-in
            </button>
        </form>
    </div>
</div></div>