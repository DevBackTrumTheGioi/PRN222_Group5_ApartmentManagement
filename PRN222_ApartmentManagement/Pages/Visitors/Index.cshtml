@page
@model PRN222_ApartmentManagement.Pages.Visitors.IndexModel
@{
    ViewData["Title"] = "Quản lý khách";
}

<div class="p-6 bg-white rounded-xl border">
    <h2 class="text-lg font-bold mb-4">Quản lý khách đã đăng ký</h2>

    @if (TempData["Success"] != null || TempData["SuccessMessage"] != null)
    {
        <div class="flex items-center gap-3 p-4 bg-emerald-50 border border-emerald-200 rounded-xl text-emerald-700 text-sm mb-4">
            <span class="material-icons text-emerald-500">check_circle</span>
            @((TempData["SuccessMessage"] ?? TempData["Success"])?.ToString())
        </div>
    }
    @if (TempData["Error"] != null || TempData["ErrorMessage"] != null)
    {
        <div class="flex items-center gap-3 p-4 bg-red-50 border border-red-200 rounded-xl text-red-700 text-sm mb-4">
            <span class="material-icons text-red-500">error</span>
            @((TempData["ErrorMessage"] ?? TempData["Error"])?.ToString())
        </div>
    }

    <form method="get" class="mb-4 flex items-center gap-3">

        <!-- Input dài hơn -->
        <input type="text" name="SearchTerm" value="@Model.SearchTerm"
               placeholder="Tìm theo tên, SĐT, CMND, căn hộ..."
               class="flex-1 min-w-[400px] px-4 py-2 border border-slate-300 rounded-lg
                  focus:outline-none focus:ring-2 focus:ring-emerald-500" />

        <!-- Nhóm nút -->
        <div class="flex items-center gap-2">
            <button type="submit"
                    class="px-4 py-2 bg-emerald-600 text-white rounded-lg hover:bg-emerald-700">
                Tìm
            </button>

            <a asp-page="Index"
               class="px-4 py-2 border border-slate-300 rounded-lg hover:bg-slate-100">
                Reset
            </a>
        </div>

    </form>

    <table class="w-full text-sm">
        <thead>
            <tr class="text-left text-slate-500 text-xs uppercase">
                <th class="px-4 py-2">Tên</th>
                <th class="px-4 py-2">Sđt</th>
                <th class="px-4 py-2">CMND</th>
                <th class="px-4 py-2">Căn hộ</th>
                <th class="px-4 py-2">Ngày</th>
                <th class="px-4 py-2">Giờ dự kiến</th>
                <th class="px-4 py-2">Check-out</th>
                <th class="px-4 py-2">Trạng thái</th>
                <th class="px-4 py-2">Đăng ký bởi</th>
                <th class="px-4 py-2"></th>
            </tr>
        </thead>
        <tbody>
            @foreach (var v in Model.Visitors)
            {
                <tr class="border-t">
                    <td class="px-4 py-2 whitespace-nowrap">@v.VisitorName</td>
                    <td class="px-4 py-2 whitespace-nowrap">@v.PhoneNumber</td>
                    <td class="px-4 py-2 whitespace-nowrap">@v.IdentityCard</td>
                    <td class="px-4 py-2 whitespace-nowrap">@v.Apartment?.ApartmentNumber</td>
                    <td class="px-4 py-2 whitespace-nowrap">@v.VisitDate.ToString("dd/MM/yyyy")</td>
                    <td class="px-4 py-2 whitespace-nowrap">@v.CheckInTime?.ToString("HH:mm")</td>
                    <td class="px-4 py-2 whitespace-nowrap">@v.CheckOutTime?.ToString("dd/MM HH:mm")</td>
                    <td class="px-4 py-2 whitespace-nowrap">@v.Status</td>
                    <td class="px-4 py-2 whitespace-nowrap">@v.RegisteredByUser?.FullName</td>
                    <td class="px-4 py-2 text-right">
                        @if (v.Status == PRN222_ApartmentManagement.Models.Enums.VisitorStatus.Pending)
                        {
                            <a asp-page="CheckIn" asp-route-id="@v.VisitorId" class="text-emerald-600 mr-2">Check-in</a>
                        }
                        else if (v.Status == PRN222_ApartmentManagement.Models.Enums.VisitorStatus.CheckedIn)
                        {
                            <a asp-page="CheckOut" asp-route-id="@v.VisitorId" class="text-rose-600">Check-out</a>
                        }
                    </td>
                </tr>
            }
        </tbody>
    </table>

    <div class="mt-4 px-4 py-3 bg-slate-50 border-t border-slate-100 rounded-b-lg flex items-center justify-between">
        <div>
            <p class="text-sm text-slate-500">Hiển thị <span class="font-medium text-slate-900">@((Model.PageIndex - 1) * Model.PageSize + 1)</span> - <span class="font-medium text-slate-900">@Math.Min(Model.PageIndex * Model.PageSize, Model.TotalItems)</span> trong tổng số <span class="font-medium text-slate-900">@Model.TotalItems</span> bản ghi</p>
        </div>

        <div class="flex items-center gap-2">
            <form method="get" class="inline-flex items-center gap-2">
                <input type="hidden" name="SearchTerm" value="@Model.SearchTerm" />
                <input type="hidden" name="PageIndex" value="@(Model.PageIndex - 1)" />
                <input type="hidden" name="PageSize" value="@Model.PageSize" />
                <button class="px-3 py-1 bg-white border border-slate-200 rounded-lg text-sm" @(Model.PageIndex == 1 ? "disabled" : "")>Trước</button>
            </form>

            <div class="flex items-center gap-1">
                @for (int i = 1; i <= Model.TotalPages; i++)
                {
                    <a href="?SearchTerm=@Model.SearchTerm&pageIndex=@i&pageSize=@Model.PageSize" class="w-8 h-8 rounded-lg text-sm font-medium flex items-center justify-center transition-colors @(i == Model.PageIndex ? "bg-primary-600 text-white font-bold" : "text-slate-600 hover:bg-slate-100")">@i</a>
                }
            </div>

            <form method="get" class="inline-flex items-center gap-2">
                <input type="hidden" name="SearchTerm" value="@Model.SearchTerm" />
                <input type="hidden" name="PageIndex" value="@(Model.PageIndex + 1)" />
                <input type="hidden" name="PageSize" value="@Model.PageSize" />
                <button class="px-3 py-1 bg-white border border-slate-200 rounded-lg text-sm" @(Model.PageIndex == Model.TotalPages ? "disabled" : "")>Sau</button>
            </form>

            <div class="ml-4">
                <form method="get">
                    <input type="hidden" name="SearchTerm" value="@Model.SearchTerm" />
                    <label class="text-xs text-slate-500 mr-2">Số lượng</label>
                    <select name="PageSize" onchange="this.form.submit()" class="px-2 py-1 border rounded">
                        <option value="10" selected="@(Model.PageSize==10)">10</option>
                        <option value="20" selected="@(Model.PageSize==20)">20</option>
                        <option value="50" selected="@(Model.PageSize==50)">50</option>
                        <option value="100" selected="@(Model.PageSize==100)">100</option>
                    </select>
                </form>
            </div>
        </div>
    </div>
</div>
