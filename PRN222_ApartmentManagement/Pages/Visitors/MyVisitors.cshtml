@page
@model PRN222_ApartmentManagement.Pages.Visitors.MyVisitorsModel
@{
    ViewData["Title"] = "Khách của tôi";
}

<div class="max-w-4xl mx-auto p-6 bg-white rounded-xl border">
    <div class="flex items-center justify-between mb-4">
        <h2 class="text-lg font-bold">Danh sách khách đã đăng ký</h2>
        <a asp-page="Register" class="px-3 py-2 bg-slate-50 border border-slate-200 rounded-lg text-sm hover:bg-slate-100">Đăng ký khách mới</a>
    </div>

    @if (TempData["Success"] != null)
    {
        <div class="flex items-center gap-3 p-4 bg-emerald-50 border border-emerald-200 rounded-xl text-emerald-700 text-sm mb-4">
            <span class="material-icons text-emerald-500">check_circle</span>
            @TempData["Success"]
        </div>
    }
    @if (TempData["Error"] != null)
    {
        <div class="flex items-center gap-3 p-4 bg-red-50 border border-red-200 rounded-xl text-red-700 text-sm mb-4">
            <span class="material-icons text-red-500">error</span>
            @TempData["Error"]
        </div>
    }

    <table class="w-full text-sm">
        <thead>
            <tr class="text-left text-slate-500 text-xs uppercase">
                <th class="px-4 py-2">Tên</th>
                <th class="px-4 py-2">Sđt</th>
                <th class="px-4 py-2">CMND</th>
                <th class="px-4 py-2">Ngày</th>
                <th class="px-4 py-2">Giờ dự kiến</th>
                <th class="px-4 py-2">Trạng thái</th>
                <th class="px-4 py-2">Ghi chú</th>
                <th class="px-4 py-2"></th>
            </tr>
        </thead>
        <tbody>
            @foreach (var v in Model.Visitors)
            {
                <tr class="border-t">
                    <td class="px-4 py-2">@v.VisitorName</td>
                    <td class="px-4 py-2">@v.PhoneNumber</td>
                    <td class="px-4 py-2">@v.IdentityCard</td>
                    <td class="px-4 py-2">@v.VisitDate.ToString("dd/MM/yyyy")</td>
                    <td class="px-4 py-2">@v.CheckInTime?.ToString("HH:mm")</td>
                    <td class="px-4 py-2">@v.Status</td>
                    <td class="px-4 py-2">@v.Notes</td>
                    <td class="px-4 py-2 text-right">
                        @if (v.Status == PRN222_ApartmentManagement.Models.Enums.VisitorStatus.Pending)
                        {
                            <form method="post" asp-page-handler="Cancel" class="inline">
                                <input type="hidden" name="id" value="@v.VisitorId" />
                                <button type="submit" class="text-rose-600">Hủy</button>
                            </form>
                        }
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>
